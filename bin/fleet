#!/bin/bash
# shellcheck disable=SC1090  # we source manifests discovered at runtime; paths are not constants
# fleet — one-glance status across every project running fleet agents.
#
# Usage:
#   fleet status              survey all projects (default)
#   fleet status <slug>       just one
#   fleet list                list discovered projects and their manifests
#   fleet doctor              diagnose every installed project (PASS/WARN/FAIL)
#   fleet doctor --json       machine-readable summary for fleet-control
#   fleet doctor --slug NAME  restrict to one project
#   fleet prompts-sha         print the SHA256 of the kit's prompts/ tree
#                             (ticket 0005 — for PROMPTS_SHA pinning)
#
# Discovers projects by scanning for */agents.config.sh under FLEET_PROJECTS_ROOT
# (default ~/Desktop/projects). Run interactively — it reads from ~/Desktop, so
# it is not subject to the launchd TCC restriction the agents are.
#
# The doctor subcommand honours FLEET_DISCOVERY_ROOT (default ~/Desktop/projects)
# as the single scan root. This is what tests/doctor.sh uses to point at a
# fixture instead of the host's real ~/Desktop tree. Set
# FLEET_SKIP_INSTALLED_LIB_SHA=1 to skip the installed-vs-repo lib SHA check
# (it WARNs anyway when ~/.local/share/agent-fleet/lib is absent — the env
# override is mostly for test hosts that intentionally have no install).

set -uo pipefail

ROOT="${FLEET_PROJECTS_ROOT:-$HOME/Desktop/projects}"
INSTALLED="$HOME/.local/share/agent-fleet/projects"
DOMAIN="gui/$UID"
CMD="${1:-status}"
WANT="${2:-}"

c_dim=$'\033[2m'; c_red=$'\033[31m'; c_grn=$'\033[32m'; c_ylw=$'\033[33m'
c_bld=$'\033[1m'; c_rst=$'\033[0m'

# Manifests live in two places: the repo working tree (may be on a branch that
# doesn't have it yet) and the TCC-safe install location (what's actually
# deployed). Union both and de-dup by SLUG so a project shows whether its
# manifest has merged to main or is still on a PR branch. Working-tree copies are
# listed first, so they win the de-dup (they sit next to docs/LESSONS.md).
discover() {
  local _seen=""
  { find "$ROOT" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
    find "$INSTALLED" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
  } | while read -r m; do
    # shellcheck disable=SC1090  # path is discovered at runtime
    local slug; slug=$( (source "$m"; echo "${SLUG:-}") 2>/dev/null )
    case " $_seen " in *" $slug "*) ;; *) _seen="$_seen $slug"; echo "$m";; esac
  done
}

human_age() {  # $1 = epoch seconds of an mtime → "3m" / "2h" / "5d" / "—"
  [ -z "${1:-}" ] && { echo "—"; return; }
  local now diff; now=$(date +%s); diff=$(( now - $1 ))
  if   [ $diff -lt 3600 ];  then echo "$(( diff/60 ))m ago"
  elif [ $diff -lt 86400 ]; then echo "$(( diff/3600 ))h ago"
  else echo "$(( diff/86400 ))d ago"; fi
}

days_until() {  # $1 = YYYYMMDD → integer days from today (may be negative)
  local target; target=$(date -j -f "%Y%m%d" "$1" +%s 2>/dev/null) || { echo 999; return; }
  local today; today=$(date -j -f "%Y%m%d" "$(date +%Y%m%d)" +%s)
  echo $(( (target - today) / 86400 ))
}

newest_log_epoch() {  # $1 = log dir → mtime of newest *.log, or empty
  local d="$1"; [ -d "$d" ] || return
  local f; f=$(ls -t "$d"/*.log 2>/dev/null | head -1) || return
  [ -n "$f" ] && stat -f %m "$f" 2>/dev/null
}

# --- doctor ---------------------------------------------------------------
# `fleet doctor` scans FLEET_DISCOVERY_ROOT (default ~/Desktop/projects) for
# */agents.config.sh, then runs seven named checks per project. Output is
# either one block per project (default) or a single JSON document keyed by
# {"projects":[{"slug":..,"checks":[{"name":..,"status":..,"reason":..}]}]}.
# Exit 0 if no FAIL across any project; exit 1 if any check is FAIL. WARN
# never fails the exit code — it's an "ok but look at me" signal.
#
# Checks (run in this order, names are the JSON-stable contract):
#   config             agents.config.sh parseable; SLUG/REPO_URL/SELF_CANCEL set
#   self_cancel        SELF_CANCEL not in the past (FAIL), >3 days out (PASS)
#   agents_md          AGENTS.md present + "## Agent parameters" section
#   backlog            docs/backlog/README.md + scripts/check-backlog.mjs exist
#   launchd_loaded     com.<slug>.agent-{ship,groom,review} are loaded
#                      (+ eng if ENG_ENABLED=1)
#   installed_lib_sha  ~/.local/share/agent-fleet/lib SHA matches the repo's
#                      lib/ SHA (WARN when either side is absent)
#   gh_auth            `gh auth status` exits 0
#   prompts_pinned     manifest's PROMPTS_SHA matches the kit's current
#                      prompts/ SHA (ticket 0005). PASS if set + matches,
#                      WARN if unset, FAIL if mismatched.

DOCTOR_ROOT="${FLEET_DISCOVERY_ROOT:-$HOME/Desktop/projects}"

# Repo lib/ dir — relative to this script (bin/fleet → ../lib).
doctor_repo_lib() {
  local self; self="$( cd "$( dirname "$0" )" && pwd )"
  echo "$self/../lib"
}

# Sum of `shasum` over every *.sh under a lib dir, sorted, joined. Stable
# across machines because we sort the filenames first. Echoes empty string if
# the dir is missing or contains no shell files.
doctor_lib_sha() {
  local dir="$1"
  [ -d "$dir" ] || return 0
  (cd "$dir" && find . -type f -name '*.sh' | sort | xargs shasum 2>/dev/null) | shasum | awk '{print $1}'
}

# --- prompts-sha ----------------------------------------------------------
# Ticket 0005. Prints the SHA256 of the concatenation of every *.md under the
# kit's prompts/ dir, with filenames sorted for cross-machine determinism.
# This is the value an operator pins via `PROMPTS_SHA=...` in their manifest
# so a future prompt edit surfaces as a `prompts_drift` warning in the runner.
#
# Defined above the doctor block because doctor's prompts_pinned check calls
# it directly — bash needs the function defined before it's referenced.
#
# Resolution order:
#   1. $FLEET_KIT_ROOT/prompts (escape hatch for fleet-control / tests)
#   2. The repo this script lives in: bin/fleet → ../prompts
#   3. The installed kit at ~/.local/share/agent-fleet/prompts
# First hit wins. Falls through with exit 1 + a stderr message if none exist
# so `PROMPTS_SHA=$(fleet prompts-sha)` doesn't silently bake in an empty pin.
fleet_prompts_sha() {
  local self prompts_dir=""
  self="$( cd "$( dirname "$0" )" && pwd )"
  for cand in \
    "${FLEET_KIT_ROOT:-}/prompts" \
    "$self/../prompts" \
    "$HOME/.local/share/agent-fleet/prompts"; do
    if [ -n "$cand" ] && [ -d "$cand" ]; then
      prompts_dir="$cand"
      break
    fi
  done
  if [ -z "$prompts_dir" ]; then
    echo "fleet prompts-sha: no prompts/ dir found (looked in FLEET_KIT_ROOT, $self/../prompts, ~/.local/share/agent-fleet/prompts)" >&2
    return 1
  fi
  # The ticket's formula verbatim. `find | sort` makes the order stable;
  # `xargs cat` concatenates contents; `shasum -a 256` is on every macOS.
  ( cd "$prompts_dir/.." && find prompts -type f -name '*.md' | sort | xargs cat ) \
    | shasum -a 256 | awk '{print $1}'
}

if [ "$CMD" = "prompts-sha" ]; then
  fleet_prompts_sha
  exit $?
fi

# Hand-rolled JSON string escape — same intent as common.sh _json_escape but
# bin/fleet doesn't source common.sh. Keep this in sync if either grows.
doctor_json_escape() {
  local s="${1-}" out="" i ch code
  for (( i=0; i<${#s}; i++ )); do
    ch="${s:i:1}"
    case "$ch" in
      '\') out+='\\' ;;
      '"') out+='\"' ;;
      $'\b') out+='\b' ;;
      $'\f') out+='\f' ;;
      $'\n') out+='\n' ;;
      $'\r') out+='\r' ;;
      $'\t') out+='\t' ;;
      *) printf -v code '%d' "'$ch"
         if [ "$code" -lt 32 ]; then printf -v out '%s\\u%04x' "$out" "$code"
         else out+="$ch"; fi ;;
    esac
  done
  printf '%s' "$out"
}

# Run all seven checks for one manifest. Echoes one "name|status|reason" line
# per check on stdout. Caller renders or JSON-encodes.
doctor_run_checks() {
  local manifest="$1"
  local proj_dir; proj_dir="$(dirname "$manifest")"
  local slug="" ns="" sc="" eng="0" repo_url=""

  # check: config -- subshell so vars don't leak across projects
  local cfg_status="PASS" cfg_reason=""
  local probe
  probe=$(
    # shellcheck disable=SC1090  # discovered at runtime
    ( source "$manifest" 2>/dev/null
      echo "SLUG=${SLUG:-}"
      echo "NAMESPACE=${NAMESPACE:-com.fleet.${SLUG:-x}}"
      echo "SELF_CANCEL=${SELF_CANCEL:-}"
      echo "ENG_ENABLED=${ENG_ENABLED:-0}"
      echo "REPO_URL=${REPO_URL:-}"
      echo "PROMPTS_SHA=${PROMPTS_SHA:-}"
    ) 2>/dev/null
  ) || true
  slug="$(echo "$probe" | sed -n 's/^SLUG=//p')"
  ns="$(echo "$probe" | sed -n 's/^NAMESPACE=//p')"
  sc="$(echo "$probe" | sed -n 's/^SELF_CANCEL=//p')"
  eng="$(echo "$probe" | sed -n 's/^ENG_ENABLED=//p')"
  repo_url="$(echo "$probe" | sed -n 's/^REPO_URL=//p')"
  local pinned_sha; pinned_sha="$(echo "$probe" | sed -n 's/^PROMPTS_SHA=//p')"
  if [ -z "$slug" ] || [ -z "$repo_url" ] || [ -z "$sc" ]; then
    cfg_status="FAIL"
    cfg_reason="manifest missing required vars (SLUG/REPO_URL/SELF_CANCEL)"
  fi
  echo "config|$cfg_status|$cfg_reason"
  # Tell the caller which slug we resolved so it can name the block.
  echo "__SLUG__|$slug|"

  # check: self_cancel
  local sc_status="PASS" sc_reason="" days=""
  if [ -z "$sc" ]; then
    sc_status="FAIL"; sc_reason="SELF_CANCEL not set"
  else
    days=$(days_until "$sc")
    if [ "$days" -lt 0 ]; then
      sc_status="FAIL"; sc_reason="SELF_CANCEL expired ${days}d ago ($sc)"
    elif [ "$days" -le 3 ]; then
      sc_status="WARN"; sc_reason="SELF_CANCEL within ${days}d ($sc)"
    fi
  fi
  echo "self_cancel|$sc_status|$sc_reason"

  # check: agents_md — file present + "## Agent parameters" section
  local am="$proj_dir/AGENTS.md"
  local am_status="PASS" am_reason=""
  if [ ! -f "$am" ]; then
    am_status="FAIL"; am_reason="AGENTS.md not found at $am"
  elif ! grep -q '^##[[:space:]]\+Agent parameters' "$am"; then
    am_status="FAIL"; am_reason="AGENTS.md missing '## Agent parameters' section"
  fi
  echo "agents_md|$am_status|$am_reason"

  # check: backlog — README.md and check-backlog.mjs
  local bl_status="PASS" bl_reason="" missing=""
  [ -f "$proj_dir/docs/backlog/README.md" ] || missing="$missing docs/backlog/README.md"
  [ -f "$proj_dir/scripts/check-backlog.mjs" ] || missing="$missing scripts/check-backlog.mjs"
  if [ -n "$missing" ]; then
    bl_status="FAIL"; bl_reason="missing:${missing}"
  fi
  echo "backlog|$bl_status|$bl_reason"

  # check: launchd_loaded -- ship/groom/review always expected; eng iff ENG_ENABLED
  local ld_status="PASS" ld_reason=""
  local jobs="ship groom review"
  [ "$eng" = "1" ] && jobs="$jobs eng"
  local missing_jobs=""
  for j in $jobs; do
    if ! launchctl print "$DOMAIN/$ns.agent-$j" >/dev/null 2>&1; then
      missing_jobs="$missing_jobs $j"
    fi
  done
  if [ -n "$missing_jobs" ]; then
    ld_status="FAIL"; ld_reason="launchd jobs not loaded:${missing_jobs}"
  fi
  echo "launchd_loaded|$ld_status|$ld_reason"

  # check: installed_lib_sha
  local ls_status="PASS" ls_reason=""
  if [ -n "${FLEET_SKIP_INSTALLED_LIB_SHA:-}" ]; then
    ls_status="WARN"; ls_reason="skipped via FLEET_SKIP_INSTALLED_LIB_SHA"
  else
    local installed_dir="$HOME/.local/share/agent-fleet/lib"
    local repo_dir; repo_dir="$(doctor_repo_lib)"
    if [ ! -d "$installed_dir" ]; then
      ls_status="WARN"; ls_reason="$installed_dir not present — run install.sh"
    elif [ ! -d "$repo_dir" ]; then
      ls_status="WARN"; ls_reason="repo lib/ not resolvable from $0"
    else
      local installed_sha repo_sha
      installed_sha="$(doctor_lib_sha "$installed_dir")"
      repo_sha="$(doctor_lib_sha "$repo_dir")"
      if [ -z "$installed_sha" ] || [ -z "$repo_sha" ]; then
        ls_status="WARN"; ls_reason="could not compute one of the lib SHAs"
      elif [ "$installed_sha" != "$repo_sha" ]; then
        ls_status="WARN"
        ls_reason="installed lib SHA differs from repo lib SHA — reinstall kit"
      fi
    fi
  fi
  echo "installed_lib_sha|$ls_status|$ls_reason"

  # check: gh_auth
  local gh_status="PASS" gh_reason=""
  if ! command -v gh >/dev/null 2>&1; then
    gh_status="FAIL"; gh_reason="gh CLI not installed"
  elif ! gh auth status >/dev/null 2>&1; then
    gh_status="FAIL"; gh_reason="gh auth status failed — run gh auth login"
  fi
  echo "gh_auth|$gh_status|$gh_reason"

  # check: prompts_pinned (ticket 0005)
  # Compare the manifest's PROMPTS_SHA against the kit's current prompts/ SHA.
  # PASS = matches, WARN = unset (operator hasn't pinned yet — non-fatal),
  # FAIL = mismatch (a reinstall has drifted behavior; operator needs to
  # acknowledge by bumping the pin, or revert).
  local pp_status="PASS" pp_reason="" current_sha=""
  current_sha="$(fleet_prompts_sha 2>/dev/null || echo "")"
  if [ -z "$current_sha" ]; then
    pp_status="WARN"; pp_reason="could not compute current prompts SHA"
  elif [ -z "$pinned_sha" ]; then
    pp_status="WARN"; pp_reason="PROMPTS_SHA unset — re-run install.sh to stamp"
  elif [ "$pinned_sha" != "$current_sha" ]; then
    pp_status="FAIL"
    pp_reason="pinned=$pinned_sha actual=$current_sha — reinstall kit to bump"
  fi
  echo "prompts_pinned|$pp_status|$pp_reason"
}

# Build the per-project block (human form). Reads check rows on stdin, decides
# the project status (FAIL > WARN > PASS), and prints one block.
doctor_render_human() {
  local slug="$1"
  local rows="$2"   # newline-joined name|status|reason lines
  local worst="PASS"
  while IFS='|' read -r name status reason; do
    [ -z "$name" ] && continue
    [ "$name" = "__SLUG__" ] && continue
    if [ "$status" = "FAIL" ]; then worst="FAIL"
    elif [ "$status" = "WARN" ] && [ "$worst" != "FAIL" ]; then worst="WARN"
    fi
  done <<<"$rows"

  local color="$c_grn"
  [ "$worst" = "WARN" ] && color="$c_ylw"
  [ "$worst" = "FAIL" ] && color="$c_red"
  printf '%b[%s]%b %s\n' "$color" "$worst" "$c_rst" "$slug"
  while IFS='|' read -r name status reason; do
    [ -z "$name" ] && continue
    [ "$name" = "__SLUG__" ] && continue
    if [ "$status" != "PASS" ]; then
      printf '  %-18s %s  %s\n' "$name" "$status" "$reason"
    else
      printf '  %-18s %s\n' "$name" "$status"
    fi
  done <<<"$rows"
  echo
}

doctor() {
  local want_json=0 slug_filter=""
  shift  # drop the leading "doctor"
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) want_json=1; shift ;;
      --slug) slug_filter="${2:-}"; shift 2 ;;
      --slug=*) slug_filter="${1#--slug=}"; shift ;;
      -h|--help)
        cat <<USAGE
fleet doctor — diagnose every installed project (PASS/WARN/FAIL)

Usage:
  fleet doctor               survey FLEET_DISCOVERY_ROOT (default ~/Desktop/projects)
  fleet doctor --json        machine-readable summary
  fleet doctor --slug NAME   restrict to one project
USAGE
        exit 0 ;;
      *) echo "fleet doctor: unknown flag '$1'" >&2; exit 2 ;;
    esac
  done

  local manifests=()
  while IFS= read -r m; do
    [ -n "$m" ] && manifests+=("$m")
  done < <(find "$DOCTOR_ROOT" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort)

  local any_fail=0
  local json_projects=""
  for m in "${manifests[@]:-}"; do
    [ -z "$m" ] && continue
    local rows; rows="$(doctor_run_checks "$m")"
    local slug; slug="$(echo "$rows" | sed -n 's/^__SLUG__|\(.*\)|.*/\1/p' | head -1)"
    [ -n "$slug_filter" ] && [ "$slug" != "$slug_filter" ] && continue

    # Track project-level status for exit code.
    if echo "$rows" | grep -q '|FAIL|'; then any_fail=1; fi

    if [ "$want_json" = "1" ]; then
      local checks_json=""
      while IFS='|' read -r name status reason; do
        [ -z "$name" ] && continue
        [ "$name" = "__SLUG__" ] && continue
        local esc_name esc_status esc_reason
        esc_name="$(doctor_json_escape "$name")"
        esc_status="$(doctor_json_escape "$status")"
        esc_reason="$(doctor_json_escape "$reason")"
        [ -n "$checks_json" ] && checks_json+=","
        checks_json+="{\"name\":\"$esc_name\",\"status\":\"$esc_status\",\"reason\":\"$esc_reason\"}"
      done <<<"$rows"
      [ -n "$json_projects" ] && json_projects+=","
      json_projects+="{\"slug\":\"$(doctor_json_escape "$slug")\",\"checks\":[$checks_json]}"
    else
      doctor_render_human "$slug" "$rows"
    fi
  done

  if [ "$want_json" = "1" ]; then
    printf '{"projects":[%s]}\n' "$json_projects"
  fi

  [ "$any_fail" = "1" ] && exit 1
  exit 0
}

if [ "$CMD" = "doctor" ]; then
  doctor "$@"
fi

if [ "$CMD" = "list" ]; then
  echo "${c_bld}fleet projects under $ROOT${c_rst}"
  while read -r m; do
    [ -z "$m" ] && continue
    # shellcheck disable=SC1090
    ( source "$m"; printf "  %-14s %s\n" "${SLUG:-?}" "$(dirname "$m")" )
  done < <(discover)
  exit 0
fi

printf "${c_bld}%-12s %-9s %-11s %-7s %-9s %s${c_rst}\n" \
  PROJECT INSTALLED "LAST RUN" PRS LESSONS "SELF-CANCEL"
echo "${c_dim}$(printf '%.0s─' {1..68})${c_rst}"

while read -r m; do
  [ -z "$m" ] && continue
  PROJECT_DIR="$(dirname "$m")"

  # Read manifest in a subshell so vars don't leak between projects.
  eval "$(
    # shellcheck disable=SC1090
    source "$m"
    echo "SLUG='${SLUG:-?}'"
    echo "NS='${NAMESPACE:-com.fleet.${SLUG:-x}}'"
    echo "REPO='$(echo "${REPO_URL:-}" | sed -E 's#https?://github.com/##; s#\.git$##')'"
    echo "SC='${SELF_CANCEL:-}'"
    echo "ENG='${ENG_ENABLED:-0}'"
  )"
  [ -n "$WANT" ] && [ "$WANT" != "$SLUG" ] && continue

  # installed? — count loaded launchd jobs for this namespace
  loaded=0
  for s in ship groom review eng; do
    launchctl print "$DOMAIN/$NS.agent-$s" >/dev/null 2>&1 && loaded=$(( loaded+1 ))
  done
  expected=3; [ "$ENG" = "1" ] && expected=4
  if   [ $loaded -eq 0 ];         then inst="${c_red}no${c_rst}      "
  elif [ $loaded -lt $expected ]; then inst="${c_ylw}$loaded/$expected${c_rst}     "
  else inst="${c_grn}yes${c_rst}     "; fi

  last="$(human_age "$(newest_log_epoch "$HOME/.cache/${SLUG}-agent/logs")")"

  # open agent PRs (best-effort; needs gh auth + network)
  prs="—"
  if command -v gh >/dev/null 2>&1 && [ -n "$REPO" ]; then
    n=$(gh pr list --repo "$REPO" --state open --base main \
          --json headRefName --jq \
          '[.[] | select(.headRefName | test("^(feat/|chore/gtm-|eng/)"))] | length' \
          2>/dev/null)
    [ -n "$n" ] && prs="$n"
  fi

  # lessons count — try the repo working tree, then the agent's fresh checkout
  # (so it resolves even when discovery used the installed manifest).
  les="—"
  for lf in "$PROJECT_DIR/docs/LESSONS.md" "$PROJECT_DIR/LESSONS.md" \
            "$HOME/.cache/${SLUG}-agent/checkout/docs/LESSONS.md" \
            "$HOME/.cache/${SLUG}-agent/checkout/LESSONS.md"; do
    [ -f "$lf" ] && { les=$(grep -cE '^(- |## )' "$lf" 2>/dev/null); break; }
  done

  # self-cancel
  if [ -n "$SC" ]; then
    d=$(days_until "$SC")
    if   [ "$d" -lt 0 ];  then sc="${c_red}EXPIRED ($SC)${c_rst}"
    elif [ "$d" -le 3 ];  then sc="${c_ylw}${d}d ($SC)${c_rst}"
    else sc="${c_dim}${d}d${c_rst}"; fi
  else sc="${c_dim}—${c_rst}"; fi

  printf "%-12s %b %-11s %-7s %-9s %b\n" "$SLUG" "$inst" "$last" "$prs" "$les" "$sc"
done < <(discover)

echo
echo "${c_dim}installed=launchd jobs loaded · last run=newest log · prs=open agent PRs · self-cancel=days left${c_rst}"
