#!/bin/bash
# shellcheck disable=SC1090  # we source manifests discovered at runtime; paths are not constants
# fleet — one-glance status across every project running fleet agents.
#
# Usage:
#   fleet status              survey all projects (default)
#   fleet status <slug>       just one
#   fleet list                list discovered projects and their manifests
#   fleet doctor              diagnose every installed project (PASS/WARN/FAIL)
#   fleet doctor --json       machine-readable summary for fleet-control
#   fleet doctor --slug NAME  restrict to one project
#   fleet weekly              Sunday ROI rollup over the trailing 7d window
#                             (ticket 0025 — pure consumer of telemetry)
#   fleet prompts-sha         print the SHA256 of the kit's prompts/ tree
#                             (ticket 0005 — for PROMPTS_SHA pinning)
#
# Discovers projects by scanning for */agents.config.sh under FLEET_PROJECTS_ROOT
# (default ~/Desktop/projects). Run interactively — it reads from ~/Desktop, so
# it is not subject to the launchd TCC restriction the agents are.
#
# The doctor subcommand honours FLEET_DISCOVERY_ROOT (default ~/Desktop/projects)
# as the single scan root. This is what tests/doctor.sh uses to point at a
# fixture instead of the host's real ~/Desktop tree. Set
# FLEET_SKIP_INSTALLED_LIB_SHA=1 to skip the installed-vs-repo lib SHA check
# (it WARNs anyway when ~/.local/share/agent-fleet/lib is absent — the env
# override is mostly for test hosts that intentionally have no install).

set -uo pipefail

ROOT="${FLEET_PROJECTS_ROOT:-$HOME/Desktop/projects}"
INSTALLED="$HOME/.local/share/agent-fleet/projects"
DOMAIN="gui/$UID"
CMD="${1:-status}"
WANT="${2:-}"

c_dim=$'\033[2m'; c_red=$'\033[31m'; c_grn=$'\033[32m'; c_ylw=$'\033[33m'
c_bld=$'\033[1m'; c_rst=$'\033[0m'

# Manifests live in two places: the repo working tree (may be on a branch that
# doesn't have it yet) and the TCC-safe install location (what's actually
# deployed). Union both and de-dup by SLUG so a project shows whether its
# manifest has merged to main or is still on a PR branch. Working-tree copies are
# listed first, so they win the de-dup (they sit next to docs/LESSONS.md).
discover() {
  local _seen=""
  { find "$ROOT" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
    find "$INSTALLED" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
  } | while read -r m; do
    # shellcheck disable=SC1090  # path is discovered at runtime
    local slug; slug=$( (source "$m"; echo "${SLUG:-}") 2>/dev/null )
    case " $_seen " in *" $slug "*) ;; *) _seen="$_seen $slug"; echo "$m";; esac
  done
}

human_age() {  # $1 = epoch seconds of an mtime → "3m" / "2h" / "5d" / "—"
  [ -z "${1:-}" ] && { echo "—"; return; }
  local now diff; now=$(date +%s); diff=$(( now - $1 ))
  if   [ $diff -lt 3600 ];  then echo "$(( diff/60 ))m ago"
  elif [ $diff -lt 86400 ]; then echo "$(( diff/3600 ))h ago"
  else echo "$(( diff/86400 ))d ago"; fi
}

days_until() {  # $1 = YYYYMMDD → integer days from today (may be negative)
  local target; target=$(date -j -f "%Y%m%d" "$1" +%s 2>/dev/null) || { echo 999; return; }
  local today; today=$(date -j -f "%Y%m%d" "$(date +%Y%m%d)" +%s)
  echo $(( (target - today) / 86400 ))
}

newest_log_epoch() {  # $1 = log dir → mtime of newest *.log, or empty
  local d="$1"; [ -d "$d" ] || return
  local f; f=$(ls -t "$d"/*.log 2>/dev/null | head -1) || return
  [ -n "$f" ] && stat -f %m "$f" 2>/dev/null
}

# --- doctor ---------------------------------------------------------------
# `fleet doctor` scans FLEET_DISCOVERY_ROOT (default ~/Desktop/projects) for
# */agents.config.sh, then runs seven named checks per project. Output is
# either one block per project (default) or a single JSON document keyed by
# {"projects":[{"slug":..,"checks":[{"name":..,"status":..,"reason":..}]}]}.
# Exit 0 if no FAIL across any project; exit 1 if any check is FAIL. WARN
# never fails the exit code — it's an "ok but look at me" signal.
#
# Checks (run in this order, names are the JSON-stable contract):
#   config             agents.config.sh parseable; SLUG/REPO_URL/SELF_CANCEL set
#   self_cancel        SELF_CANCEL not in the past (FAIL), >3 days out (PASS)
#   agents_md          AGENTS.md present + "## Agent parameters" section
#   backlog            docs/backlog/README.md + scripts/check-backlog.mjs exist
#   launchd_loaded     com.<slug>.agent-{ship,groom,review} are loaded
#                      (+ eng if ENG_ENABLED=1)
#   installed_lib_sha  ~/.local/share/agent-fleet/lib SHA matches the repo's
#                      lib/ SHA (WARN when either side is absent)
#   gh_auth            `gh auth status` exits 0
#   prompts_pinned     manifest's PROMPTS_SHA matches the kit's current
#                      prompts/ SHA (ticket 0005). PASS if set + matches,
#                      WARN if unset, FAIL if mismatched.

DOCTOR_ROOT="${FLEET_DISCOVERY_ROOT:-$HOME/Desktop/projects}"

# Repo lib/ dir — relative to this script (bin/fleet → ../lib).
doctor_repo_lib() {
  local self; self="$( cd "$( dirname "$0" )" && pwd )"
  echo "$self/../lib"
}

# Sum of `shasum` over every *.sh under a lib dir, sorted, joined. Stable
# across machines because we sort the filenames first. Echoes empty string if
# the dir is missing or contains no shell files.
doctor_lib_sha() {
  local dir="$1"
  [ -d "$dir" ] || return 0
  (cd "$dir" && find . -type f -name '*.sh' | sort | xargs shasum 2>/dev/null) | shasum | awk '{print $1}'
}

# --- prompts-sha ----------------------------------------------------------
# Ticket 0005. Prints the SHA256 of the concatenation of every *.md under the
# kit's prompts/ dir, with filenames sorted for cross-machine determinism.
# This is the value an operator pins via `PROMPTS_SHA=...` in their manifest
# so a future prompt edit surfaces as a `prompts_drift` warning in the runner.
#
# Defined above the doctor block because doctor's prompts_pinned check calls
# it directly — bash needs the function defined before it's referenced.
#
# Resolution order:
#   1. $FLEET_KIT_ROOT/prompts (escape hatch for fleet-control / tests)
#   2. The repo this script lives in: bin/fleet → ../prompts
#   3. The installed kit at ~/.local/share/agent-fleet/prompts
# First hit wins. Falls through with exit 1 + a stderr message if none exist
# so `PROMPTS_SHA=$(fleet prompts-sha)` doesn't silently bake in an empty pin.
fleet_prompts_sha() {
  local self prompts_dir=""
  self="$( cd "$( dirname "$0" )" && pwd )"
  for cand in \
    "${FLEET_KIT_ROOT:-}/prompts" \
    "$self/../prompts" \
    "$HOME/.local/share/agent-fleet/prompts"; do
    if [ -n "$cand" ] && [ -d "$cand" ]; then
      prompts_dir="$cand"
      break
    fi
  done
  if [ -z "$prompts_dir" ]; then
    echo "fleet prompts-sha: no prompts/ dir found (looked in FLEET_KIT_ROOT, $self/../prompts, ~/.local/share/agent-fleet/prompts)" >&2
    return 1
  fi
  # The ticket's formula verbatim. `find | sort` makes the order stable;
  # `xargs cat` concatenates contents; `shasum -a 256` is on every macOS.
  ( cd "$prompts_dir/.." && find prompts -type f -name '*.md' | sort | xargs cat ) \
    | shasum -a 256 | awk '{print $1}'
}

if [ "$CMD" = "prompts-sha" ]; then
  fleet_prompts_sha
  exit $?
fi

# --- prompts-diff ---------------------------------------------------------
# Ticket 0013. `fleet prompts-diff` explains the WHY behind a
# `prompts_drift` warning (ticket 0005). Three modes:
#
#   fleet prompts-diff
#     Unified diff of every *.md under the installed prompts tree
#     (~/.local/share/agent-fleet/prompts) against the kit's current
#     prompts/. Exit 1 if any file differs; 0 otherwise. The operator
#     reads this in tandem with `fleet doctor` to see what changed.
#
#   fleet prompts-diff --since <SHA>
#     Walk `git log -- prompts/` to find the commit whose subtree SHA
#     matches the operator's old pin, then `git diff <commit>..HEAD
#     -- prompts/`. Used after an install.sh re-pin to see what the
#     bump actually changed.
#
#   fleet prompts-diff --changelog
#     Print all prompts/CHANGELOG.md entries verbatim that are NEWER
#     than the installed-prompts SHA. "Newer" is decided by walking
#     the CHANGELOG top-down (newest entries first by convention) and
#     stopping at the entry whose body cites the installed SHA — when
#     no installed-SHA stamp exists, every entry is surfaced.
#
# Naming (LESSONS 2026-05-26): the dispatch function is named
# `prompts_diff_cmd` rather than `prompts_diff` so it never shadows the
# system `diff` binary (we shell out to `diff -u` from inside this very
# function). Same trap that bit `tail()` in ticket 0015.
#
# Resolution: KIT_ROOT is derived from this script's location
# (bin/fleet → ..). $FLEET_KIT_ROOT overrides it for tests.

prompts_diff_kit_root() {
  local self
  self="$( cd "$( dirname "$0" )" && pwd )"
  echo "${FLEET_KIT_ROOT:-$(cd "$self/.." && pwd)}"
}

# Print prompts/CHANGELOG.md, optionally filtered to entries newer than
# the operator's pinned SHA. Filtering logic:
#
#   * Discover the operator's pin by reading
#     `~/.local/share/agent-fleet/projects/*/agents.config.sh` and grabbing
#     the first `PROMPTS_SHA="..."` value (install.sh stamps every
#     installed manifest with the same pin — same kit, same SHA).
#   * If no pin is discoverable OR the pin equals the kit's current
#     prompts SHA → print the full CHANGELOG (no cutoff to apply).
#   * Otherwise, walk `git log -- prompts/CHANGELOG.md` to find the
#     commit whose CHANGELOG-version corresponds to the operator's pin
#     era. We use a simple heuristic: take the FIRST heading present in
#     the historical CHANGELOG at that commit and treat it as the
#     cutoff — everything above that heading in the kit CHANGELOG is
#     "newer than the operator's install."
#
# When git history isn't queryable (test fixture without a .git dir) we
# fall through to printing the full CHANGELOG, which matches the
# "surface everything" semantics callers expect when no pin info exists.
prompts_diff_changelog() {
  local kit_root="$1"
  local kit_chg="$kit_root/prompts/CHANGELOG.md"
  if [ ! -f "$kit_chg" ]; then
    echo "fleet prompts-diff --changelog: no CHANGELOG at $kit_chg" >&2
    return 1
  fi

  # Discover the operator's pin. Empty when no installed manifest yet.
  local pin=""
  local installed_root="$HOME/.local/share/agent-fleet/projects"
  if [ -d "$installed_root" ]; then
    local m
    for m in "$installed_root"/*/agents.config.sh; do
      [ -f "$m" ] || continue
      pin="$(sed -nE 's/^PROMPTS_SHA="?([0-9a-f]+)"?.*/\1/p' "$m" | head -1)"
      [ -n "$pin" ] && break
    done
  fi

  # Compute kit SHA. When it matches the pin OR no pin exists → surface
  # the full CHANGELOG. The point of --changelog is to be informational;
  # silence is the wrong default.
  local kit_sha=""
  kit_sha="$( ( cd "$kit_root" && find prompts -type f -name '*.md' | sort | xargs cat ) \
                | shasum -a 256 | awk '{print $1}' )"
  if [ -z "$pin" ] || [ "$pin" = "$kit_sha" ]; then
    cat "$kit_chg"
    return 0
  fi

  # Pin differs from the kit. Try git to find the historical CHANGELOG
  # at the pinned era; if git isn't usable, fall back to the full file.
  if ! ( cd "$kit_root" && git rev-parse HEAD >/dev/null 2>&1 ); then
    cat "$kit_chg"
    return 0
  fi
  local match=""
  while IFS= read -r commit; do
    [ -z "$commit" ] && continue
    local sha
    sha="$( cd "$kit_root" \
            && git ls-tree -r --name-only "$commit" -- prompts 2>/dev/null \
                 | sort \
                 | while read -r f; do
                     git show "$commit:$f" 2>/dev/null
                   done \
                 | shasum -a 256 | awk '{print $1}' )"
    if [ "$sha" = "$pin" ]; then
      match="$commit"
      break
    fi
  done < <(cd "$kit_root" && git log -200 --format=%H -- prompts 2>/dev/null)

  if [ -z "$match" ]; then
    cat "$kit_chg"
    return 0
  fi

  # Use the FIRST heading from the historical CHANGELOG as cutoff.
  local cutoff
  cutoff="$( cd "$kit_root" && git show "$match:prompts/CHANGELOG.md" 2>/dev/null \
              | awk '/^## [0-9]{4}-[0-9]{2}-[0-9]{2}/ { print; exit }' )"
  if [ -z "$cutoff" ]; then
    cat "$kit_chg"
    return 0
  fi
  awk -v cutoff="$cutoff" '
    BEGIN { surf = 1 }
    {
      if ($0 == cutoff) { surf = 0 }
      if (surf) print
    }
  ' "$kit_chg"
}

# Compare two prompt trees via `diff -u`. Echoes the unified diff to
# stdout. Returns 0 when identical, 1 on any difference, 2 on error.
prompts_diff_trees() {
  local installed="$1" kit_prompts="$2"
  if [ ! -d "$kit_prompts" ]; then
    echo "fleet prompts-diff: no kit prompts dir at $kit_prompts" >&2
    return 2
  fi
  if [ ! -d "$installed" ]; then
    echo "fleet prompts-diff: no installed prompts dir at $installed" >&2
    echo "(re-run install.sh from any project to populate it)" >&2
    return 2
  fi
  # `diff -ruN` walks both directories, prints unified diffs per file,
  # treats missing files on either side as empty. Exit 0 = identical,
  # 1 = different, 2 = error.
  diff -ruN "$installed" "$kit_prompts"
  return $?
}

# Walk `git log -- prompts/` for a commit whose prompts/ tree-SHA matches
# the operator's old pin, then diff that commit's prompts/ against HEAD's.
# The pin is the SHA produced by `bin/fleet prompts-sha`, NOT a git SHA —
# we compute the kit's formula at each ancestor commit until we find a
# match (bounded to the last 200 commits to avoid runaway scans).
prompts_diff_since() {
  local kit_root="$1" pin="$2"
  if [ -z "$pin" ]; then
    echo "fleet prompts-diff --since: missing <SHA> argument" >&2
    return 2
  fi
  if ! ( cd "$kit_root" && git rev-parse HEAD >/dev/null 2>&1 ); then
    echo "fleet prompts-diff --since: $kit_root is not a git checkout" >&2
    return 2
  fi
  local match=""
  while IFS= read -r commit; do
    [ -z "$commit" ] && continue
    local sha
    sha="$( cd "$kit_root" \
            && git show "$commit:prompts" >/dev/null 2>&1 \
            && git ls-tree -r --name-only "$commit" -- prompts \
                 | sort \
                 | while read -r f; do
                     git show "$commit:$f" 2>/dev/null
                   done \
                 | shasum -a 256 | awk '{print $1}' )"
    if [ "$sha" = "$pin" ]; then
      match="$commit"
      break
    fi
  done < <(cd "$kit_root" && git log -200 --format=%H -- prompts)
  if [ -z "$match" ]; then
    echo "fleet prompts-diff --since: no commit in the last 200 matched pin $pin" >&2
    return 1
  fi
  ( cd "$kit_root" && git diff "$match"..HEAD -- prompts )
  return $?
}

prompts_diff_cmd() {
  shift  # drop the leading "prompts-diff"
  local mode="tree" since_sha=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --changelog) mode="changelog"; shift ;;
      --since)     mode="since"; since_sha="${2:-}"; shift 2 ;;
      --since=*)   mode="since"; since_sha="${1#--since=}"; shift ;;
      -h|--help)
        cat <<USAGE
fleet prompts-diff — explain WHAT changed in the kit's prompts since install.

Usage:
  fleet prompts-diff                       unified diff installed vs kit
  fleet prompts-diff --since <SHA>         diff against a historical pin
  fleet prompts-diff --changelog           CHANGELOG entries newer than pin

Exit 1 on any difference (so it composes with \`&&\` for scripts); 0
when the installed prompts match the kit's current tree.

The kit root resolves to this script's parent (bin/fleet -> ..) unless
\$FLEET_KIT_ROOT overrides it. Installed prompts live at
~/.local/share/agent-fleet/prompts (populated by lib/install.sh).
USAGE
        exit 0 ;;
      --) shift ;;
      -*) echo "fleet prompts-diff: unknown flag '$1'" >&2; exit 2 ;;
      *)  echo "fleet prompts-diff: unexpected argument '$1'" >&2; exit 2 ;;
    esac
  done

  local kit_root; kit_root="$(prompts_diff_kit_root)"
  local kit_prompts="$kit_root/prompts"
  local installed="$HOME/.local/share/agent-fleet/prompts"

  case "$mode" in
    changelog)
      prompts_diff_changelog "$kit_root"
      exit $?
      ;;
    since)
      prompts_diff_since "$kit_root" "$since_sha"
      exit $?
      ;;
    tree|*)
      prompts_diff_trees "$installed" "$kit_prompts"
      exit $?
      ;;
  esac
}

if [ "$CMD" = "prompts-diff" ]; then
  prompts_diff_cmd "$@"
fi

# --- onboard --------------------------------------------------------------
# Ticket 0011. `fleet onboard <project-path>` scaffolds a fresh project with
# the full kit contract — manifest, AGENTS.md, docs/LESSONS.md stub, the
# backlog README+template, scripts/check-backlog.mjs, and the three Claude
# subagent files under .claude/agents/. Then by default calls
# `bash $KIT_ROOT/lib/install.sh <project-path>` so the operator gets a fully
# installed loop in one shot. Flags:
#   --dry-run        list files that would be written; create nothing; exit 0
#   --force          overwrite existing contract files; emit `[OK] reset <file>`
#   --skip-install   scaffold only; do not call install.sh
# If `$FLEET_INSTALL_CMD` is set, that command is invoked instead of
# `bash $KIT_ROOT/lib/install.sh` — the test rig uses this to stub install.
#
# Resolution: templates live next to this script (bin/fleet → ../templates).
# A project is considered "already onboarded" if its agents.config.sh exists.

onboard_kit_root() {
  local self; self="$( cd "$( dirname "$0" )" && pwd )"
  ( cd "$self/.." && pwd )
}

# All files the scaffolder writes, paired with how each is sourced. Each row
# is `dest|kind|source` where:
#   kind=template  — copy templates/<source> verbatim
#   kind=manifest  — render the manifest from inline derivations (slug, etc.)
#   kind=agents-md — render AGENTS.md by prepending a slug header to
#                    templates/AGENTS.section.md
#   kind=lessons   — write the empty docs/LESSONS.md stub inline
onboard_file_list() {
  cat <<'LIST'
agents.config.sh|manifest|
AGENTS.md|agents-md|AGENTS.section.md
docs/LESSONS.md|lessons|
docs/backlog/README.md|inline-backlog-readme|
docs/backlog/_template.md|template|backlog/_template.md
scripts/check-backlog.mjs|template|scripts/check-backlog.mjs
.claude/agents/implementation-dev.md|template|claude-agents/implementation-dev.md
.claude/agents/gtm-innovation.md|template|claude-agents/gtm-innovation.md
.claude/agents/review.md|template|claude-agents/review.md
LIST
}

# Render the manifest for a given project dir + slug. Mirrors
# manifest.example.sh's structure but substitutes the derived values.
onboard_render_manifest() {
  local slug="$1" proj_dir="$2"
  local repo_url self_cancel namespace
  repo_url=$( (cd "$proj_dir" && git remote get-url origin 2>/dev/null) || echo "" )
  # Today + 21 days UTC, YYYYMMDD. macOS BSD date uses -v; GNU date uses -d.
  self_cancel=$(date -u -v+21d +%Y%m%d 2>/dev/null \
                 || date -u -d "+21 days" +%Y%m%d)
  namespace="com.$slug"
  cat <<MANIFEST
# agents.config.sh — per-project fleet manifest (PLUMBING ONLY).
#
# This file holds the values the SHELL needs (identity, schedule, spend
# bound). Everything the AGENT needs at runtime (gating checks, branch
# prefixes, the local gate command, voice, hard NOs) lives in this project's
# AGENTS.md "## Agent parameters" section — NOT here.
#
# After editing, re-deploy: bash <kit>/lib/install.sh /abs/path/to/project

# --- identity -------------------------------------------------------------
PROJECT_NAME="$slug"
SLUG="$slug"
NAMESPACE="$namespace"
REPO_URL="$repo_url"
MODEL="claude-opus-4-7"

# Commits the agents author under this identity.
GIT_AUTHOR_NAME="$slug Agent"
GIT_AUTHOR_EMAIL="noreply@anthropic.com"

# --- spend bound ----------------------------------------------------------
# YYYYMMDD UTC. After this date all agents no-op until you bump it + reinstall.
SELF_CANCEL="$self_cancel"

# Optional per-slug daily cap in USD. Unset = no cap.
# MAX_DAILY_USD=5

# Optional trainee-mode gate: first N feature PRs require manual merge.
# TRAINEE_PR_COUNT=5

# --- cadence --------------------------------------------------------------
SHIP_MINUTE=41
GROOM_HOURS="0 6 12 18"
GROOM_MINUTE=17
REVIEW_INTERVAL=300

# --- engineering queue (optional second worker) ---------------------------
ENG_ENABLED=0
ENG_HOURS="3 9 15 21"
ENG_MINUTE=23
MANIFEST
}

# Render AGENTS.md by stitching a slug header onto templates/AGENTS.section.md
# (which carries the canonical "## Agent parameters" + "## Hard NOs" content).
onboard_render_agents_md() {
  local slug="$1" kit_root="$2"
  cat <<HEADER
# AGENTS.md — $slug

This file is the **contract** between the autonomous loop and this repo.
The shared engine in \`lib/\` reads \`agents.config.sh\`; the \`claude\`
agent that runs each ship/groom/review cycle reads **this file**, in a
fresh checkout, every single time.

> Replace every bracketed value below before the first run. The dev agent
> takes "## Agent parameters" as ground truth — wrong values silently break
> gating and branch handling.

HEADER
  # AGENTS.section.md already contains the "## Agent parameters" and
  # "## Hard NOs" sections. Drop its leading HTML comment block (the
  # "paste these two sections" instruction is for humans, not the project).
  awk 'started || /^## /{started=1} started' "$kit_root/templates/AGENTS.section.md"
}

# Render the docs/backlog/README.md scaffold. Inline so we don't have to ship
# another template file just for one paragraph + an empty table.
onboard_render_backlog_readme() {
  local slug="$1"
  cat <<README
# Backlog — $slug

Tickets here ship via the kit: \`implementation-dev\` picks the top groomed
row, \`gtm-innovation\` proposes new ones, \`review\` grades them.

## Conventions

- \`id\` is a 4-digit zero-padded integer; the filename is
  \`NNNN-kebab-title.md\`.
- \`status\` is one of: \`proposed\`, \`groomed\`, \`in-progress\`, \`shipped\`,
  \`rejected\`, \`needs-discovery\`.
- \`priority\` is \`P0\` (oncall-now), \`P1\` (this week), \`P2\` (next),
  \`P3\` (later).
- \`area\` is project-specific — set the allowed list in AGENTS.md
  "## Agent parameters · Backlog areas".
- The table below MUST stay in sync with the frontmatter of each ticket file.
  CI gate \`validate\` runs \`node scripts/check-backlog.mjs\` and rejects drift.

## Index

| id | title | priority | status | area |
|----|-------|----------|--------|------|
README
}

# Write one scaffold file. Honours $force (overwrite-with-OK-line) and
# $dry_run (print "would create" and skip the write).
onboard_write_one() {
  local dest_rel="$1" kind="$2" source_rel="$3"
  local proj_dir="$4" slug="$5" kit_root="$6"
  local force="$7" dry_run="$8"
  local dest="$proj_dir/$dest_rel"

  if [ "$dry_run" = "1" ]; then
    echo "would create $dest_rel"
    return 0
  fi

  if [ -e "$dest" ] && [ "$force" != "1" ]; then
    # The top-level guard already caught agents.config.sh; for other files
    # this is a quiet skip — the operator may have edited them. We do
    # nothing rather than silently clobber.
    return 0
  fi

  mkdir -p "$(dirname "$dest")"
  case "$kind" in
    manifest)
      onboard_render_manifest "$slug" "$proj_dir" > "$dest"
      ;;
    agents-md)
      onboard_render_agents_md "$slug" "$kit_root" > "$dest"
      ;;
    lessons)
      printf '# LESSONS\n\nOperational memory.\n' > "$dest"
      ;;
    inline-backlog-readme)
      onboard_render_backlog_readme "$slug" > "$dest"
      ;;
    template)
      /bin/cp -f "$kit_root/templates/$source_rel" "$dest"
      ;;
    *)
      echo "fleet onboard: unknown render kind '$kind' for $dest_rel" >&2
      return 1
      ;;
  esac

  if [ "$force" = "1" ]; then
    echo "[OK] reset $dest_rel"
  fi
}

onboard() {
  shift  # drop the leading "onboard"
  local dry_run=0 force=0 skip_install=0 proj_arg=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1; shift ;;
      --force) force=1; shift ;;
      --skip-install) skip_install=1; shift ;;
      -h|--help)
        cat <<USAGE
fleet onboard — scaffold a fresh project with the kit contract.

Usage:
  fleet onboard <project-path>            scaffold + run install.sh
  fleet onboard --dry-run <project-path>  print what would be written
  fleet onboard --force <project-path>    overwrite existing contract files
  fleet onboard --skip-install <path>     scaffold only; skip install.sh

The project-path must already be a git repo with an 'origin' remote. The
manifest pulls REPO_URL from \`git remote get-url origin\` and derives SLUG
from the basename. Edit agents.config.sh and AGENTS.md after — the bracketed
values (gating checks, local gate command, backlog areas) are project-specific.
USAGE
        exit 0 ;;
      --) shift; proj_arg="${1:-}"; shift || true; break ;;
      -*) echo "fleet onboard: unknown flag '$1'" >&2; exit 2 ;;
      *)
        if [ -z "$proj_arg" ]; then proj_arg="$1"; shift
        else echo "fleet onboard: unexpected extra argument '$1'" >&2; exit 2
        fi ;;
    esac
  done

  if [ -z "$proj_arg" ]; then
    echo "fleet onboard: missing <project-path>" >&2
    echo "usage: fleet onboard [--dry-run|--force|--skip-install] <project-path>" >&2
    exit 2
  fi
  if [ ! -d "$proj_arg" ]; then
    echo "fleet onboard: $proj_arg is not a directory" >&2
    exit 2
  fi

  local proj_dir; proj_dir="$( cd "$proj_arg" && pwd )"
  local slug; slug="$(basename "$proj_dir")"
  local kit_root; kit_root="$(onboard_kit_root)"

  # Already-onboarded guard — exact wording per ticket 0011.
  if [ -f "$proj_dir/agents.config.sh" ] && [ "$force" != "1" ] && [ "$dry_run" != "1" ]; then
    echo "already onboarded — use 'fleet onboard --force' to overwrite" >&2
    exit 1
  fi

  # Scaffold each file. On dry-run we just print the list and exit before
  # any side-effects (including the install.sh call).
  while IFS='|' read -r dest_rel kind source_rel; do
    [ -z "$dest_rel" ] && continue
    onboard_write_one "$dest_rel" "$kind" "$source_rel" \
                      "$proj_dir" "$slug" "$kit_root" \
                      "$force" "$dry_run"
  done < <(onboard_file_list)

  if [ "$dry_run" = "1" ]; then
    exit 0
  fi

  # Install unless explicitly skipped. The test harness sets
  # FLEET_INSTALL_CMD to point at a stub; production runs use the real
  # lib/install.sh sitting alongside this script.
  if [ "$skip_install" != "1" ]; then
    local install_cmd="${FLEET_INSTALL_CMD:-}"
    if [ -n "$install_cmd" ]; then
      "$install_cmd" "$proj_dir" || {
        echo "fleet onboard: install command failed: $install_cmd" >&2
        exit 1
      }
    else
      bash "$kit_root/lib/install.sh" "$proj_dir" || {
        echo "fleet onboard: install.sh failed" >&2
        exit 1
      }
    fi
  fi

  echo
  echo "next: 'launchctl kickstart -k gui/\$UID/com.${slug}.agent-ship' to trigger the first run"
  exit 0
}

if [ "$CMD" = "onboard" ]; then
  onboard "$@"
fi

# Hand-rolled JSON string escape — same intent as common.sh _json_escape but
# bin/fleet doesn't source common.sh. Keep this in sync if either grows.
doctor_json_escape() {
  local s="${1-}" out="" i ch code
  for (( i=0; i<${#s}; i++ )); do
    ch="${s:i:1}"
    case "$ch" in
      '\') out+='\\' ;;
      '"') out+='\"' ;;
      $'\b') out+='\b' ;;
      $'\f') out+='\f' ;;
      $'\n') out+='\n' ;;
      $'\r') out+='\r' ;;
      $'\t') out+='\t' ;;
      *) printf -v code '%d' "'$ch"
         if [ "$code" -lt 32 ]; then printf -v out '%s\\u%04x' "$out" "$code"
         else out+="$ch"; fi ;;
    esac
  done
  printf '%s' "$out"
}

# Run all seven checks for one manifest. Echoes one "name|status|reason" line
# per check on stdout. Caller renders or JSON-encodes.
doctor_run_checks() {
  local manifest="$1"
  local proj_dir; proj_dir="$(dirname "$manifest")"
  local slug="" ns="" sc="" eng="0" repo_url=""

  # check: config -- subshell so vars don't leak across projects
  local cfg_status="PASS" cfg_reason=""
  local probe
  probe=$(
    # shellcheck disable=SC1090  # discovered at runtime
    ( source "$manifest" 2>/dev/null
      echo "SLUG=${SLUG:-}"
      echo "NAMESPACE=${NAMESPACE:-com.fleet.${SLUG:-x}}"
      echo "SELF_CANCEL=${SELF_CANCEL:-}"
      echo "ENG_ENABLED=${ENG_ENABLED:-0}"
      echo "REPO_URL=${REPO_URL:-}"
      echo "PROMPTS_SHA=${PROMPTS_SHA:-}"
      echo "TRAINEE_PR_COUNT=${TRAINEE_PR_COUNT:-0}"
    ) 2>/dev/null
  ) || true
  slug="$(echo "$probe" | sed -n 's/^SLUG=//p')"
  ns="$(echo "$probe" | sed -n 's/^NAMESPACE=//p')"
  sc="$(echo "$probe" | sed -n 's/^SELF_CANCEL=//p')"
  eng="$(echo "$probe" | sed -n 's/^ENG_ENABLED=//p')"
  repo_url="$(echo "$probe" | sed -n 's/^REPO_URL=//p')"
  local pinned_sha; pinned_sha="$(echo "$probe" | sed -n 's/^PROMPTS_SHA=//p')"
  local trainee_cap; trainee_cap="$(echo "$probe" | sed -n 's/^TRAINEE_PR_COUNT=//p')"
  if [ -z "$slug" ] || [ -z "$repo_url" ] || [ -z "$sc" ]; then
    cfg_status="FAIL"
    cfg_reason="manifest missing required vars (SLUG/REPO_URL/SELF_CANCEL)"
  fi
  echo "config|$cfg_status|$cfg_reason"
  # Tell the caller which slug we resolved so it can name the block.
  echo "__SLUG__|$slug|"

  # check: self_cancel
  local sc_status="PASS" sc_reason="" days=""
  if [ -z "$sc" ]; then
    sc_status="FAIL"; sc_reason="SELF_CANCEL not set"
  else
    days=$(days_until "$sc")
    if [ "$days" -lt 0 ]; then
      sc_status="FAIL"; sc_reason="SELF_CANCEL expired ${days}d ago ($sc)"
    elif [ "$days" -le 3 ]; then
      sc_status="WARN"; sc_reason="SELF_CANCEL within ${days}d ($sc)"
    fi
  fi
  echo "self_cancel|$sc_status|$sc_reason"

  # check: agents_md — file present + "## Agent parameters" section
  local am="$proj_dir/AGENTS.md"
  local am_status="PASS" am_reason=""
  if [ ! -f "$am" ]; then
    am_status="FAIL"; am_reason="AGENTS.md not found at $am"
  elif ! grep -q '^##[[:space:]]\+Agent parameters' "$am"; then
    am_status="FAIL"; am_reason="AGENTS.md missing '## Agent parameters' section"
  fi
  echo "agents_md|$am_status|$am_reason"

  # check: backlog — README.md and check-backlog.mjs
  local bl_status="PASS" bl_reason="" missing=""
  [ -f "$proj_dir/docs/backlog/README.md" ] || missing="$missing docs/backlog/README.md"
  [ -f "$proj_dir/scripts/check-backlog.mjs" ] || missing="$missing scripts/check-backlog.mjs"
  if [ -n "$missing" ]; then
    bl_status="FAIL"; bl_reason="missing:${missing}"
  fi
  echo "backlog|$bl_status|$bl_reason"

  # check: launchd_loaded -- ship/groom/review always expected; eng iff ENG_ENABLED
  local ld_status="PASS" ld_reason=""
  local jobs="ship groom review"
  [ "$eng" = "1" ] && jobs="$jobs eng"
  local missing_jobs=""
  for j in $jobs; do
    if ! launchctl print "$DOMAIN/$ns.agent-$j" >/dev/null 2>&1; then
      missing_jobs="$missing_jobs $j"
    fi
  done
  if [ -n "$missing_jobs" ]; then
    ld_status="FAIL"; ld_reason="launchd jobs not loaded:${missing_jobs}"
  fi
  echo "launchd_loaded|$ld_status|$ld_reason"

  # check: installed_lib_sha
  local ls_status="PASS" ls_reason=""
  if [ -n "${FLEET_SKIP_INSTALLED_LIB_SHA:-}" ]; then
    ls_status="WARN"; ls_reason="skipped via FLEET_SKIP_INSTALLED_LIB_SHA"
  else
    local installed_dir="$HOME/.local/share/agent-fleet/lib"
    local repo_dir; repo_dir="$(doctor_repo_lib)"
    if [ ! -d "$installed_dir" ]; then
      ls_status="WARN"; ls_reason="$installed_dir not present — run install.sh"
    elif [ ! -d "$repo_dir" ]; then
      ls_status="WARN"; ls_reason="repo lib/ not resolvable from $0"
    else
      local installed_sha repo_sha
      installed_sha="$(doctor_lib_sha "$installed_dir")"
      repo_sha="$(doctor_lib_sha "$repo_dir")"
      if [ -z "$installed_sha" ] || [ -z "$repo_sha" ]; then
        ls_status="WARN"; ls_reason="could not compute one of the lib SHAs"
      elif [ "$installed_sha" != "$repo_sha" ]; then
        ls_status="WARN"
        ls_reason="installed lib SHA differs from repo lib SHA — reinstall kit"
      fi
    fi
  fi
  echo "installed_lib_sha|$ls_status|$ls_reason"

  # check: gh_auth
  local gh_status="PASS" gh_reason=""
  if ! command -v gh >/dev/null 2>&1; then
    gh_status="FAIL"; gh_reason="gh CLI not installed"
  elif ! gh auth status >/dev/null 2>&1; then
    gh_status="FAIL"; gh_reason="gh auth status failed — run gh auth login"
  fi
  echo "gh_auth|$gh_status|$gh_reason"

  # check: prompts_pinned (ticket 0005)
  # Compare the manifest's PROMPTS_SHA against the kit's current prompts/ SHA.
  # PASS = matches, WARN = unset (operator hasn't pinned yet — non-fatal),
  # FAIL = mismatch (a reinstall has drifted behavior; operator needs to
  # acknowledge by bumping the pin, or revert).
  local pp_status="PASS" pp_reason="" current_sha=""
  current_sha="$(fleet_prompts_sha 2>/dev/null || echo "")"
  if [ -z "$current_sha" ]; then
    pp_status="WARN"; pp_reason="could not compute current prompts SHA"
  elif [ -z "$pinned_sha" ]; then
    pp_status="WARN"; pp_reason="PROMPTS_SHA unset — re-run install.sh to stamp"
  elif [ "$pinned_sha" != "$current_sha" ]; then
    pp_status="FAIL"
    pp_reason="pinned=$pinned_sha actual=$current_sha — reinstall kit to bump"
  fi
  echo "prompts_pinned|$pp_status|$pp_reason"

  # check: trainee_mode (ticket 0014)
  # Surfaces whether the project still requires manual operator merge on
  # feature PRs. PASS = disabled (TRAINEE_PR_COUNT unset/0) or graduated
  # (no PRs remain). WARN = active, with the remaining-count in the
  # reason string so the operator sees "trainee mode active: N PRs
  # remaining" without having to crack open the manifest. FAIL is reserved
  # — trainee mode being active is informational, not an error.
  local tm_status="PASS" tm_reason=""
  case "$trainee_cap" in
    ''|0|*[!0-9]*)
      : ;;  # disabled -> PASS, no reason
    *)
      # Compute merged feat/ PR count via gh (best-effort).
      local merged=0 raw=""
      if command -v gh >/dev/null 2>&1; then
        local repo_slug; repo_slug="$(echo "$repo_url" | sed -E 's#https?://github.com/##; s#\.git$##')"
        raw="$(gh pr list \
                  --state merged \
                  --search "head:feat/ base:main" \
                  --json number \
                  --limit 100 \
                  ${repo_slug:+--repo "$repo_slug"} \
                2>/dev/null || true)"
        if [ -n "$raw" ] && [ "$raw" != "[]" ]; then
          if command -v jq >/dev/null 2>&1; then
            merged="$(printf '%s' "$raw" | jq 'length' 2>/dev/null || echo 0)"
          else
            merged="$(printf '%s' "$raw" | tr -cd '{' | wc -c | tr -d ' ')"
          fi
        fi
      fi
      case "$merged" in ''|*[!0-9]*) merged=0 ;; esac
      local remaining=$(( trainee_cap - merged ))
      [ "$remaining" -lt 0 ] && remaining=0
      if [ "$remaining" -gt 0 ]; then
        tm_status="WARN"
        tm_reason="trainee mode active: $remaining PRs remaining (cap=$trainee_cap)"
      else
        tm_reason="trainee mode graduated (cap=$trainee_cap, $merged merged)"
      fi
      ;;
  esac
  echo "trainee_mode|$tm_status|$tm_reason"

  # check: events_size (ticket 0016)
  # Surfaces the health of $CACHE_DIR/events.jsonl per project:
  #   PASS when the file is under FLEET_EVENTS_MAX_BYTES (default 1 MiB) OR
  #        the events.jsonl.archive directory shows a rotation marker file
  #        mtime within the last 7 days (rotation is doing its job).
  #   WARN when the file is at/above the threshold AND no recent rotation
  #        marker exists — `lib/common.sh` will rotate on the next emit,
  #        but if a host has gone quiet (no agents firing) the file may be
  #        oversized for a while and the operator should know.
  #   FAIL when ANY line in events.jsonl does not parse as JSON. Best-
  #        effort: a missing file is PASS (nothing to check). The malformed
  #        case never aborts the doctor pass — we always emit the row.
  local es_status="PASS" es_reason=""
  local es_cache="$HOME/.cache/${slug}-agent"
  local es_events="$es_cache/events.jsonl"
  local es_archive_dir="$es_cache/events.jsonl.archive"
  local es_max="${FLEET_EVENTS_MAX_BYTES:-1048576}"
  if [ -f "$es_events" ]; then
    # Malformed-line check first: any single line failing JSON.parse promotes
    # to FAIL regardless of size. We use python3 (ships with macOS Command
    # Line Tools) to avoid a node hard-dep here; fall back to node if python3
    # is missing. If neither exists we silently skip the parse check (PASS).
    local es_bad=""
    if command -v python3 >/dev/null 2>&1; then
      es_bad="$(python3 - "$es_events" <<'PY' 2>/dev/null || true
import json, sys
path = sys.argv[1]
try:
  with open(path, encoding="utf-8") as f:
    for i, line in enumerate(f, start=1):
      s = line.strip()
      if not s:
        continue
      try:
        json.loads(s)
      except Exception:
        print(i)
        break
except Exception:
  pass
PY
)"
    elif command -v node >/dev/null 2>&1; then
      es_bad="$(node -e '
        const fs = require("fs");
        const lines = fs.readFileSync(process.argv[1], "utf8").split("\n");
        for (let i = 0; i < lines.length; i++) {
          const s = lines[i].trim();
          if (!s) continue;
          try { JSON.parse(s); }
          catch (e) { console.log(i + 1); process.exit(0); }
        }
      ' "$es_events" 2>/dev/null || true)"
    fi
    if [ -n "$es_bad" ]; then
      es_status="FAIL"
      es_reason="events.jsonl line $es_bad does not parse as JSON"
    else
      # Size check + rotation-marker freshness.
      local es_size
      es_size=$(stat -f %z "$es_events" 2>/dev/null || stat -c %s "$es_events" 2>/dev/null || echo 0)
      if [ "$es_size" -ge "$es_max" ]; then
        # Look for a recent (< 7d) archive file: a rotation has fired
        # recently and the next emit will rotate this one too.
        local es_now es_recent=""
        es_now=$(date -u +%s)
        if [ -d "$es_archive_dir" ]; then
          local f
          for f in "$es_archive_dir"/*.jsonl; do
            [ -f "$f" ] || continue
            local fm fage
            fm=$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null || echo 0)
            fage=$(( es_now - fm ))
            if [ "$fage" -lt 604800 ]; then
              es_recent="$f"
              break
            fi
          done
        fi
        if [ -z "$es_recent" ]; then
          es_status="WARN"
          es_reason="events.jsonl is ${es_size}B (>= ${es_max}B) with no rotation in the last 7d"
        fi
      fi
    fi
  fi
  echo "events_size|$es_status|$es_reason"

  # check: groom_cadence (ticket 0007)
  # Surfaces whether `lib/groom.sh` has throttled itself because the
  # backlog ran dry. The signal is the per-slug marker file
  # `$CACHE_DIR/groom-slowed-since` written by fleet_check_groom_cadence.
  # PASS = no marker, OR marker is stale (>=12h old → next groom will
  # clear it and proceed). WARN = marker is fresh; the reason string
  # carries the marker timestamp so operators see the throttle's age.
  # We never FAIL here — throttling is by design, not an error.
  local gc_status="PASS" gc_reason=""
  local gc_marker="$HOME/.cache/${slug}-agent/groom-slowed-since"
  if [ -f "$gc_marker" ]; then
    local gc_now gc_mtime gc_age
    gc_now=$(date -u +%s)
    gc_mtime=$(stat -f %m "$gc_marker" 2>/dev/null || stat -c %Y "$gc_marker" 2>/dev/null || echo "$gc_now")
    gc_age=$(( gc_now - gc_mtime ))
    if [ "$gc_age" -lt 43200 ]; then
      local gc_ts; gc_ts="$(cat "$gc_marker" 2>/dev/null || echo "?")"
      gc_status="WARN"
      gc_reason="groom throttled since $gc_ts (empty_backlog; ${gc_age}s of 12h floor)"
    fi
  fi
  echo "groom_cadence|$gc_status|$gc_reason"
}

# Build the per-project block (human form). Reads check rows on stdin, decides
# the project status (FAIL > WARN > PASS), and prints one block.
doctor_render_human() {
  local slug="$1"
  local rows="$2"   # newline-joined name|status|reason lines
  local worst="PASS"
  while IFS='|' read -r name status reason; do
    [ -z "$name" ] && continue
    [ "$name" = "__SLUG__" ] && continue
    if [ "$status" = "FAIL" ]; then worst="FAIL"
    elif [ "$status" = "WARN" ] && [ "$worst" != "FAIL" ]; then worst="WARN"
    fi
  done <<<"$rows"

  local color="$c_grn"
  [ "$worst" = "WARN" ] && color="$c_ylw"
  [ "$worst" = "FAIL" ] && color="$c_red"
  printf '%b[%s]%b %s\n' "$color" "$worst" "$c_rst" "$slug"
  while IFS='|' read -r name status reason; do
    [ -z "$name" ] && continue
    [ "$name" = "__SLUG__" ] && continue
    if [ "$status" != "PASS" ]; then
      printf '  %-18s %s  %s\n' "$name" "$status" "$reason"
    else
      printf '  %-18s %s\n' "$name" "$status"
    fi
  done <<<"$rows"
  echo
}

doctor() {
  local want_json=0 slug_filter=""
  shift  # drop the leading "doctor"
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) want_json=1; shift ;;
      --slug) slug_filter="${2:-}"; shift 2 ;;
      --slug=*) slug_filter="${1#--slug=}"; shift ;;
      -h|--help)
        cat <<USAGE
fleet doctor — diagnose every installed project (PASS/WARN/FAIL)

Usage:
  fleet doctor               survey FLEET_DISCOVERY_ROOT (default ~/Desktop/projects)
  fleet doctor --json        machine-readable summary
  fleet doctor --slug NAME   restrict to one project
USAGE
        exit 0 ;;
      *) echo "fleet doctor: unknown flag '$1'" >&2; exit 2 ;;
    esac
  done

  local manifests=()
  while IFS= read -r m; do
    [ -n "$m" ] && manifests+=("$m")
  done < <(find "$DOCTOR_ROOT" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort)

  local any_fail=0
  local json_projects=""
  for m in "${manifests[@]:-}"; do
    [ -z "$m" ] && continue
    local rows; rows="$(doctor_run_checks "$m")"
    local slug; slug="$(echo "$rows" | sed -n 's/^__SLUG__|\(.*\)|.*/\1/p' | head -1)"
    [ -n "$slug_filter" ] && [ "$slug" != "$slug_filter" ] && continue

    # Track project-level status for exit code.
    if echo "$rows" | grep -q '|FAIL|'; then any_fail=1; fi

    if [ "$want_json" = "1" ]; then
      local checks_json=""
      while IFS='|' read -r name status reason; do
        [ -z "$name" ] && continue
        [ "$name" = "__SLUG__" ] && continue
        local esc_name esc_status esc_reason
        esc_name="$(doctor_json_escape "$name")"
        esc_status="$(doctor_json_escape "$status")"
        esc_reason="$(doctor_json_escape "$reason")"
        [ -n "$checks_json" ] && checks_json+=","
        checks_json+="{\"name\":\"$esc_name\",\"status\":\"$esc_status\",\"reason\":\"$esc_reason\"}"
      done <<<"$rows"
      [ -n "$json_projects" ] && json_projects+=","
      json_projects+="{\"slug\":\"$(doctor_json_escape "$slug")\",\"checks\":[$checks_json]}"
    else
      doctor_render_human "$slug" "$rows"
    fi
  done

  if [ "$want_json" = "1" ]; then
    printf '{"projects":[%s]}\n' "$json_projects"
  fi

  [ "$any_fail" = "1" ] && exit 1
  exit 0
}

if [ "$CMD" = "doctor" ]; then
  doctor "$@"
fi

# --- digest ---------------------------------------------------------------
# Ticket 0012. `fleet digest` prints one line per discovered project
# summarising the last 24h (configurable via --since Nh|Nd): state tag,
# `N opened / M merged` PRs, $X.YY spend, and the most recent event type
# (or the last LESSONS.md line if no events in 7d).
#
# Discovery uses FLEET_DISCOVERY_ROOT — same root as doctor (0003). The
# output is intentionally line-oriented so an operator can pipe it into
# `mail`, `grep`, or a tmux status bar.
#
# Output contract (one line per project, slug-alpha):
#   <slug>  <STATE>  N opened / M merged  $X.YY  <last-event-or-lesson>
# State priority (red → quiet):
#   EXPIRED       past SELF_CANCEL
#   OVER-BUDGET   today's spend ≥ MAX_DAILY_USD
#   PAUSED        launchd label <ns>.agent-ship is disabled
#   THROTTLED     $CACHE_DIR/groom-slowed-since exists (ticket 0007)
#   STUCK         an open agent PR is >24h old with no activity in 6h
#   OK            none of the above
# Exit code 1 if ANY project is red (EXPIRED/OVER-BUDGET/STUCK); else 0.
#
# --json mode emits a JSON array with the same fields plus structured
# sub-fields (slug, state, prs_opened, prs_merged, spend_usd, last,
# self_cancel, since_seconds). The schema is the source of truth for any
# downstream consumer (fleet-control, cron-mailed digests).

DIGEST_ROOT="${FLEET_DISCOVERY_ROOT:-$HOME/Desktop/projects}"

# Parse "Nh" or "Nd" → seconds. Echoes 0 + returns 1 on bad input.
digest_parse_since() {
  local s="$1" n unit
  case "$s" in
    *h) unit=h; n="${s%h}" ;;
    *d) unit=d; n="${s%d}" ;;
    *)  return 1 ;;
  esac
  case "$n" in
    ''|*[!0-9]*) return 1 ;;
  esac
  if [ "$unit" = "h" ]; then echo $(( n * 3600 ))
  else                       echo $(( n * 86400 )); fi
}

# Convert an ISO8601-ish UTC timestamp to epoch seconds. Returns "" on parse
# failure so the caller can skip the record without aborting the whole digest.
# macOS BSD date wants -j -f; GNU date takes -d directly.
digest_iso_to_epoch() {
  local ts="$1"
  [ -z "$ts" ] && return 0
  # Strip trailing Z + any sub-second fraction.
  local clean; clean="$(echo "$ts" | sed -E 's/\.[0-9]+Z$/Z/; s/Z$//')"
  date -u -j -f '%Y-%m-%dT%H:%M:%S' "$clean" +%s 2>/dev/null \
    || date -u -d "$ts" +%s 2>/dev/null \
    || true
}

# Sum total_cost_usd in runs.jsonl whose ts_start ≥ cutoff_epoch. Echoes a
# number like "1.50". Tolerates a missing file (echoes 0).
digest_spend_since() {
  local runs="$1" cutoff="$2"
  [ -f "$runs" ] || { echo "0"; return 0; }
  awk -v cutoff="$cutoff" '
    function iso2ep(ts,    cmd, out) {
      gsub(/\.[0-9]+Z$/, "Z", ts); sub(/Z$/, "", ts)
      cmd = "date -u -j -f %Y-%m-%dT%H:%M:%S \"" ts "\" +%s 2>/dev/null"
      cmd = cmd " || date -u -d \"" ts "Z\" +%s 2>/dev/null"
      if ((cmd | getline out) <= 0) out = 0
      close(cmd)
      return out + 0
    }
    {
      ts=""; cost=0
      if (match($0, /"ts_start"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        ts=substr($0, RSTART, RLENGTH)
        sub(/.*"ts_start"[[:space:]]*:[[:space:]]*"/, "", ts)
        sub(/".*/, "", ts)
      }
      if (match($0, /"total_cost_usd"[[:space:]]*:[[:space:]]*-?[0-9.eE+-]+/)) {
        c=substr($0, RSTART, RLENGTH)
        sub(/.*:[[:space:]]*/, "", c)
        cost = c + 0
      }
      if (ts == "") next
      ep = iso2ep(ts)
      if (ep >= cutoff) total += cost
    }
    END { printf("%.2f", total + 0) }
  ' "$runs"
}

# Count events of a given type in events.jsonl whose ts ≥ cutoff.
digest_event_count_since() {
  local events="$1" cutoff="$2" want_type="$3"
  [ -f "$events" ] || { echo 0; return 0; }
  awk -v cutoff="$cutoff" -v want="$want_type" '
    function iso2ep(ts,    cmd, out) {
      gsub(/\.[0-9]+Z$/, "Z", ts); sub(/Z$/, "", ts)
      cmd = "date -u -j -f %Y-%m-%dT%H:%M:%S \"" ts "\" +%s 2>/dev/null"
      cmd = cmd " || date -u -d \"" ts "Z\" +%s 2>/dev/null"
      if ((cmd | getline out) <= 0) out = 0
      close(cmd)
      return out + 0
    }
    {
      ts=""; type=""
      if (match($0, /"ts"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        ts=substr($0, RSTART, RLENGTH)
        sub(/.*"ts"[[:space:]]*:[[:space:]]*"/, "", ts); sub(/".*/, "", ts)
      }
      if (match($0, /"type"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        type=substr($0, RSTART, RLENGTH)
        sub(/.*"type"[[:space:]]*:[[:space:]]*"/, "", type); sub(/".*/, "", type)
      }
      if (type != want) next
      if (iso2ep(ts) >= cutoff) n++
    }
    END { print (n+0) }
  ' "$events"
}

# Print the .type of the most recent event in events.jsonl. Echoes empty if
# none. Most recent = last line (file is append-only). Caller decides whether
# to fall back to LESSONS.md based on age.
digest_last_event() {
  local events="$1"
  [ -f "$events" ] || return 0
  local line
  line="$(tail -n 1 "$events" 2>/dev/null)"
  [ -z "$line" ] && return 0
  echo "$line" | sed -nE 's/.*"type"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/p'
}

# Echo the ts of the most recent event as epoch seconds, or empty.
digest_last_event_epoch() {
  local events="$1"
  [ -f "$events" ] || return 0
  local line; line="$(tail -n 1 "$events" 2>/dev/null)"
  [ -z "$line" ] && return 0
  local ts; ts="$(echo "$line" | sed -nE 's/.*"ts"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/p')"
  digest_iso_to_epoch "$ts"
}

# Echo the last non-empty line of LESSONS.md, truncated to 60 chars. Empty
# if the file doesn't exist.
digest_last_lesson() {
  local proj_dir="$1"
  local lf
  for lf in "$proj_dir/docs/LESSONS.md" "$proj_dir/LESSONS.md"; do
    [ -f "$lf" ] || continue
    awk 'NF { last=$0 } END { print last }' "$lf" | cut -c1-60
    return 0
  done
}

# Compute the state tag per the ticket's priority order. Echoes one of
# EXPIRED | OVER-BUDGET | PAUSED | THROTTLED | STUCK | OK.
digest_state() {
  local self_cancel="$1" spend_today="$2" cap="$3" namespace="$4" cache_dir="$5"
  # EXPIRED — SELF_CANCEL is YYYYMMDD (UTC).
  local today; today="$(date -u +%Y%m%d)"
  case "$self_cancel" in
    ''|*[!0-9]*) ;;
    *) if [ "$today" -ge "$self_cancel" ]; then echo "EXPIRED"; return 0; fi ;;
  esac
  # OVER-BUDGET — today's spend ≥ cap (when cap is set).
  if [ -n "$cap" ]; then
    if awk -v s="$spend_today" -v c="$cap" 'BEGIN { exit !(s + 0 >= c + 0) }'; then
      echo "OVER-BUDGET"; return 0
    fi
  fi
  # PAUSED — launchctl print-disabled lists the agent-ship label.
  if command -v launchctl >/dev/null 2>&1; then
    if launchctl print-disabled "gui/$UID" 2>/dev/null \
         | grep -q "\"$namespace.agent-ship\" => true"; then
      echo "PAUSED"; return 0
    fi
  fi
  # THROTTLED — groom-slowed-since marker exists (ticket 0007).
  if [ -f "$cache_dir/groom-slowed-since" ]; then
    echo "THROTTLED"; return 0
  fi
  # STUCK — defer to caller (needs `gh`); the digest opts out of STUCK when
  # gh is unavailable. We treat STUCK as out-of-scope unless explicitly
  # surfaced via `FLEET_DIGEST_STUCK=1` + a non-empty stuck signal file
  # (kept simple for the v1 — STUCK is the noisiest signal to compute).
  if [ -f "$cache_dir/stuck-pr" ]; then
    echo "STUCK"; return 0
  fi
  echo "OK"
}

# Today's UTC-day spend, used for the OVER-BUDGET check (which is per
# calendar day, not per --since window).
digest_spend_today() {
  local runs="$1"
  [ -f "$runs" ] || { echo "0"; return 0; }
  local today; today="$(date -u +%Y-%m-%d)"
  awk -v day="$today" '
    {
      ts=""; cost=0
      if (match($0, /"ts_start"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        ts=substr($0, RSTART, RLENGTH)
        sub(/.*"ts_start"[[:space:]]*:[[:space:]]*"/, "", ts); sub(/".*/, "", ts)
      }
      if (match($0, /"total_cost_usd"[[:space:]]*:[[:space:]]*-?[0-9.eE+-]+/)) {
        c=substr($0, RSTART, RLENGTH); sub(/.*:[[:space:]]*/, "", c); cost = c + 0
      }
      if (index(ts, day) == 1) total += cost
    }
    END { printf("%.2f", total + 0) }
  ' "$runs"
}

# Render one project line in human form. All inputs pre-computed.
digest_render_human() {
  local slug="$1" state="$2" opened="$3" merged="$4" spend="$5" last="$6"
  printf '%s  %s  %s opened / %s merged  $%s  %s\n' \
    "$slug" "$state" "$opened" "$merged" "$spend" "$last"
}

digest() {
  shift  # drop "digest"
  local want_json=0 slug_filter="" since="24h" emoji=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)  want_json=1; shift ;;
      --emoji) emoji=1; shift ;;
      --slug)  slug_filter="${2:-}"; shift 2 ;;
      --slug=*) slug_filter="${1#--slug=}"; shift ;;
      --since) since="${2:-}"; shift 2 ;;
      --since=*) since="${1#--since=}"; shift ;;
      -h|--help)
        cat <<USAGE
fleet digest — one-line summary per project for the trailing window.

Usage:
  fleet digest                       survey all projects, last 24h
  fleet digest --slug NAME           restrict to one project
  fleet digest --since 7d            widen the window (Nh or Nd)
  fleet digest --json                machine-readable array
  fleet digest --emoji               (reserved; non-ASCII state glyphs)

Output (one line per project, slug-alpha order):
  <slug>  <STATE>  N opened / M merged  \$X.YY  <last-event-or-lesson>

States, priority order: EXPIRED, OVER-BUDGET, PAUSED, THROTTLED, STUCK, OK.

JSON schema (one object per project):
  { slug, state, prs_opened, prs_merged, spend_usd, last,
    self_cancel, since_seconds }

Exit code: 1 if any project is in a red state
(EXPIRED, OVER-BUDGET, STUCK); else 0.
USAGE
        exit 0 ;;
      *) echo "fleet digest: unknown flag '$1'" >&2; exit 2 ;;
    esac
  done

  # We don't currently use --emoji's value, but accepting the flag now lets
  # us add glyphs later without breaking callers. Reference it once so the
  # static analyzer doesn't complain about an unread variable.
  : "$emoji"

  local since_seconds
  if ! since_seconds="$(digest_parse_since "$since")"; then
    echo "fleet digest: --since must be Nh or Nd (got '$since')" >&2
    exit 2
  fi
  local now cutoff
  now=$(date -u +%s)
  cutoff=$(( now - since_seconds ))
  local seven_days_ago=$(( now - 7 * 86400 ))

  # Discover manifests under FLEET_DISCOVERY_ROOT — same pattern as doctor.
  local manifests=()
  while IFS= read -r m; do
    [ -n "$m" ] && manifests+=("$m")
  done < <(find "$DIGEST_ROOT" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort)

  local any_red=0
  local json_rows=""
  local m
  for m in "${manifests[@]:-}"; do
    [ -z "$m" ] && continue
    local proj_dir; proj_dir="$(dirname "$m")"
    # Load manifest in a subshell, echo back the fields we need.
    local probe slug namespace self_cancel cap
    probe=$(
      # shellcheck disable=SC1090
      ( source "$m" 2>/dev/null
        echo "SLUG=${SLUG:-}"
        echo "NAMESPACE=${NAMESPACE:-com.fleet.${SLUG:-x}}"
        echo "SELF_CANCEL=${SELF_CANCEL:-}"
        echo "MAX_DAILY_USD=${MAX_DAILY_USD:-}"
      ) 2>/dev/null
    ) || true
    slug="$(echo "$probe" | sed -n 's/^SLUG=//p')"
    namespace="$(echo "$probe" | sed -n 's/^NAMESPACE=//p')"
    self_cancel="$(echo "$probe" | sed -n 's/^SELF_CANCEL=//p')"
    cap="$(echo "$probe" | sed -n 's/^MAX_DAILY_USD=//p')"
    [ -z "$slug" ] && continue
    [ -n "$slug_filter" ] && [ "$slug" != "$slug_filter" ] && continue

    local cache_dir="$HOME/.cache/${slug}-agent"
    local runs="$cache_dir/runs.jsonl"
    local events="$cache_dir/events.jsonl"

    # PR counts — events.jsonl is the source of truth (per AC#2). pr_opened
    # is emitted today; pr_merged is reserved for when a runner emits it.
    local opened merged
    opened="$(digest_event_count_since "$events" "$cutoff" "pr_opened")"
    merged="$(digest_event_count_since "$events" "$cutoff" "pr_merged")"

    # Spend in the requested window (display column) AND today's spend
    # (used for OVER-BUDGET, which is calendar-day per AC#4).
    local spend spend_today
    spend="$(digest_spend_since "$runs" "$cutoff")"
    spend_today="$(digest_spend_today "$runs")"

    local state
    state="$(digest_state "$self_cancel" "$spend_today" "$cap" "$namespace" "$cache_dir")"

    case "$state" in
      EXPIRED|OVER-BUDGET|STUCK) any_red=1 ;;
    esac

    # last-event-or-lesson. If newest event ≥ 7d ago, use type; otherwise
    # fall back to the trailing LESSONS.md line, truncated to 60 chars.
    local last last_type last_epoch
    last_type="$(digest_last_event "$events")"
    last_epoch="$(digest_last_event_epoch "$events")"
    if [ -n "$last_type" ] && [ -n "$last_epoch" ] && [ "$last_epoch" -ge "$seven_days_ago" ]; then
      last="$last_type"
      # Trim to 60 chars (the type alone is short; this is defensive).
      last="$(printf '%s' "$last" | cut -c1-60)"
    else
      last="$(digest_last_lesson "$proj_dir")"
      [ -z "$last" ] && last="-"
    fi

    if [ "$want_json" = "1" ]; then
      local esc_slug esc_state esc_last esc_sc
      esc_slug="$(doctor_json_escape "$slug")"
      esc_state="$(doctor_json_escape "$state")"
      esc_last="$(doctor_json_escape "$last")"
      esc_sc="$(doctor_json_escape "$self_cancel")"
      [ -n "$json_rows" ] && json_rows+=","
      json_rows+="{\"slug\":\"$esc_slug\",\"state\":\"$esc_state\""
      json_rows+=",\"prs_opened\":$opened,\"prs_merged\":$merged"
      json_rows+=",\"spend_usd\":$spend"
      json_rows+=",\"last\":\"$esc_last\""
      json_rows+=",\"self_cancel\":\"$esc_sc\""
      json_rows+=",\"since_seconds\":$since_seconds}"
    else
      digest_render_human "$slug" "$state" "$opened" "$merged" "$spend" "$last"
    fi
  done

  if [ "$want_json" = "1" ]; then
    printf '[%s]\n' "$json_rows"
  fi

  [ "$any_red" = "1" ] && exit 1
  exit 0
}

if [ "$CMD" = "digest" ]; then
  digest "$@"
fi

# --- weekly (ticket 0025) ------------------------------------------------
# `fleet weekly` prints a one-screen Sunday ROI rollup per project covering
# the trailing 7 days (configurable via --since Nh|Nd). Pure consumer of
# events.jsonl + runs.jsonl — emits NO new event types (P-6: telemetry is
# the source of truth; readers compose, they do not invent).
#
# Discovery reuses the same root-redirect pattern as `digest` / `overview`
# (FLEET_DISCOVERY_ROOT). Render is deliberately separate from `digest`
# because the column set differs (no LAST line; adds DRAFTS, PAUSED, INFRA).
# All per-row math reuses the digest helpers above:
#   digest_parse_since, digest_iso_to_epoch, digest_spend_since,
#   digest_event_count_since
# plus three thin wrappers named for the event type they count
# (weekly_draft_count_since / weekly_heal_count_since /
#  weekly_infra_flake_count_since) so the call sites read like English.
#
# Test seam: FLEET_WEEKLY_FAKE_NOW (epoch seconds) overrides "now" so the
# WEEK header, the cutoff math, and the self-cancel countdown all become
# deterministic for tests/weekly.sh.
#
# Naming clash check (LESSONS 2026-05-26): `weekly` is not a coreutils
# binary on macOS or Linux; no `_cmd` suffix needed.

WEEKLY_ROOT="${FLEET_DISCOVERY_ROOT:-$HOME/Desktop/projects}"
WEEKLY_INSTALLED="$HOME/.local/share/agent-fleet/projects"

# Discover (slug, manifest_path) rows union of the two roots, de-duped by
# SLUG, slug-alpha sorted. Working-tree manifests win over installed
# copies (same convention as `overview_discover`).
weekly_discover() {
  local _seen="" m slug
  { find "$WEEKLY_ROOT"      -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
    find "$WEEKLY_INSTALLED" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
  } | while read -r m; do
    [ -z "$m" ] && continue
    # shellcheck disable=SC1090
    slug=$( (source "$m"; echo "${SLUG:-}") 2>/dev/null )
    [ -z "$slug" ] && continue
    case " $_seen " in *" $slug "*) continue ;; esac
    _seen="$_seen $slug"
    printf '%s\t%s\n' "$slug" "$m"
  done | sort -t $'\t' -k1,1
}

# Thin, intent-named wrappers around digest_event_count_since so call
# sites read clearly. Each just counts one event type in the window.
weekly_draft_count_since() {        # $1 = events.jsonl, $2 = cutoff epoch
  digest_event_count_since "$1" "$2" "lesson_draft_emitted"
}
weekly_heal_count_since() {         # $1 = events.jsonl, $2 = cutoff epoch
  digest_event_count_since "$1" "$2" "gate_failed"
}
weekly_infra_flake_count_since() {  # $1 = events.jsonl, $2 = cutoff epoch
  digest_event_count_since "$1" "$2" "infra_flake_rerun"
}

# Count SHIP-prefixed runs.jsonl rows whose ts_start is in window. The
# result_head's "SHIP <ticket-id>" prefix is the dev agent's standard
# exit-line format (per prompts/ship.prompt.md line 159); we treat it as
# the proxy for "merged agent PR" since the offline rule (AC#2) forbids
# us from cross-referencing gh's mergedAt.
weekly_ship_count_since() {  # $1 = runs.jsonl, $2 = cutoff epoch
  local runs="$1" cutoff="$2"
  [ -f "$runs" ] || { echo 0; return 0; }
  awk -v cutoff="$cutoff" '
    function iso2ep(ts,    cmd, out) {
      gsub(/\.[0-9]+Z$/, "Z", ts); sub(/Z$/, "", ts)
      cmd = "date -u -j -f %Y-%m-%dT%H:%M:%S \"" ts "\" +%s 2>/dev/null"
      cmd = cmd " || date -u -d \"" ts "Z\" +%s 2>/dev/null"
      if ((cmd | getline out) <= 0) out = 0
      close(cmd)
      return out + 0
    }
    {
      ts=""; head=""
      if (match($0, /"ts_start"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        ts=substr($0, RSTART, RLENGTH)
        sub(/.*"ts_start"[[:space:]]*:[[:space:]]*"/, "", ts); sub(/".*/, "", ts)
      }
      if (match($0, /"result_head"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        head=substr($0, RSTART, RLENGTH)
        sub(/.*"result_head"[[:space:]]*:[[:space:]]*"/, "", head); sub(/".*/, "", head)
      }
      if (ts == "" || head == "") next
      if (substr(head, 1, 5) != "SHIP ") next
      if (iso2ep(ts) < cutoff) next
      n++
    }
    END { print (n+0) }
  ' "$runs"
}

# Days since the project's agent-ship plist was last touched (proxy for
# "how long has this project been paused?"). The mtime of
# ~/Library/LaunchAgents/com.<slug>.agent-ship.plist updates on each
# install.sh; if a project has been paused for less than the time since
# the last install, this OVERSTATES — acceptable for v1 per the ticket
# engineering notes. Echoes a non-negative integer, or empty when no
# plist exists.
weekly_paused_days() {  # $1 = namespace (e.g. com.courtiq)
  local namespace="$1"
  local plist="$HOME/Library/LaunchAgents/${namespace}.agent-ship.plist"
  [ -f "$plist" ] || { echo ""; return 0; }
  local mtime now
  mtime="$(stat -f %m "$plist" 2>/dev/null || stat -c %Y "$plist" 2>/dev/null)"
  [ -n "$mtime" ] || { echo ""; return 0; }
  now="${FLEET_WEEKLY_FAKE_NOW:-$(date -u +%s)}"
  local diff=$(( now - mtime ))
  [ "$diff" -lt 0 ] && diff=0
  echo $(( diff / 86400 ))
}

# Is the project currently paused (agent-ship label disabled in launchctl)?
# Echoes "1" yes, "0" no. Skipped silently when launchctl is unavailable.
weekly_is_paused() {  # $1 = namespace
  local namespace="$1"
  command -v launchctl >/dev/null 2>&1 || { echo 0; return 0; }
  if launchctl print-disabled "gui/$UID" 2>/dev/null \
       | grep -q "\"$namespace.agent-ship\" => true"; then
    echo 1
  else
    echo 0
  fi
}

# Self-cancel days remaining, honouring FLEET_WEEKLY_FAKE_NOW so the
# golden file's countdown stays stable. Echoes a possibly-negative integer
# (negative = past) or empty when SELF_CANCEL is unset / unparseable.
weekly_self_cancel_days() {  # $1 = YYYYMMDD
  local sc="$1"
  case "$sc" in
    ''|*[!0-9]*) echo ""; return 0 ;;
  esac
  local target; target=$(date -u -j -f "%Y%m%d" "$sc" +%s 2>/dev/null) || { echo ""; return 0; }
  local now_epoch="${FLEET_WEEKLY_FAKE_NOW:-$(date -u +%s)}"
  local today_iso today_epoch
  today_iso="$(date -u -r "$now_epoch" +%Y%m%d 2>/dev/null || date -u -d "@$now_epoch" +%Y%m%d)"
  today_epoch=$(date -u -j -f "%Y%m%d" "$today_iso" +%s 2>/dev/null) \
    || today_epoch=$(date -u -d "$today_iso" +%s 2>/dev/null) || today_epoch=0
  echo $(( (target - today_epoch) / 86400 ))
}

# Pad a string to a fixed DISPLAY width, treating the few non-ASCII glyphs
# we render (↑, ⚠, ✗, – en-dash) as 1 display column even though they
# take 3 UTF-8 bytes each. bash printf's %-Ns counts bytes, so without
# this helper the DRAFTS↑ header and the SELF-CANCEL "EXPIRED ✗" cells
# would mis-align under their column boundaries.
weekly_pad() {  # $1 = string, $2 = display width
  local s="$1" w="$2"
  local stripped="$s"
  stripped="${stripped//↑/X}"
  stripped="${stripped//⚠/X}"
  stripped="${stripped//✗/X}"
  stripped="${stripped//–/X}"
  local len="${#stripped}"
  local pad=$(( w - len ))
  [ "$pad" -lt 0 ] && pad=0
  printf '%s%*s' "$s" "$pad" ''
}

# Render one row (header or data). Eight columns, fixed widths. The
# DRAFTS, SELF-CANCEL columns may carry unicode glyphs — we route through
# weekly_pad so the byte-width arithmetic stays display-correct.
weekly_render_row() {
  local project="$1" shipped="$2" spend="$3" drafts="$4"
  local heal="$5" infra="$6" paused="$7" self_cancel="$8"
  weekly_pad "$project" 14;     printf ' '
  weekly_pad "$shipped" 8;      printf ' '
  weekly_pad "$spend" 8;        printf ' '
  weekly_pad "$drafts" 8;       printf ' '
  weekly_pad "$heal" 5;         printf ' '
  weekly_pad "$infra" 6;        printf ' '
  weekly_pad "$paused" 7;       printf ' '
  printf '%s\n' "$self_cancel"
}

weekly() {
  shift  # drop the leading "weekly"
  local want_json=0 slug_filter="" since="7d"
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)    want_json=1; shift ;;
      --slug)    slug_filter="${2:-}"; shift 2 ;;
      --slug=*)  slug_filter="${1#--slug=}"; shift ;;
      --since)   since="${2:-}"; shift 2 ;;
      --since=*) since="${1#--since=}"; shift ;;
      -h|--help)
        cat <<USAGE
fleet weekly — Sunday ROI rollup, one row per project.

Usage:
  fleet weekly                 default --since 7d window
  fleet weekly --since 14d     biweekly view (also accepts Nh)
  fleet weekly --slug NAME     restrict to one project (no ALL: line)
  fleet weekly --json          one JSON object per project + one summary

Columns:
  PROJECT      slug from manifest
  SHIPPED      count of merged agent PRs in window (SHIP-prefixed runs)
  \$SPEND       sum of runs.jsonl total_cost_usd in window
  DRAFTS↑      lesson_draft_emitted events in window (suffix * when > 0)
  HEAL         gate_failed events in window
  INFRA        infra_flake_rerun events in window
  PAUSED       "Nd!" if agent-ship label is disabled, else "no"
  SELF-CANCEL  days remaining (Nd / Nd ⚠ if ≤7 / EXPIRED ✗ if past)

Trailing lines:
  N* drafts waiting on you...  (only when sum(DRAFTS) > 0)
  ALL: P PRs shipped, \$S spent (\$avg/PR avg), H heal, I infra-flake
       rerun, P paused, E expired.  (suppressed when --slug given)

JSON schema (per-project):
  {slug, shipped, spend, drafts, heal, infra, paused_days,
   self_cancel_days, self_cancel_state}  self_cancel_state in ok|warn|expired
JSON schema (summary):
  {summary:true, prs, spend, avg_per_pr, heal, infra, paused, expired,
   window_days}

Read-only — no commits, no PRs, no new event types.
USAGE
        exit 0 ;;
      *) echo "fleet weekly: unknown flag '$1'" >&2; exit 2 ;;
    esac
  done

  local since_seconds
  if ! since_seconds="$(digest_parse_since "$since")"; then
    echo "weekly: invalid --since \"$since\" (use Nh or Nd)" >&2
    exit 2
  fi
  local now cutoff
  now="${FLEET_WEEKLY_FAKE_NOW:-$(date -u +%s)}"
  cutoff=$(( now - since_seconds ))
  local window_days=$(( since_seconds / 86400 ))
  [ "$window_days" -lt 1 ] && window_days=1

  # Header banner — only printed in human mode.
  if [ "$want_json" != "1" ]; then
    local from_iso to_iso
    from_iso="$(date -u -r "$cutoff" +%F 2>/dev/null || date -u -d "@$cutoff" +%F)"
    to_iso="$(date -u -r "$now" +%F 2>/dev/null || date -u -d "@$now" +%F)"
    printf 'WEEK OF %s – %s (%dd)\n' "$from_iso" "$to_iso" "$window_days"
    printf '\n'
    weekly_render_row "PROJECT" "SHIPPED" "\$SPEND" "DRAFTS↑" "HEAL" "INFRA" "PAUSED" "SELF-CANCEL"
    # Underline. 73 = total printable width of the row (14+1+8+1+8+1+8+1+5+1+6+1+7+1+11 = 74).
    printf -- '%s\n' "─────────────────────────────────────────────────────────────────────────"
  fi

  # Aggregate per-project, accumulating totals for the ALL: line.
  local total_prs=0 total_drafts=0 total_heal=0 total_infra=0
  local total_paused=0 total_expired=0
  # We sum spend in awk (float).
  local total_spend_dollars="0.00"

  local json_rows=""
  local slug manifest
  while IFS=$'\t' read -r slug manifest; do
    [ -z "$slug" ] && continue
    [ -n "$slug_filter" ] && [ "$slug" != "$slug_filter" ] && continue

    # Manifest probe — fetch namespace + self-cancel.
    local probe namespace self_cancel
    probe=$(
      # shellcheck disable=SC1090
      ( source "$manifest" 2>/dev/null
        echo "NAMESPACE=${NAMESPACE:-com.fleet.${SLUG:-x}}"
        echo "SELF_CANCEL=${SELF_CANCEL:-}"
      ) 2>/dev/null
    ) || true
    namespace="$(echo "$probe" | sed -n 's/^NAMESPACE=//p')"
    self_cancel="$(echo "$probe" | sed -n 's/^SELF_CANCEL=//p')"

    local cache_dir="$HOME/.cache/${slug}-agent"
    local runs="$cache_dir/runs.jsonl"
    local events="$cache_dir/events.jsonl"

    local shipped spend drafts heal infra
    shipped="$(weekly_ship_count_since        "$runs"   "$cutoff")"
    spend="$(  digest_spend_since             "$runs"   "$cutoff")"
    drafts="$( weekly_draft_count_since       "$events" "$cutoff")"
    heal="$(   weekly_heal_count_since        "$events" "$cutoff")"
    infra="$(  weekly_infra_flake_count_since "$events" "$cutoff")"

    # PAUSED + paused_days.
    local is_paused paused_days paused_cell
    is_paused="$(weekly_is_paused "$namespace")"
    if [ "$is_paused" = "1" ]; then
      paused_days="$(weekly_paused_days "$namespace")"
      [ -z "$paused_days" ] && paused_days=0
      paused_cell="${paused_days}d!"
      total_paused=$(( total_paused + 1 ))
    else
      paused_days=""
      paused_cell="no"
    fi

    # SELF-CANCEL cell + state.
    local sc_days sc_cell sc_state
    sc_days="$(weekly_self_cancel_days "$self_cancel")"
    if [ -z "$sc_days" ]; then
      sc_cell="—"; sc_state="ok"
    elif [ "$sc_days" -lt 0 ]; then
      sc_cell="EXPIRED ✗"; sc_state="expired"
      total_expired=$(( total_expired + 1 ))
    elif [ "$sc_days" -le 7 ]; then
      sc_cell="${sc_days}d ⚠"; sc_state="warn"
    else
      sc_cell="${sc_days}d"; sc_state="ok"
    fi

    # DRAFTS cell: append `*` when > 0 to draw the eye (per AC#2).
    local drafts_cell="$drafts"
    [ "$drafts" -gt 0 ] && drafts_cell="${drafts}*"

    # Accumulate totals (drafts numeric, not with asterisk).
    total_prs=$(( total_prs + shipped ))
    total_drafts=$(( total_drafts + drafts ))
    total_heal=$(( total_heal + heal ))
    total_infra=$(( total_infra + infra ))
    total_spend_dollars="$(awk -v a="$total_spend_dollars" -v b="$spend" \
      'BEGIN { printf("%.2f", a + b) }')"

    if [ "$want_json" = "1" ]; then
      local esc_slug
      esc_slug="$(doctor_json_escape "$slug")"
      local paused_days_json="null"
      [ -n "$paused_days" ] && paused_days_json="$paused_days"
      local sc_days_json="null"
      [ -n "$sc_days" ] && sc_days_json="$sc_days"
      [ -n "$json_rows" ] && json_rows+=$'\n'
      json_rows+="{\"slug\":\"$esc_slug\""
      json_rows+=",\"shipped\":$shipped"
      json_rows+=",\"spend\":$spend"
      json_rows+=",\"drafts\":$drafts"
      json_rows+=",\"heal\":$heal"
      json_rows+=",\"infra\":$infra"
      json_rows+=",\"paused_days\":$paused_days_json"
      json_rows+=",\"self_cancel_days\":$sc_days_json"
      json_rows+=",\"self_cancel_state\":\"$sc_state\"}"
    else
      weekly_render_row "$slug" "$shipped" "\$$spend" "$drafts_cell" \
                        "$heal" "$infra" "$paused_cell" "$sc_cell"
    fi
  done < <(weekly_discover)

  # Avg cost per PR. Empty / null when no PRs shipped this window.
  local avg_per_pr="" avg_per_pr_json="null"
  if [ "$total_prs" -gt 0 ]; then
    avg_per_pr="$(awk -v s="$total_spend_dollars" -v p="$total_prs" \
      'BEGIN { printf("%.2f", s / p) }')"
    avg_per_pr_json="$avg_per_pr"
  fi

  if [ "$want_json" = "1" ]; then
    # Stream one JSON object per line, project rows first, then summary.
    [ -n "$json_rows" ] && printf '%s\n' "$json_rows"
    printf '{"summary":true'
    printf ',"prs":%s' "$total_prs"
    printf ',"spend":%s' "$total_spend_dollars"
    printf ',"avg_per_pr":%s' "$avg_per_pr_json"
    printf ',"heal":%s' "$total_heal"
    printf ',"infra":%s' "$total_infra"
    printf ',"paused":%s' "$total_paused"
    printf ',"expired":%s' "$total_expired"
    printf ',"window_days":%s' "$window_days"
    printf '}\n'
    exit 0
  fi

  # Human-mode trailing lines.
  # Drafts hint: only when sum > 0.
  if [ "$total_drafts" -gt 0 ]; then
    printf '\n%d* drafts waiting on you. Promote in <repo>/docs/LESSONS.md or run\n' "$total_drafts"
    printf '`fleet digest --slug <slug>` for the per-project event tail.\n'
  fi

  # ALL: summary. Suppressed when --slug filter is set.
  if [ -z "$slug_filter" ]; then
    printf '\n'
    if [ "$total_prs" -gt 0 ]; then
      printf 'ALL: %d PRs shipped, $%s spent ($%s/PR avg), %d heal attempts,\n' \
        "$total_prs" "$total_spend_dollars" "$avg_per_pr" "$total_heal"
    else
      printf 'ALL: %d PRs shipped, $%s spent, %d heal attempts,\n' \
        "$total_prs" "$total_spend_dollars" "$total_heal"
    fi
    printf '     %d infra-flake rerun, %d paused, %d expired.\n' \
      "$total_infra" "$total_paused" "$total_expired"
  fi

  exit 0
}

if [ "$CMD" = "weekly" ]; then
  weekly "$@"
fi

# --- prompts-score (ticket 0024) -----------------------------------------
# `fleet prompts-score <slug> [--since Nh|Nd] [--json]` grades each prompt
# revision the project ran against, using events.jsonl + runs.jsonl as the
# rear-view mirror. Group key is the PROMPTS_SHA in effect at each run's
# ts_start; the timeline comes from `prompts_pin_changed` events emitted
# by lib/install.sh (this ticket) with `prompts_drift` events as the
# fallback for projects that haven't re-installed since the new pin
# tracking landed.
#
# Output (human): one header row, one row per revision, optional trend
# line when ≥2 revisions are present. The current revision (the SHA in
# effect at the latest event timestamp) carries a trailing `← current`
# marker. JSON output (--json) is one JSON object per line.
#
# Reuses digest_parse_since / digest_iso_to_epoch from the digest helpers
# above; the JSON-line awk patterns mirror digest_event_count_since.

# Test seam: FLEET_PROMPTS_SCORE_FAKE_NOW (epoch seconds) overrides "now"
# so the golden file's DATE column stays stable.
prompts_score_now() {
  echo "${FLEET_PROMPTS_SCORE_FAKE_NOW:-$(date -u +%s)}"
}

# Build the (epoch \t sha) timeline of prompt-pin transitions from
# events.jsonl, sorted ascending by epoch. prompts_pin_changed events are
# authoritative (the `new` field is the SHA going forward).
# prompts_drift events are the fallback for projects that haven't yet
# re-installed under the new code path: they carry `actual` as the SHA
# the runner observed.
#
# $1 = path to events.jsonl. Emits one "EPOCH<TAB>SHA" line per
# transition to stdout. No file = empty output.
prompts_score_assemble_timeline() {
  local events="$1"
  [ -f "$events" ] || return 0
  awk '
    function iso2ep(ts,    cmd, out) {
      gsub(/\.[0-9]+Z$/, "Z", ts); sub(/Z$/, "", ts)
      cmd = "date -u -j -f %Y-%m-%dT%H:%M:%S \"" ts "\" +%s 2>/dev/null"
      cmd = cmd " || date -u -d \"" ts "Z\" +%s 2>/dev/null"
      if ((cmd | getline out) <= 0) out = 0
      close(cmd)
      return out + 0
    }
    function field(line, key,    s) {
      if (match(line, "\"" key "\"[[:space:]]*:[[:space:]]*\"[^\"]*\"")) {
        s = substr(line, RSTART, RLENGTH)
        sub(".*\"" key "\"[[:space:]]*:[[:space:]]*\"", "", s)
        sub("\".*", "", s)
        return s
      }
      return ""
    }
    {
      type = field($0, "type"); if (type == "") next
      ts   = field($0, "ts");   if (ts   == "") next
      sha  = ""
      if (type == "prompts_pin_changed") {
        sha = field($0, "new")
      } else if (type == "prompts_drift") {
        sha = field($0, "actual")
      } else {
        next
      }
      if (sha == "") next
      ep = iso2ep(ts)
      if (ep == 0) next
      printf("%d\t%s\n", ep, sha)
    }
  ' "$events" | sort -n -k1,1
}

# Resolve every event of interest (pr_opened, gate_failed,
# lesson_draft_emitted, infra_flake_rerun) to its SHA via the timeline,
# and aggregate per-SHA counters. Inputs:
#   $1 = path to events.jsonl
#   $2 = path to a tmp file containing the timeline (epoch\tsha lines)
#   $3 = cutoff epoch (events with ts < cutoff are skipped)
# Emits one "SHA<TAB>PRS<TAB>DRAFTS<TAB>HEAL<TAB>INFRA" line per SHA seen.
prompts_score_aggregate_events() {
  local events="$1" timeline="$2" cutoff="$3"
  [ -f "$events" ] || return 0
  awk -v cutoff="$cutoff" -v timeline="$timeline" '
    BEGIN {
      n = 0
      while ((getline line < timeline) > 0) {
        split(line, a, "\t")
        tl_ep[n]  = a[1] + 0
        tl_sha[n] = a[2]
        n++
      }
      close(timeline)
    }
    function iso2ep(ts,    cmd, out) {
      gsub(/\.[0-9]+Z$/, "Z", ts); sub(/Z$/, "", ts)
      cmd = "date -u -j -f %Y-%m-%dT%H:%M:%S \"" ts "\" +%s 2>/dev/null"
      cmd = cmd " || date -u -d \"" ts "Z\" +%s 2>/dev/null"
      if ((cmd | getline out) <= 0) out = 0
      close(cmd)
      return out + 0
    }
    function field(line, key,    s) {
      if (match(line, "\"" key "\"[[:space:]]*:[[:space:]]*\"[^\"]*\"")) {
        s = substr(line, RSTART, RLENGTH)
        sub(".*\"" key "\"[[:space:]]*:[[:space:]]*\"", "", s)
        sub("\".*", "", s)
        return s
      }
      return ""
    }
    function sha_at(ep,    i, found) {
      found = ""
      for (i = 0; i < n; i++) {
        if (tl_ep[i] <= ep) { found = tl_sha[i] }
        else break
      }
      return found
    }
    {
      type = field($0, "type"); if (type == "") next
      if (type != "pr_opened" && type != "gate_failed" \
          && type != "lesson_draft_emitted" && type != "infra_flake_rerun") next
      ts = field($0, "ts"); if (ts == "") next
      ep = iso2ep(ts)
      if (ep < cutoff + 0) next
      sha = sha_at(ep)
      if (sha == "") next
      if (type == "pr_opened")            prs[sha]++
      else if (type == "lesson_draft_emitted") drafts[sha]++
      else if (type == "gate_failed")     heal[sha]++
      else if (type == "infra_flake_rerun") infra[sha]++
      seen[sha] = 1
    }
    END {
      for (sha in seen) {
        printf("%s\t%d\t%d\t%d\t%d\n",
               sha, prs[sha]+0, drafts[sha]+0, heal[sha]+0, infra[sha]+0)
      }
    }
  ' "$events"
}

# Aggregate runs.jsonl into per-SHA RUNS count + summed spend. Same
# timeline-lookup pattern. Emits "SHA<TAB>RUNS<TAB>SPEND" per SHA.
prompts_score_aggregate_runs() {
  local runs="$1" timeline="$2" cutoff="$3"
  [ -f "$runs" ] || return 0
  awk -v cutoff="$cutoff" -v timeline="$timeline" '
    BEGIN {
      n = 0
      while ((getline line < timeline) > 0) {
        split(line, a, "\t")
        tl_ep[n]  = a[1] + 0
        tl_sha[n] = a[2]
        n++
      }
      close(timeline)
    }
    function iso2ep(ts,    cmd, out) {
      gsub(/\.[0-9]+Z$/, "Z", ts); sub(/Z$/, "", ts)
      cmd = "date -u -j -f %Y-%m-%dT%H:%M:%S \"" ts "\" +%s 2>/dev/null"
      cmd = cmd " || date -u -d \"" ts "Z\" +%s 2>/dev/null"
      if ((cmd | getline out) <= 0) out = 0
      close(cmd)
      return out + 0
    }
    function sha_at(ep,    i, found) {
      found = ""
      for (i = 0; i < n; i++) {
        if (tl_ep[i] <= ep) { found = tl_sha[i] }
        else break
      }
      return found
    }
    {
      ts = ""; cost = 0
      if (match($0, /"ts_start"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        ts = substr($0, RSTART, RLENGTH)
        sub(/.*"ts_start"[[:space:]]*:[[:space:]]*"/, "", ts); sub(/".*/, "", ts)
      }
      if (match($0, /"total_cost_usd"[[:space:]]*:[[:space:]]*-?[0-9.eE+-]+/)) {
        c = substr($0, RSTART, RLENGTH); sub(/.*:[[:space:]]*/, "", c); cost = c + 0
      }
      if (ts == "") next
      ep = iso2ep(ts)
      if (ep < cutoff + 0) next
      sha = sha_at(ep)
      if (sha == "") next
      runs_n[sha]++
      spend[sha] += cost
      seen[sha] = 1
    }
    END {
      for (sha in seen) {
        printf("%s\t%d\t%.6f\n", sha, runs_n[sha]+0, spend[sha]+0)
      }
    }
  ' "$runs"
}

# Format a row. Args: sha date runs prs sendback_pct drafts heal_per_pr
# infra_flake spend_per_pr is_current.
prompts_score_render_row() {
  local sha="$1" date="$2" runs="$3" prs="$4" sendback="$5" drafts="$6"
  local heal="$7" infra="$8" spend="$9" is_current="${10}"
  local marker=""
  [ "$is_current" = "1" ] && marker="  ← current"
  # Column widths chosen to match the AC sample header:
  # SHA(7) DATE(10) RUNS(4) PRS(4) SENDBACK%(9) DRAFTS(6) HEAL/PR(7) INFRA-FLK(9) $/PR(5)
  printf -- '%-7s  %-10s  %4s  %4s  %9s  %6s  %7s  %9s  %5s%s\n' \
    "$sha" "$date" "$runs" "$prs" "$sendback" "$drafts" "$heal" "$infra" "$spend" "$marker"
}

prompts_score() {
  shift  # drop "prompts-score"
  local slug="" since="7d" want_json=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)     want_json=1; shift ;;
      --since)    since="${2:-}"; shift 2 ;;
      --since=*)  since="${1#--since=}"; shift ;;
      -h|--help)
        cat <<USAGE
fleet prompts-score — grade each prompt revision against the event log.

Usage:
  fleet prompts-score <slug>                   default --since 7d, table
  fleet prompts-score <slug> --since 30d       widen the window (Nh or Nd)
  fleet prompts-score <slug> --json            one JSON object per revision

Columns:
  SHA | DATE | RUNS | PRS | SENDBACK% | DRAFTS | HEAL/PR | INFRA-FLK | \$/PR

Per-revision metrics, drawn from events.jsonl + runs.jsonl under
\$HOME/.cache/<slug>-agent/. The current revision (SHA in effect at the
latest event timestamp) is marked with a trailing 'left-arrow current'.
USAGE
        exit 0 ;;
      --)         shift ;;
      -*)
        echo "prompts-score: unknown flag '$1'" >&2
        exit 2 ;;
      *)
        if [ -z "$slug" ]; then slug="$1"; shift
        else echo "prompts-score: unexpected extra argument '$1'" >&2; exit 2
        fi ;;
    esac
  done

  if [ -z "$slug" ]; then
    echo "prompts-score: missing <slug> argument" >&2
    exit 2
  fi

  local since_seconds
  if ! since_seconds="$(digest_parse_since "$since")"; then
    echo "prompts-score: invalid --since \"$since\" (use Nh or Nd)" >&2
    exit 2
  fi

  local cache_dir="$HOME/.cache/${slug}-agent"
  local events="$cache_dir/events.jsonl"
  local runs="$cache_dir/runs.jsonl"

  # Empty/missing events is not an error — it's a fresh project. Print the
  # documented message to stderr and exit 0.
  if [ ! -s "$events" ]; then
    echo "prompts-score: no events found for $slug (cache: $events)" >&2
    exit 0
  fi

  local now cutoff
  now="$(prompts_score_now)"
  cutoff=$(( now - since_seconds ))

  # Assemble the full timeline (every transition ever recorded). We need
  # the entries BEFORE the cutoff to seed each row's "what SHA was in
  # effect when this event landed?" lookup — without them, the row that
  # spans the cutoff would have no SHA. We pre-filter aggregation by
  # cutoff inside the awk passes.
  local timeline_file; timeline_file="$(mktemp -t prompts-score-tl.XXXXXX)"
  prompts_score_assemble_timeline "$events" > "$timeline_file"
  if [ ! -s "$timeline_file" ]; then
    rm -f "$timeline_file"
    echo "prompts-score: no events found for $slug (cache: $events)" >&2
    exit 0
  fi

  # Aggregate events + runs by SHA.
  local events_agg runs_agg
  events_agg="$(prompts_score_aggregate_events "$events" "$timeline_file" "$cutoff")"
  runs_agg="$(prompts_score_aggregate_runs "$runs" "$timeline_file" "$cutoff")"

  # Determine the current SHA — the last entry in the timeline.
  local current_sha
  current_sha="$(tail -n 1 "$timeline_file" | awk -F'\t' '{print $2}')"

  # Build the union of SHAs that have at least one event or one run in window.
  # Use a temp file so we can preserve order via the timeline's epoch sort.
  local union_file; union_file="$(mktemp -t prompts-score-u.XXXXXX)"
  {
    [ -n "$events_agg" ] && echo "$events_agg" | awk -F'\t' '{print $1}'
    [ -n "$runs_agg" ]   && echo "$runs_agg"   | awk -F'\t' '{print $1}'
  } | sort -u > "$union_file"

  # If nothing fell in the window, treat that like "no events found" so a
  # too-tight --since doesn't produce an empty table.
  if [ ! -s "$union_file" ]; then
    rm -f "$timeline_file" "$union_file"
    echo "prompts-score: no events found for $slug (cache: $events)" >&2
    exit 0
  fi

  # Order SHAs by their first-appearance epoch in the timeline. SHAs not
  # in the timeline (data-only) sort last.
  local ordered_shas
  ordered_shas="$(
    while IFS= read -r sha; do
      [ -z "$sha" ] && continue
      local ep
      ep="$(awk -F'\t' -v s="$sha" '$2 == s { print $1; exit }' "$timeline_file")"
      [ -z "$ep" ] && ep=9999999999
      printf '%s\t%s\n' "$ep" "$sha"
    done < "$union_file" | sort -n -k1,1 | awk -F'\t' '{print $2}'
  )"

  # Render. Human mode prints the header + a separator + one row per SHA;
  # JSON mode skips the header and emits one JSON object per line.
  local header sep_line
  header='SHA      DATE        RUNS  PRS   SENDBACK%  DRAFTS  HEAL/PR  INFRA-FLK  $/PR'
  # 77 box-drawing chars to underline the header — counts the same as the
  # AC sample. Pure ASCII to keep `LC_ALL=C` safe.
  sep_line="$(printf '%.0s-' $(seq 1 77))"

  if [ "$want_json" != "1" ]; then
    printf '%s\n' "$header"
    printf '%s\n' "$sep_line"
  fi

  # Track the previous row's metrics for the trend line.
  local rows_emitted=0
  local prev_sendback="" prev_heal="" prev_spend=""
  local cur_sendback="" cur_heal="" cur_spend=""
  local sha
  while IFS= read -r sha; do
    [ -z "$sha" ] && continue
    local row_prs row_drafts row_heal row_infra row_runs row_spend
    row_prs=0; row_drafts=0; row_heal=0; row_infra=0
    row_runs=0; row_spend=0
    if [ -n "$events_agg" ]; then
      local er
      er="$(echo "$events_agg" | awk -F'\t' -v s="$sha" '$1 == s { print; exit }')"
      if [ -n "$er" ]; then
        row_prs="$(echo "$er" | awk -F'\t' '{print $2}')"
        row_drafts="$(echo "$er" | awk -F'\t' '{print $3}')"
        row_heal="$(echo "$er" | awk -F'\t' '{print $4}')"
        row_infra="$(echo "$er" | awk -F'\t' '{print $5}')"
      fi
    fi
    if [ -n "$runs_agg" ]; then
      local rr
      rr="$(echo "$runs_agg" | awk -F'\t' -v s="$sha" '$1 == s { print; exit }')"
      if [ -n "$rr" ]; then
        row_runs="$(echo "$rr" | awk -F'\t' '{print $2}')"
        row_spend="$(echo "$rr" | awk -F'\t' '{print $3}')"
      fi
    fi

    # DATE — the YYYY-MM-DD of this SHA's first appearance in the
    # timeline. Falls back to "—" if the SHA never appears (shouldn't
    # happen given the union construction, but defensive).
    local sha_epoch row_date
    sha_epoch="$(awk -F'\t' -v s="$sha" '$2 == s { print $1; exit }' "$timeline_file")"
    if [ -n "$sha_epoch" ]; then
      row_date="$(date -u -r "$sha_epoch" +%F 2>/dev/null \
                  || date -u -d "@$sha_epoch" +%F 2>/dev/null \
                  || echo "—")"
    else
      row_date="—"
    fi

    # Derived metrics. Guard against divide-by-zero when PRS=0.
    local sendback_pct heal_per_pr spend_per_pr sendback_rate_json heal_per_pr_json spend_per_pr_json
    if [ "$row_prs" -gt 0 ]; then
      sendback_pct="$(awk -v d="$row_drafts" -v p="$row_prs" \
                       'BEGIN { printf("%.1f%%", (d/p)*100) }')"
      heal_per_pr="$(awk -v h="$row_heal" -v p="$row_prs" \
                       'BEGIN { printf("%.1f", h/p) }')"
      spend_per_pr="$(awk -v s="$row_spend" -v p="$row_prs" \
                       'BEGIN { printf("$%.2f", s/p) }')"
      sendback_rate_json="$(awk -v d="$row_drafts" -v p="$row_prs" \
                       'BEGIN { printf("%.4f", d/p) }')"
      heal_per_pr_json="$(awk -v h="$row_heal" -v p="$row_prs" \
                       'BEGIN { printf("%.4f", h/p) }')"
      spend_per_pr_json="$(awk -v s="$row_spend" -v p="$row_prs" \
                       'BEGIN { printf("%.4f", s/p) }')"
    else
      sendback_pct="0.0%"
      heal_per_pr="0.0"
      spend_per_pr="\$0.00"
      sendback_rate_json="0.0000"
      heal_per_pr_json="0.0000"
      spend_per_pr_json="0.0000"
    fi

    local is_current=0
    [ "$sha" = "$current_sha" ] && is_current=1

    if [ "$want_json" = "1" ]; then
      local is_current_json="false"
      [ "$is_current" = "1" ] && is_current_json="true"
      printf '{"sha":"%s","date":"%s","runs":%s,"prs":%s,"sendback_rate":%s,"drafts":%s,"heal_per_pr":%s,"infra_flake":%s,"spend_per_pr":%s,"is_current":%s}\n' \
        "$sha" "$row_date" "$row_runs" "$row_prs" "$sendback_rate_json" \
        "$row_drafts" "$heal_per_pr_json" "$row_infra" "$spend_per_pr_json" \
        "$is_current_json"
    else
      prompts_score_render_row "$sha" "$row_date" "$row_runs" "$row_prs" \
        "$sendback_pct" "$row_drafts" "$heal_per_pr" "$row_infra" \
        "$spend_per_pr" "$is_current"
    fi

    # Track for trend line (we use the LAST two rows in display order).
    prev_sendback="$cur_sendback"
    prev_heal="$cur_heal"
    prev_spend="$cur_spend"
    cur_sendback="$(echo "$sendback_pct" | sed 's/%$//')"
    cur_heal="$heal_per_pr"
    cur_spend="$(echo "$spend_per_pr" | sed 's/^\$//')"
    rows_emitted=$(( rows_emitted + 1 ))
  done <<< "$ordered_shas"

  # Trend line: only when ≥2 revisions present AND we're not in JSON mode.
  if [ "$want_json" != "1" ] && [ "$rows_emitted" -ge 2 ]; then
    local d_sendback d_heal d_spend
    d_sendback="$(awk -v c="$cur_sendback" -v p="$prev_sendback" \
                    'BEGIN { printf("%+.1fpp", c - p) }')"
    d_heal="$(awk -v c="$cur_heal" -v p="$prev_heal" \
                'BEGIN { printf("%+.1f", c - p) }')"
    d_spend="$(awk -v c="$cur_spend" -v p="$prev_spend" \
                'BEGIN { printf("$%+.2f", c - p) }')"
    printf 'trend: sendback %s, heal/PR %s, $/PR %s vs previous revision.\n' \
      "$d_sendback" "$d_heal" "$d_spend"
  fi

  rm -f "$timeline_file" "$union_file"
  exit 0
}

if [ "$CMD" = "prompts-score" ]; then
  prompts_score "$@"
fi

# --- tail -----------------------------------------------------------------
# Ticket 0015. `fleet tail` streams events.jsonl entries live, formatted for
# human eyes. With no arg it follows every discovered project concurrently;
# with a positional slug it restricts to one. Flags:
#   --since Ns|Nm|Nh|Nd   pre-roll events from the cutoff window before
#                         following live (per AGENTS.md § Telemetry, `ts` is
#                         ISO8601 UTC so the math is in UTC seconds).
#   --json                emit raw events.jsonl lines instead of the formatted
#                         "<HH:MM:SS>  <slug>/<phase>  <type>  <extras>" form.
#                         Useful for `fleet tail --json | jq .`.
#   --type a,b            comma-separated event-type allowlist. Lines whose
#                         `type` is not in the list are dropped.
#
# Discovery reuses doctor's two-root pattern: $FLEET_DISCOVERY_ROOT first,
# then ~/.local/share/agent-fleet/projects. Per slug we run one `tail -F`
# (capital F: survives rotation, important once ticket 0016 ships) into a
# small shell-only formatter — no `jq` dependency, consistent with the
# events.jsonl producer side (`fleet_emit_event` is also shell-only).
#
# SIGINT/SIGTERM trap kills every background `tail -F` PID so the operator
# can Ctrl-C without leaking processes. Per AGENTS.md § Telemetry, consumers
# MUST tolerate unknown event types — we never special-case `type`, so any
# new event lights up the tail output automatically.
#
# Test hook: $FLEET_TAIL_FAKE_NOW (epoch seconds) overrides the formatter's
# "now" so `--since` replay is deterministic in tests/tail.sh.

TAIL_ROOT="${FLEET_DISCOVERY_ROOT:-$HOME/Desktop/projects}"
TAIL_INSTALLED="$HOME/.local/share/agent-fleet/projects"

# Parse "Ns" / "Nm" / "Nh" / "Nd" to seconds. Echoes the integer + returns 0
# on success; returns 1 + echoes nothing on bad input. Mirrors digest's unit
# parser shape but adds the s/m units the ticket calls for.
tail_parse_since() {
  local s="$1" n unit
  case "$s" in
    *s) unit=s; n="${s%s}" ;;
    *m) unit=m; n="${s%m}" ;;
    *h) unit=h; n="${s%h}" ;;
    *d) unit=d; n="${s%d}" ;;
    *)  return 1 ;;
  esac
  case "$n" in
    ''|*[!0-9]*) return 1 ;;
  esac
  case "$unit" in
    s) echo "$n" ;;
    m) echo $(( n * 60 )) ;;
    h) echo $(( n * 3600 )) ;;
    d) echo $(( n * 86400 )) ;;
  esac
}

# Resolve discovered slug → events.jsonl path. Same union-by-SLUG pattern as
# the top-level `discover()` helper but standalone (we need the file path,
# not the manifest path) and tied to TAIL_ROOT so tests can override it.
tail_discover_events() {
  local _seen=""
  { find "$TAIL_ROOT" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
    find "$TAIL_INSTALLED" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
  } | while read -r m; do
    [ -z "$m" ] && continue
    # shellcheck disable=SC1090
    local slug; slug=$( (source "$m"; echo "${SLUG:-}") 2>/dev/null )
    [ -z "$slug" ] && continue
    case " $_seen " in *" $slug "*) continue ;; esac
    _seen="$_seen $slug"
    printf '%s\t%s\n' "$slug" "$HOME/.cache/${slug}-agent/events.jsonl"
  done
}

# Format one events.jsonl line for human consumption. Stdin gets the raw
# JSON line; stdout gets either the formatted "HH:MM:SS  slug/phase  type
# extras" string or the JSON line unchanged (when $1 is "json"). No `jq`.
# We pull the four required keys with a tiny awk; everything beyond becomes
# k=v extras in stable JSON-source order.
#
# $1: "json" | "human"
# $2: comma-separated type filter (empty = no filter)
tail_format_stream() {
  local mode="$1" type_filter="$2"
  awk -v mode="$mode" -v filter="$type_filter" '
    function strip_quotes(s) { gsub(/^"|"$/, "", s); return s }
    function field(line, name,    re, start, end, raw) {
      re = "\"" name "\"[[:space:]]*:[[:space:]]*"
      start = match(line, re)
      if (start == 0) return ""
      raw = substr(line, start + RLENGTH)
      if (substr(raw, 1, 1) == "\"") {
        # string value — find next unescaped quote.
        end = index(substr(raw, 2), "\"")
        if (end == 0) return ""
        return substr(raw, 2, end - 1)
      }
      # number/bool/null — read until comma or closing brace.
      end = match(raw, /[,}]/)
      if (end == 0) return raw
      return substr(raw, 1, end - 1)
    }
    # iso2hms: extract HH:MM:SS from an ISO8601 ts. ts looks like
    # "2026-05-26T14:37:09Z" or "...Z" with fractional seconds. We just
    # find the T and grab the 8 chars after it.
    function iso2hms(ts,    p) {
      p = index(ts, "T")
      if (p == 0) return ts
      return substr(ts, p + 1, 8)
    }
    {
      if ($0 ~ /^[[:space:]]*$/) next
      # Skip control lines (like "waiting for ..." or the per-file headers
      # the OSes tail emits with ==> file <== ) — they come from stdin
      # already (the formatter is downstream of `tail -F`).
      if ($0 ~ /^==>/) next
      ty = field($0, "type")
      if (filter != "") {
        # Match against comma-separated list.
        found = 0
        n = split(filter, parts, ",")
        for (i = 1; i <= n; i++) if (parts[i] == ty) { found = 1; break }
        if (!found) next
      }
      if (mode == "json") { print $0; fflush(); next }
      ts    = field($0, "ts")
      slug  = field($0, "slug")
      phase = field($0, "phase")
      # Extras: every "key":"value" pair except the four required keys.
      extras = ""
      rest = $0
      while (match(rest, /"[^"]+"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        seg = substr(rest, RSTART, RLENGTH)
        rest = substr(rest, RSTART + RLENGTH)
        # Parse seg = "key":"value"
        kq = index(seg, "\""); seg2 = substr(seg, kq + 1)
        kq2 = index(seg2, "\""); k = substr(seg2, 1, kq2 - 1)
        v_part = substr(seg2, kq2 + 1)
        vq = index(v_part, "\""); v_part2 = substr(v_part, vq + 1)
        vq2 = index(v_part2, "\""); v = substr(v_part2, 1, vq2 - 1)
        if (k == "ts" || k == "slug" || k == "phase" || k == "type") continue
        if (extras == "") extras = k "=" v
        else              extras = extras " " k "=" v
      }
      hms = iso2hms(ts)
      if (extras == "") printf("%s  %s/%s  %s\n", hms, slug, phase, ty)
      else              printf("%s  %s/%s  %s  %s\n", hms, slug, phase, ty, extras)
      fflush()
    }
  '
}

# Replay all events in $1 (events.jsonl) whose ts ≥ cutoff_epoch. Stdout is
# raw JSON lines — caller pipes them through tail_format_stream. Tolerates
# a missing file (echoes nothing).
tail_replay_since() {
  local events="$1" cutoff="$2"
  [ -f "$events" ] || return 0
  awk -v cutoff="$cutoff" '
    function iso2ep(ts,    cmd, out) {
      gsub(/\.[0-9]+Z$/, "Z", ts); sub(/Z$/, "", ts)
      cmd = "date -u -j -f %Y-%m-%dT%H:%M:%S \"" ts "\" +%s 2>/dev/null"
      cmd = cmd " || date -u -d \"" ts "Z\" +%s 2>/dev/null"
      if ((cmd | getline out) <= 0) out = 0
      close(cmd)
      return out + 0
    }
    {
      if ($0 ~ /^[[:space:]]*$/) next
      ts = ""
      if (match($0, /"ts"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        ts = substr($0, RSTART, RLENGTH)
        sub(/.*"ts"[[:space:]]*:[[:space:]]*"/, "", ts); sub(/".*/, "", ts)
      }
      if (ts == "") next
      if (iso2ep(ts) >= cutoff) print $0
    }
  ' "$events"
}

tail_cmd() {
  shift  # drop the leading "tail"
  local want_json=0 since="" type_filter="" slug_arg=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) want_json=1; shift ;;
      --since) since="${2:-}"; shift 2 ;;
      --since=*) since="${1#--since=}"; shift ;;
      --type) type_filter="${2:-}"; shift 2 ;;
      --type=*) type_filter="${1#--type=}"; shift ;;
      -h|--help)
        cat <<USAGE
fleet tail — stream events.jsonl entries live, formatted for human eyes.

Usage:
  fleet tail                   follow every discovered project concurrently
  fleet tail <slug>            restrict to one project
  fleet tail --since 5m        replay last 5 minutes before following live
  fleet tail --json            emit raw JSON lines (pipe into jq)
  fleet tail --type a,b        filter to a comma-separated type allowlist

Output (human form):
  <HH:MM:SS>  <slug>/<phase>  <type>  <extras k=v ...>

Exits 0 on SIGINT and cleans up background tail -F PIDs.
USAGE
        exit 0 ;;
      --) shift ;;
      -*) echo "fleet tail: unknown flag '$1'" >&2; exit 2 ;;
      *)
        if [ -z "$slug_arg" ]; then slug_arg="$1"; shift
        else echo "fleet tail: unexpected extra argument '$1'" >&2; exit 2
        fi ;;
    esac
  done

  # Resolve --since to a cutoff epoch (0 = no replay).
  local cutoff=0
  if [ -n "$since" ]; then
    local secs
    if ! secs="$(tail_parse_since "$since")"; then
      echo "fleet tail: --since must be Ns|Nm|Nh|Nd (got '$since')" >&2
      exit 2
    fi
    local now
    now="${FLEET_TAIL_FAKE_NOW:-$(date -u +%s)}"
    cutoff=$(( now - secs ))
  fi

  # Pick the format mode for downstream pipes.
  local mode="human"
  [ "$want_json" = "1" ] && mode="json"

  # Collect (slug, events_path) rows we plan to follow.
  local rows
  rows="$(tail_discover_events)"
  if [ -n "$slug_arg" ]; then
    rows="$(printf '%s\n' "$rows" | awk -F'\t' -v s="$slug_arg" '$1 == s')"
    if [ -z "$rows" ]; then
      echo "fleet tail: no project with SLUG=$slug_arg found under $TAIL_ROOT or $TAIL_INSTALLED" >&2
      exit 2
    fi
  fi
  if [ -z "$rows" ]; then
    echo "fleet tail: no projects discovered under $TAIL_ROOT" >&2
    exit 2
  fi

  # Background tail -F PIDs we'll need to clean up on SIGINT/SIGTERM.
  local -a pids=()
  cleanup() {
    local p
    for p in "${pids[@]:-}"; do
      [ -n "$p" ] && kill "$p" 2>/dev/null || true
    done
    # Best-effort: give them a beat, then SIGKILL the stragglers.
    sleep 0.1 2>/dev/null || true
    for p in "${pids[@]:-}"; do
      [ -n "$p" ] && kill -9 "$p" 2>/dev/null || true
    done
    exit 0
  }
  trap cleanup INT TERM

  # Replay phase: emit historical lines from every events.jsonl that exists,
  # in file order per slug. Run BEFORE starting tail -F so the replay output
  # lands before live lines on the formatter's stdin.
  local fifo
  fifo="$(mktemp -u -t fleet-tail.XXXXXX).fifo"
  mkfifo "$fifo"
  # Open the FIFO read end for the formatter. The formatter runs in the
  # foreground so the trap can fire when the operator hits Ctrl-C.
  tail_format_stream "$mode" "$type_filter" < "$fifo" &
  local fmt_pid=$!
  pids+=("$fmt_pid")

  # Open the FIFO write end on fd 3 so producers can append without each one
  # closing it (which would EOF the formatter prematurely).
  exec 3>"$fifo"
  # The FIFO file on disk is no longer needed once both ends are open.
  rm -f "$fifo"

  # Replay step (per slug, in discovery order). Skipped when cutoff == 0.
  if [ "$cutoff" -gt 0 ]; then
    while IFS=$'\t' read -r slug events; do
      [ -z "$slug" ] && continue
      [ -f "$events" ] || continue
      tail_replay_since "$events" "$cutoff" >&3 || true
    done <<<"$rows"
  fi

  # Live follow: one `tail -F` per slug, redirected to the formatter FIFO.
  # If the events.jsonl is missing we surface the wait message (human mode
  # only) and poll until it appears, then start the tailer.
  while IFS=$'\t' read -r slug events; do
    [ -z "$slug" ] && continue
    if [ ! -f "$events" ]; then
      [ "$mode" = "human" ] && echo "waiting for events.jsonl at $events..."
      # Spawn a background poller that waits, then starts tail -F. We DON'T
      # block here — multi-project mode must still follow projects whose
      # file does exist.
      (
        while [ ! -f "$events" ]; do sleep 1; done
        # Once the file appears, follow from offset 0 so we don't miss the
        # first lines (the producer may have written several before the
        # poller noticed).
        exec tail -n +1 -F "$events" >&3
      ) &
      pids+=("$!")
      continue
    fi
    # tail -n 0 -F: don't replay (we already did) — only the new lines.
    tail -n 0 -F "$events" >&3 &
    pids+=("$!")
  done <<<"$rows"

  # Wait for the formatter (the SIGINT trap kills children + exits 0).
  wait "$fmt_pid" 2>/dev/null || true
  cleanup
}

if [ "$CMD" = "tail" ]; then
  tail_cmd "$@"
fi

# --- rollback -------------------------------------------------------------
# Ticket 0017. `fleet rollback <slug>` identifies the most recent
# agent-authored merge (head:feat/ OR head:eng/) to main and opens a revert
# PR on `revert/<id>-<slug>`, with the same gating contract as any other
# agent PR. One subcommand, full audit trail.
#
# Discovery: the slug-to-repo resolver mirrors `tail`/`digest` (union of
# FLEET_DISCOVERY_ROOT and ~/.local/share/agent-fleet/projects, de-duped by
# SLUG). Once a slug resolves to a manifest, REPO_URL → owner/name is
# derived the same way `bin/fleet status` derives it.
#
# Flags:
#   --yes | -y         skip the "proceed with revert? [y/N]" prompt
#   --dry-run          print metadata + the exact git/gh commands; do nothing
#   --pr <N>           override auto-pick; revert the specific PR number
#                      (uses `gh pr view <N>` instead of `gh pr list`)
#
# Squash vs true merge: `gh pr view --json mergeMethod` tells us how the
# original PR landed. SQUASH → `git revert --no-edit <sha>` (single
# linear commit). MERGE → `git revert -m 1 <sha>` (true merge commits need
# the mainline-parent hint). The test covers both branches.
#
# Telemetry: emits `rollback_opened pr=<new> reverts=<orig>
# merge_commit=<sha>` to the slug's events.jsonl on success.
#
# Hard-NOs honoured: never pushes to main; never bypasses branch
# protection; the revert PR goes through the same `shellcheck` + `validate`
# gates as any other agent PR.

# Resolve slug → manifest path. Echoes the manifest path or empty.
rollback_resolve_manifest() {
  local want="$1"
  local roots=("${FLEET_DISCOVERY_ROOT:-$HOME/Desktop/projects}" "$HOME/.local/share/agent-fleet/projects")
  local root m slug
  for root in "${roots[@]}"; do
    [ -d "$root" ] || continue
    while IFS= read -r m; do
      [ -n "$m" ] || continue
      # shellcheck disable=SC1090
      slug=$( (source "$m"; echo "${SLUG:-}") 2>/dev/null )
      if [ "$slug" = "$want" ]; then
        echo "$m"
        return 0
      fi
    done < <(find "$root" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort)
  done
}

# Extract a single string-value JSON field from a flat object. The kit's
# gh --json responses never embed objects beyond `mergeCommit.oid`, which
# we handle as a special case below. Echoes the bare value (no quotes).
rollback_json_string() {
  local json="$1" key="$2"
  printf '%s' "$json" | sed -nE "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"([^\"]*)\".*/\\1/p" | head -1
}

# Extract a number value (PR number, etc.). Echoes the digits.
rollback_json_number() {
  local json="$1" key="$2"
  printf '%s' "$json" | sed -nE "s/.*\"$key\"[[:space:]]*:[[:space:]]*([0-9]+).*/\\1/p" | head -1
}

# Extract mergeCommit.oid (one-deep object) from a PR JSON object.
rollback_json_merge_oid() {
  local json="$1"
  printf '%s' "$json" | sed -nE 's/.*"mergeCommit"[[:space:]]*:[[:space:]]*\{[[:space:]]*"oid"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p' | head -1
}

# Parse the leading "<id>-<slug-tail>" out of an agent headRefName. Returns
# the part after the prefix (feat/, eng/) — e.g. "feat/0019-broken-thing"
# → "0019-broken-thing". Echoes empty if no recognised prefix.
rollback_branch_tail() {
  local head="$1"
  case "$head" in
    feat/*) echo "${head#feat/}" ;;
    eng/*)  echo "${head#eng/}" ;;
    *)      echo "" ;;
  esac
}

# Pick the most-recent agent-merged PR from a `gh pr list --json ...` JSON
# array. We split on `},{` (with optional whitespace) boundaries — safe
# because gh's JSON never nests braces inside string values without
# escaping AND we already have `mergeCommit` as the only nested object,
# which closes with `}` BEFORE the comma that starts the next top-level
# key. Picking the FIRST object yields the most recent merge because
# `gh pr list` returns mergedAt-desc by default.
rollback_first_pr_json() {
  local list_json="$1"
  # Normalize whitespace, strip the outer `[...]`, then replace `},{`
  # (with any inter-object whitespace) with a sentinel we can split on.
  printf '%s' "$list_json" \
    | tr -d '\n' \
    | sed -E 's/^[[:space:]]*\[[[:space:]]*//; s/[[:space:]]*\][[:space:]]*$//; s/\}[[:space:]]*,[[:space:]]*\{/}@@PRSPLIT@@{/g' \
    | awk 'BEGIN{RS="@@PRSPLIT@@"} NR==1 { gsub(/^[[:space:]]+|[[:space:]]+$/, ""); print; exit }'
}

rollback() {
  shift  # drop the leading "rollback"
  local slug_arg="" want_yes=0 want_dry=0 pr_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes|-y)   want_yes=1; shift ;;
      --dry-run)  want_dry=1; shift ;;
      --pr)       pr_override="${2:-}"; shift 2 ;;
      --pr=*)     pr_override="${1#--pr=}"; shift ;;
      -h|--help)
        cat <<USAGE
fleet rollback — revert the last agent-shipped commit on a project.

Usage:
  fleet rollback <slug>             interactive: pick the latest agent PR, prompt, revert
  fleet rollback <slug> --yes       skip the [y/N] prompt
  fleet rollback <slug> --dry-run   print metadata + planned commands; do nothing
  fleet rollback <slug> --pr <N>    revert the specific PR number (skips auto-pick)

Identifies the most recent merged PR whose head matches \`feat/\` or \`eng/\`
on \`main\`, opens a revert PR on branch \`revert/<id>-<slug>\`, and arms
\`gh pr merge --auto --squash\` so the standard gating CI checks decide if
the revert lands.
USAGE
        exit 0 ;;
      --) shift ;;
      -*) echo "fleet rollback: unknown flag '$1'" >&2; exit 2 ;;
      *)
        if [ -z "$slug_arg" ]; then slug_arg="$1"; shift
        else echo "fleet rollback: unexpected extra argument '$1'" >&2; exit 2
        fi ;;
    esac
  done

  if [ -z "$slug_arg" ]; then
    echo "fleet rollback: missing <slug>" >&2
    echo "usage: fleet rollback <slug> [--yes|--dry-run|--pr <N>]" >&2
    exit 2
  fi

  # Resolve slug → manifest → REPO_URL → owner/name + CACHE_DIR.
  local manifest
  manifest="$(rollback_resolve_manifest "$slug_arg")"
  if [ -z "$manifest" ]; then
    echo "fleet rollback: no project with SLUG=$slug_arg found" >&2
    exit 2
  fi
  local slug repo_url repo cache_dir
  # shellcheck disable=SC1090  # discovered at runtime
  eval "$(
    source "$manifest"
    echo "slug='${SLUG:-}'"
    echo "repo_url='${REPO_URL:-}'"
  )"
  repo="$(echo "$repo_url" | sed -E 's#https?://github.com/##; s#\.git$##')"
  cache_dir="$HOME/.cache/${slug}-agent"

  # Pick the target PR JSON.
  local target_json=""
  if [ -n "$pr_override" ]; then
    target_json="$(gh pr view "$pr_override" \
                     --repo "$repo" \
                     --json number,title,mergeCommit,headRefName,mergedAt,mergeMethod \
                     2>/dev/null || true)"
    if [ -z "$target_json" ] || [ "$target_json" = "{}" ]; then
      echo "fleet rollback: gh pr view $pr_override returned nothing" >&2
      exit 1
    fi
  else
    local list_json
    list_json="$(gh pr list \
                   --repo "$repo" \
                   --state merged \
                   --base main \
                   --limit 20 \
                   --search "head:feat/ OR head:eng/" \
                   --json number,title,mergeCommit,headRefName,mergedAt \
                   2>/dev/null || true)"
    if [ -z "$list_json" ] || [ "$list_json" = "[]" ]; then
      echo "no agent-merged feature PR found in the last 20 merges" >&2
      exit 1
    fi
    target_json="$(rollback_first_pr_json "$list_json")"
    if [ -z "$target_json" ]; then
      echo "no agent-merged feature PR found in the last 20 merges" >&2
      exit 1
    fi
  fi

  # Parse the target. mergeMethod only comes from `gh pr view`; when we got
  # the target from `gh pr list`, fetch it separately so the squash/merge
  # branch detection is always correct (AC#9).
  local pr_number title merge_oid head_ref merged_at merge_method
  pr_number="$(rollback_json_number "$target_json" "number")"
  title="$(rollback_json_string "$target_json" "title")"
  merge_oid="$(rollback_json_merge_oid "$target_json")"
  head_ref="$(rollback_json_string "$target_json" "headRefName")"
  merged_at="$(rollback_json_string "$target_json" "mergedAt")"
  merge_method="$(rollback_json_string "$target_json" "mergeMethod")"

  if [ -z "$merge_method" ]; then
    local view_json
    view_json="$(gh pr view "$pr_number" \
                   --repo "$repo" \
                   --json mergeMethod \
                   2>/dev/null || true)"
    merge_method="$(rollback_json_string "$view_json" "mergeMethod")"
  fi
  # Default: assume squash (the kit's standard merge style).
  [ -z "$merge_method" ] && merge_method="SQUASH"

  local branch_tail revert_branch
  branch_tail="$(rollback_branch_tail "$head_ref")"
  if [ -z "$branch_tail" ]; then
    echo "fleet rollback: PR #$pr_number head '$head_ref' is not an agent prefix (feat/, eng/)" >&2
    exit 1
  fi
  revert_branch="revert/${branch_tail}"

  # Pick the revert command form based on mergeMethod.
  local revert_cmd
  case "$merge_method" in
    SQUASH|REBASE) revert_cmd="git revert --no-edit $merge_oid" ;;
    MERGE)         revert_cmd="git revert -m 1 $merge_oid" ;;
    *)             revert_cmd="git revert --no-edit $merge_oid" ;;
  esac

  # Print target metadata. Same shape as the user-story callout in the ticket.
  echo "Last agent merge to main: $merged_at"
  echo "  commit:   $merge_oid"
  echo "  PR:       #$pr_number $head_ref"
  echo "  title:    $title"
  echo "  mergeMethod: $merge_method"

  local checkout="$cache_dir/rollback-checkout"
  local pr_body="Reverts #${pr_number}. Issued by fleet rollback ${slug}."
  local clone_cmd="git clone --depth 50 $repo_url $checkout"
  local create_cmd="gh pr create --fill --base main --head $revert_branch --body \"$pr_body\" --repo $repo"
  local merge_cmd="gh pr merge --auto --squash --repo $repo"

  if [ "$want_dry" = "1" ]; then
    echo
    echo "Planned (dry-run; nothing executed):"
    echo "  $clone_cmd"
    echo "  cd $checkout"
    echo "  git checkout -b $revert_branch"
    echo "  $revert_cmd"
    echo "  git push -u origin $revert_branch"
    echo "  $create_cmd"
    echo "  $merge_cmd"
    exit 0
  fi

  # Confirmation prompt (unless --yes).
  if [ "$want_yes" != "1" ]; then
    local reply=""
    # `read -r -p` writes the prompt to stderr in some shells; explicit echo
    # to stdout keeps the test's `grep <<< OUT` happy.
    echo -n "proceed with revert? [y/N] "
    read -r reply || reply=""
    case "$reply" in
      y|Y|yes|YES) : ;;
      *)
        echo "rollback cancelled."
        exit 0 ;;
    esac
  fi

  # --- Execute. ----------------------------------------------------------
  echo
  echo "Opening revert PR on branch $revert_branch..."

  # Fresh, isolated checkout under $CACHE_DIR/rollback-checkout. We do NOT
  # share state with the ship/groom/review checkouts so an in-flight ship
  # cannot race with the revert. Always start from a clean slate.
  rm -rf "$checkout"
  mkdir -p "$cache_dir"
  git clone --depth 50 "$repo_url" "$checkout" >/dev/null 2>&1 || {
    echo "fleet rollback: git clone failed" >&2
    exit 1
  }
  cd "$checkout" || { echo "fleet rollback: cd $checkout failed" >&2; exit 1; }
  git checkout -b "$revert_branch" >/dev/null 2>&1 || {
    echo "fleet rollback: git checkout -b $revert_branch failed" >&2
    exit 1
  }
  # shellcheck disable=SC2086  # revert_cmd intentionally word-splits the form
  $revert_cmd >/dev/null 2>&1 || {
    echo "fleet rollback: $revert_cmd failed (merge conflict? try --dry-run + manual revert)" >&2
    exit 1
  }
  git push -u origin "$revert_branch" >/dev/null 2>&1 || {
    echo "fleet rollback: git push failed" >&2
    exit 1
  }

  # Open the PR. Capture the URL → parse the new PR number from the trailing
  # /pull/<N> path component.
  local create_out new_pr_number=""
  create_out="$(gh pr create \
                  --fill \
                  --base main \
                  --head "$revert_branch" \
                  --body "$pr_body" \
                  --repo "$repo" \
                  2>&1 || true)"
  echo "$create_out"
  new_pr_number="$(echo "$create_out" | sed -nE 's#.*/pull/([0-9]+).*#\1#p' | head -1)"
  if [ -z "$new_pr_number" ]; then
    echo "fleet rollback: could not parse new PR number from 'gh pr create' output" >&2
    # Still arm auto-merge below if at all possible? No — without a PR number
    # we can't, and we'd skip the event emission too. Hard fail is right.
    exit 1
  fi

  gh pr merge "$new_pr_number" --auto --squash --repo "$repo" >/dev/null 2>&1 || true
  echo "Auto-merge armed for PR #$new_pr_number; waiting for CI green."

  # Emit telemetry. Initialize the cache dir + FLEET_PHASE so fleet_emit_event
  # routes the event to the right channel and tags it sensibly. We source
  # lib/common.sh from the repo this script lives in.
  local kit_root; kit_root="$( cd "$( dirname "$0" )/.." && pwd )"
  if [ -f "$kit_root/lib/common.sh" ]; then
    # shellcheck disable=SC1091
    (
      export SLUG="$slug"
      export CACHE_DIR="$cache_dir"
      export FLEET_PHASE="rollback"
      # shellcheck disable=SC1090
      source "$kit_root/lib/common.sh" >/dev/null 2>&1
      fleet_emit_event rollback_opened \
        "pr=$new_pr_number" \
        "reverts=$pr_number" \
        "merge_commit=$merge_oid"
    ) || true
  fi

  exit 0
}

if [ "$CMD" = "rollback" ]; then
  rollback "$@"
fi

# --- kickstart ------------------------------------------------------------
# Ticket 0010. `fleet kickstart <slug> <phase> [--dry-run]` is the operator's
# pre-flight check: it triggers a one-shot run of the per-slug launchd label
# matching the phase (`agent-ship`, `agent-groom`, `agent-review`, `agent-eng`).
# With `--dry-run`, the kickstart is prefixed by
# `launchctl setenv AGENT_DRY_RUN 1` so the runner gates `fleet_run_claude`
# into tool-locked mode (the prompt still runs end-to-end; only side-effects
# are blocked — see fleet_run_claude in lib/common.sh).
#
# We use `launchctl setenv` rather than `env AGENT_DRY_RUN=1 launchctl
# kickstart` because launchd jobs inherit the launchd user-session env, not
# the caller's. `setenv` writes into that session env so the spawned runner
# actually sees the variable. `unsetenv` after the kickstart call would
# leave a race window where a concurrent launchd fire (e.g. groom at :17
# while ship at :41) could also pick up the flag — so we intentionally
# leave the var set on the dry-run path. Operators can clear it themselves
# with `launchctl unsetenv AGENT_DRY_RUN` once they're done dry-running.
# Without `--dry-run`, we do NOT touch the launchd env at all, so the var
# stays unset across the kickstart call (verified by AC#6).
#
# Naming note (LESSONS 2026-05-26): we use `kickstart_cmd` rather than
# `kickstart` so the dispatch function never shadows any coreutils binary
# the same script might shell out to. No collision exists today, but
# `tail_cmd` set the precedent for any user-facing subcommand name.
#
# Discovery: slug → manifest via the same two-root pattern as rollback/tail/
# digest (FLEET_DISCOVERY_ROOT + ~/.local/share/agent-fleet/projects,
# de-duped by SLUG, working-tree manifest wins). NAMESPACE comes from the
# manifest; the label is "${NAMESPACE}.agent-${PHASE}".

# Resolve slug → manifest path. Echoes the manifest path or empty (same
# shape as rollback_resolve_manifest, kept independent so future churn in
# either doesn't ripple).
kickstart_resolve_manifest() {
  local want="$1"
  local roots=("${FLEET_DISCOVERY_ROOT:-$HOME/Desktop/projects}" "$HOME/.local/share/agent-fleet/projects")
  local root m slug
  for root in "${roots[@]}"; do
    [ -d "$root" ] || continue
    while IFS= read -r m; do
      [ -n "$m" ] || continue
      # shellcheck disable=SC1090
      slug=$( (source "$m"; echo "${SLUG:-}") 2>/dev/null )
      if [ "$slug" = "$want" ]; then
        echo "$m"
        return 0
      fi
    done < <(find "$root" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort)
  done
}

kickstart_cmd() {
  shift  # drop the leading "kickstart"
  local slug_arg="" phase_arg="" dry=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry=1; shift ;;
      -h|--help)
        cat <<USAGE
fleet kickstart — trigger a one-shot agent run, optionally in dry-run mode.

Usage:
  fleet kickstart <slug> <phase>             trigger the launchd label
  fleet kickstart <slug> <phase> --dry-run   set AGENT_DRY_RUN=1 first

<phase> is one of: ship, groom, review, eng.

In --dry-run mode the runner still calls claude end-to-end, but with
\`--allowedTools none\` so no side-effects (commits, pushes, gh calls)
land. The run emits \`run_dry_run plan_head=...\` to events.jsonl and
still appends to runs.jsonl with the real cost. Operator unsets the env
with: launchctl unsetenv AGENT_DRY_RUN
USAGE
        exit 0 ;;
      --) shift ;;
      -*) echo "fleet kickstart: unknown flag '$1'" >&2; exit 2 ;;
      *)
        if   [ -z "$slug_arg" ];  then slug_arg="$1";  shift
        elif [ -z "$phase_arg" ]; then phase_arg="$1"; shift
        else echo "fleet kickstart: unexpected extra argument '$1'" >&2; exit 2
        fi ;;
    esac
  done

  if [ -z "$slug_arg" ] || [ -z "$phase_arg" ]; then
    echo "fleet kickstart: missing <slug> and/or <phase>" >&2
    echo "usage: fleet kickstart <slug> <phase> [--dry-run]" >&2
    exit 2
  fi
  case "$phase_arg" in
    ship|groom|review|eng) ;;
    *)
      echo "fleet kickstart: <phase> must be ship|groom|review|eng (got '$phase_arg')" >&2
      exit 2 ;;
  esac

  local manifest
  manifest="$(kickstart_resolve_manifest "$slug_arg")"
  if [ -z "$manifest" ]; then
    echo "fleet kickstart: no project with SLUG=$slug_arg found" >&2
    exit 2
  fi
  local namespace
  # shellcheck disable=SC1090  # discovered at runtime
  namespace=$( (source "$manifest"; echo "${NAMESPACE:-com.fleet.${SLUG:-$slug_arg}}") 2>/dev/null )
  if [ -z "$namespace" ]; then
    echo "fleet kickstart: could not derive NAMESPACE from $manifest" >&2
    exit 2
  fi

  local uid="${UID:-$(id -u)}"
  local label="gui/${uid}/${namespace}.agent-${phase_arg}"

  # Dry-run: set the launchd session env so the spawned runner inherits it.
  # We deliberately do NOT unsetenv afterwards — see the module header.
  if [ "$dry" = "1" ]; then
    launchctl setenv AGENT_DRY_RUN 1 || true
  fi

  launchctl kickstart -k "$label"
  exit $?
}

if [ "$CMD" = "kickstart" ]; then
  kickstart_cmd "$@"
fi

# --- replay ---------------------------------------------------------------
# Ticket 0021. `fleet replay <slug> --pr <N> [--phase ship|review] [--out
# FILE] [--request-changes-ok]` re-runs the kit's CURRENT prompts against
# a past (merged OR open) PR in dry-run, so an operator who just edited
# `prompts/PRINCIPLES.md` or `prompts/ship.prompt.md` can sanity-check the
# change against real historical behavior BEFORE the live loop fires under
# it.
#
# Substrate: ticket 0010's `AGENT_DRY_RUN=1` already tool-locks `claude`
# with `--allowedTools none`. We invoke claude directly here (not
# `fleet_run_claude`) because:
#   - replay is operator-invoked, not a launchd runner — there's no
#     `fleet_log_init` to chain off of, and we don't want a log file in
#     `$LOG_DIR/replay-…` polluting log-mtime-based "last run" surfaces.
#   - We DO want the same runs.jsonl append shape (cost accounting per
#     AC#8), so we mirror the JSON layout `fleet_run_claude` writes today
#     but tag `phase=replay` so `fleet digest` can sort replay calls
#     from real ship runs.
#
# Prompt composition (per the ticket's "User → operator" lens):
#   --phase review → AGENTS.md + LESSONS.md + ticket + diff + the review
#                    contract ("VERDICT: sign-off | request-changes" + a
#                    rationale). The diff is the substance the prompt is
#                    grading.
#   --phase ship   → AGENTS.md + LESSONS.md + ticket (NO diff — ship is
#                    asked "what would you do?", not "is this good?").
#                    Verdict line: "ACTION: ship | heal | wait | noop".
#
# Verdict parsing: we grep the claude `.result` for the first line
# matching the phase's regex. If no line matches, replay prints
# `VERDICT: unknown` (or `ACTION: unknown`) and exits 1 — the operator
# sees the raw output in the saved file.
#
# Exit codes:
#   0  — verdict matches the success condition for the phase.
#   1  — verdict missing OR doesn't match (the default success is
#        sign-off/ship/heal; --request-changes-ok flips this).
#   2  — usage error: PR head isn't an agent feature prefix, missing
#        flag value, slug not resolved.
#
# Naming (LESSONS 2026-05-26): the dispatcher is named `replay()` — no
# coreutils binary by that name (we checked: `man replay` / `which replay`
# come up empty on macOS). The function shells out to `claude`, `gh`, and
# `git` only; nothing collides.

# Resolve slug → manifest path. Echoes the manifest or empty. Reuses the
# same two-root union pattern as rollback/kickstart (per ticket 0017's
# engineering notes). We declare a thin wrapper around
# `rollback_resolve_manifest` rather than duplicating the body so a future
# discovery-shape change ripples through one site.
replay_resolve_manifest() {
  rollback_resolve_manifest "$1"
}

# Parse the leading "<id>-<slug-tail>" out of an agent headRefName so the
# operator's "the ticket file is docs/backlog/<NNNN>-…" derivation has a
# stable input. Returns the part after the feat/ prefix, or empty.
replay_branch_tail() {
  local head="$1"
  case "$head" in
    feat/*) echo "${head#feat/}" ;;
    eng/*)  echo "${head#eng/}" ;;
    *)      echo "" ;;
  esac
}

# Compose the prompt body for one phase. Reads files from $checkout (the
# fresh agent-fleet checkout the function created) and the PR metadata
# from environment locals the caller already has in scope.
#
# Args: $1 phase, $2 checkout dir, $3 ticket-file path (may not exist),
# $4 diff (already on disk at this path), $5 pr_number, $6 pr_title,
# $7 head_ref, $8 pr_body, $9 merged_at.
replay_compose_prompt() {
  local phase="$1" checkout="$2" ticket_path="$3" diff_path="$4"
  local pr_number="$5" pr_title="$6" head_ref="$7" pr_body="$8" merged_at="$9"

  # Top matter: shared across phases.
  printf 'You are replaying the kit'\''s CURRENT %s prompt against a past PR.\n' "$phase"
  printf 'This is a dry-run: produce only a verdict + rationale.\n\n'

  printf '## PR metadata\n'
  # Use `printf -- 'fmt' arg` so a leading '-' in the format-line body is
  # not interpreted as a flag by some printf implementations.
  printf -- '- number: #%s\n' "$pr_number"
  printf -- '- title: %s\n' "$pr_title"
  printf -- '- head: %s\n' "$head_ref"
  printf -- '- merged_at: %s\n' "${merged_at:-(open)}"
  printf '\n'

  if [ -f "$checkout/AGENTS.md" ]; then
    printf '## AGENTS.md (current tree)\n'
    cat "$checkout/AGENTS.md"
    printf '\n'
  fi
  if [ -f "$checkout/docs/LESSONS.md" ]; then
    printf '## docs/LESSONS.md (current tree)\n'
    cat "$checkout/docs/LESSONS.md"
    printf '\n'
  fi
  if [ -n "$ticket_path" ] && [ -f "$ticket_path" ]; then
    printf '## Ticket\n'
    cat "$ticket_path"
    printf '\n'
  fi
  if [ -n "$pr_body" ]; then
    printf '## PR body\n%s\n\n' "$pr_body"
  fi

  case "$phase" in
    review)
      if [ -f "$diff_path" ]; then
        printf '## Diff (the substance to grade)\n'
        printf '```\n'
        cat "$diff_path"
        printf '\n```\n\n'
      fi
      printf '## Review contract\n'
      printf 'Read prompts/PRINCIPLES.md and AGENTS.md § Hard NOs. Decide whether\n'
      printf 'this diff would land cleanly under the current rules. Respond with\n'
      printf 'EXACTLY one line of the form:\n'
      printf '\n'
      printf '  VERDICT: sign-off\n'
      printf '  VERDICT: request-changes\n'
      printf '\n'
      printf 'followed by a one-paragraph rationale citing the principle id\n'
      printf '(P-N) you are acting under, if any.\n'
      ;;
    ship)
      printf '## Ship contract\n'
      printf 'Read prompts/PRINCIPLES.md, AGENTS.md, docs/LESSONS.md, and the\n'
      printf 'ticket above. Decide what the ship runner would do RIGHT NOW for\n'
      printf 'this ticket. Respond with EXACTLY one line of the form:\n'
      printf '\n'
      printf '  ACTION: ship\n'
      printf '  ACTION: heal\n'
      printf '  ACTION: wait\n'
      printf '  ACTION: noop\n'
      printf '\n'
      printf 'followed by a one-paragraph rationale.\n'
      ;;
  esac
}

# Append a runs.jsonl row for the replay call. Mirrors the shape
# fleet_run_claude emits (slug/phase/ts_start/ts_end/exit/model/
# session_id/total_cost_usd/duration_ms/num_turns/usage/is_error/
# result_head) so cost accounting + `fleet digest` ingest it without
# special-casing. Best-effort: missing jq → no append, no error.
replay_append_runs() {
  local runs_file="$1" claude_json="$2" slug="$3" phase="$4"
  local ts_start="$5" ts_end="$6" model="$7" claude_exit="$8"
  command -v jq >/dev/null 2>&1 || return 0
  jq -e . "$claude_json" >/dev/null 2>&1 || return 0
  local rec
  rec="$(jq -c \
    --arg slug "$slug" --arg phase "$phase" --arg exit "$claude_exit" \
    --arg s "$ts_start" --arg e "$ts_end" --arg model "$model" \
    '{slug:$slug,phase:$phase,ts_start:$s,ts_end:$e,exit:($exit|tonumber),model:$model,
      session_id:.session_id, total_cost_usd:.total_cost_usd, duration_ms:.duration_ms,
      num_turns:.num_turns, usage:.usage, is_error:.is_error, result_head:((.result//"")[0:500])}' \
    "$claude_json" 2>/dev/null)"
  if [ -n "$rec" ]; then
    mkdir -p "$(dirname "$runs_file")" 2>/dev/null || true
    printf '%s\n' "$rec" >> "$runs_file"
  fi
}

replay() {
  shift  # drop the leading "replay"
  local slug_arg="" pr_number="" phase="review" out_path="" want_rc_ok=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --pr)        pr_number="${2:-}";  shift 2 ;;
      --pr=*)      pr_number="${1#--pr=}"; shift ;;
      --phase)     phase="${2:-review}"; shift 2 ;;
      --phase=*)   phase="${1#--phase=}"; shift ;;
      --out)       out_path="${2:-}"; shift 2 ;;
      --out=*)     out_path="${1#--out=}"; shift ;;
      --request-changes-ok) want_rc_ok=1; shift ;;
      --dry)       shift ;;  # the default; accepted for symmetry
      -h|--help)
        cat <<USAGE
fleet replay — re-run the kit's current prompts against a past PR in dry-run.

Usage:
  fleet replay <slug> --pr <N>                          phase=review (default)
  fleet replay <slug> --pr <N> --phase ship             phase=ship
  fleet replay <slug> --pr <N> --request-changes-ok     succeed iff verdict is request-changes
  fleet replay <slug> --pr <N> --out FILE               write the full claude result to FILE

Composes a prompt input from the PR's metadata + diff (review) or just
metadata + ticket (ship), the AGENTS.md and docs/LESSONS.md from a fresh
kit checkout, then invokes claude with --allowedTools none so no
side-effects land. Prints the parsed verdict line (VERDICT: ... for
review, ACTION: ... for ship); exit 0 on success, 1 on a missing/wrong
verdict, 2 on usage error.
USAGE
        exit 0 ;;
      --) shift ;;
      -*) echo "fleet replay: unknown flag '$1'" >&2; exit 2 ;;
      *)
        if [ -z "$slug_arg" ]; then slug_arg="$1"; shift
        else echo "fleet replay: unexpected extra argument '$1'" >&2; exit 2
        fi ;;
    esac
  done

  if [ -z "$slug_arg" ] || [ -z "$pr_number" ]; then
    echo "fleet replay: missing <slug> or --pr <N>" >&2
    echo "usage: fleet replay <slug> --pr <N> [--phase review|ship] [--out FILE] [--request-changes-ok]" >&2
    exit 2
  fi
  case "$phase" in
    review|ship) ;;
    *)
      echo "fleet replay: --phase must be 'review' or 'ship' (got '$phase')" >&2
      exit 2 ;;
  esac

  # Resolve slug → manifest → REPO_URL + CACHE_DIR.
  local manifest
  manifest="$(replay_resolve_manifest "$slug_arg")"
  if [ -z "$manifest" ]; then
    echo "fleet replay: no project with SLUG=$slug_arg found" >&2
    exit 2
  fi
  local slug repo_url repo cache_dir model
  # shellcheck disable=SC1090  # discovered at runtime
  eval "$(
    source "$manifest"
    echo "slug='${SLUG:-}'"
    echo "repo_url='${REPO_URL:-}'"
    echo "model='${MODEL:-claude-opus-4-7}'"
  )"
  repo="$(echo "$repo_url" | sed -E 's#https?://github.com/##; s#\.git$##')"
  cache_dir="$HOME/.cache/${slug}-agent"
  mkdir -p "$cache_dir"

  # Fetch PR metadata. We pull more fields than we strictly need so the
  # composed prompt has every relevant header for the verdict-rendering
  # subagent (title/body matter; mergeCommit/mergedAt confirm the
  # merged-vs-open state).
  local pr_view_json
  pr_view_json="$(gh pr view "$pr_number" \
                    --repo "$repo" \
                    --json number,title,headRefName,body,mergeCommit,mergedAt,files,state \
                    2>/dev/null || true)"
  if [ -z "$pr_view_json" ] || [ "$pr_view_json" = "{}" ]; then
    echo "fleet replay: gh pr view $pr_number returned nothing" >&2
    exit 1
  fi

  # Parse the PR fields. We reuse the rollback_json_* helpers — they're
  # robust enough for flat-string fields and the one-deep mergeCommit oid.
  local pr_title head_ref pr_body merged_at
  pr_title="$(rollback_json_string "$pr_view_json" "title")"
  head_ref="$(rollback_json_string "$pr_view_json" "headRefName")"
  # `body` may contain quoted JSON characters; we only echo it into the
  # prompt, never re-emit it as JSON, so the shallow extractor is fine.
  pr_body="$(rollback_json_string "$pr_view_json" "body")"
  merged_at="$(rollback_json_string "$pr_view_json" "mergedAt")"

  local branch_tail
  branch_tail="$(replay_branch_tail "$head_ref")"
  if [ -z "$branch_tail" ]; then
    echo "not an agent feature PR; replay is scoped to feat/ and eng/ branches" >&2
    exit 2
  fi

  # Identify the linked ticket by the PR title's `feat/<id>-` prefix
  # convention. The branch_tail looks like "0017-fleet-rollback"; we
  # split on the first dash to get the 4-digit id.
  local ticket_id="${branch_tail%%-*}"

  # Fresh checkout to read AGENTS.md, LESSONS.md, and the ticket file at
  # the CURRENT tree's state (the whole point of "replay against current
  # prompts"). Uses $CACHE_DIR/replay-checkout — a separate dir from
  # ship/groom/review so a running ship can't race with a replay.
  local checkout="$cache_dir/replay-checkout"
  rm -rf "$checkout"
  mkdir -p "$(dirname "$checkout")"
  if ! git clone --depth 1 "$repo_url" "$checkout" >/dev/null 2>&1; then
    echo "fleet replay: git clone $repo_url failed" >&2
    exit 1
  fi

  # Find the ticket file by 4-digit id. We glob rather than assume the
  # exact slug-tail so a renamed-on-merge ticket still resolves.
  local ticket_path=""
  local cand
  for cand in "$checkout/docs/backlog/${ticket_id}-"*.md; do
    if [ -f "$cand" ]; then
      ticket_path="$cand"
      break
    fi
  done

  # Pull the diff for review phase. We only need this when the prompt
  # grades the diff; ship doesn't, per the ticket's AC#2.
  local diff_path="$cache_dir/replay-pr${pr_number}.diff"
  if [ "$phase" = "review" ]; then
    gh pr diff "$pr_number" --repo "$repo" > "$diff_path" 2>/dev/null || true
  fi

  # Compose the prompt body into a tmpfile, then pipe it to claude with
  # tool-lock. We do NOT shell out to fleet_run_claude — see the header.
  local prompt_file claude_out_json
  prompt_file="$(mktemp -t fleet-replay-prompt.XXXXXX)"
  claude_out_json="$(mktemp -t fleet-replay-claude.XXXXXX)"
  replay_compose_prompt \
    "$phase" "$checkout" "$ticket_path" "$diff_path" \
    "$pr_number" "$pr_title" "$head_ref" "$pr_body" "$merged_at" \
    > "$prompt_file"

  local ts_start ts_end claude_exit
  ts_start="$(date -u +%FT%TZ)"
  # AGENT_DRY_RUN is the kit's standard tool-lock env var — set it for
  # the duration of the claude call so any consumer that inspects env
  # (e.g. a future telemetry hook) sees we were in dry-run.
  AGENT_DRY_RUN=1 claude \
    --print \
    --output-format json \
    --dangerously-skip-permissions \
    --model "$model" \
    --allowedTools none \
    < "$prompt_file" \
    > "$claude_out_json" 2>/dev/null
  claude_exit=$?
  ts_end="$(date -u +%FT%TZ)"

  # Parse `result` from the claude JSON. Best-effort: missing jq → fall
  # back to the raw text.
  local result_text=""
  if command -v jq >/dev/null 2>&1 && jq -e . "$claude_out_json" >/dev/null 2>&1; then
    result_text="$(jq -r '.result // empty' "$claude_out_json")"
  else
    result_text="$(cat "$claude_out_json")"
  fi

  # Persist the full result to disk so the operator can `cat` it later.
  if [ -z "$out_path" ]; then
    local stamp; stamp="$(date -u +%Y%m%dT%H%M%SZ)"
    out_path="$cache_dir/replay-${slug}-pr${pr_number}-${phase}-${stamp}.txt"
  fi
  mkdir -p "$(dirname "$out_path")" 2>/dev/null || true
  printf '%s\n' "$result_text" > "$out_path"

  # Append to runs.jsonl with phase=replay (per AC#8).
  replay_append_runs \
    "$cache_dir/runs.jsonl" "$claude_out_json" \
    "$slug" "replay" "$ts_start" "$ts_end" "$model" "$claude_exit"

  # --- render summary -----------------------------------------------------
  echo "Replaying $phase prompt against $slug PR #$pr_number ($branch_tail)"
  [ -n "$ticket_path" ] && echo "  ticket: ${ticket_path#"$checkout/"} (${merged_at:-open})"
  echo "  prompt: composed at $prompt_file"
  echo "  result: $out_path"
  echo

  # Truncate the printed body to ~400 chars per AC#1.
  local head_400="${result_text:0:400}"
  echo "$head_400"
  [ "${#result_text}" -gt 400 ] && echo "[... truncated; full result at $out_path]"
  echo

  # Parse the verdict line.
  local verdict_re verdict
  case "$phase" in
    review) verdict_re='^VERDICT:[[:space:]]+(sign-off|request-changes)' ;;
    ship)   verdict_re='^ACTION:[[:space:]]+(heal|ship|wait|noop)' ;;
  esac
  verdict="$(printf '%s\n' "$result_text" \
              | grep -E -m1 "$verdict_re" \
              | head -1)"

  # Print the parsed verdict line on its own — the test grep relies on
  # this exact prefix (^VERDICT: / ^ACTION:) anchored at the start of a
  # line in stdout.
  if [ -n "$verdict" ]; then
    printf '%s\n' "$verdict"
  else
    case "$phase" in
      review) echo "VERDICT: unknown" ;;
      ship)   echo "ACTION: unknown" ;;
    esac
  fi

  # Compute exit code from the verdict + --request-changes-ok flag.
  local verdict_kind=""
  if [ -n "$verdict" ]; then
    verdict_kind="$(printf '%s' "$verdict" \
                    | sed -nE 's/^(VERDICT|ACTION):[[:space:]]+([a-zA-Z_-]+).*/\2/p')"
  fi

  rm -f "$prompt_file" "$claude_out_json"

  case "$phase" in
    review)
      if [ "$want_rc_ok" = "1" ]; then
        [ "$verdict_kind" = "request-changes" ] && exit 0 || exit 1
      else
        [ "$verdict_kind" = "sign-off" ] && exit 0 || exit 1
      fi
      ;;
    ship)
      # Success = "would do real work" (ship or heal). wait/noop/unknown → 1.
      # --request-changes-ok is review-only; on ship we ignore it.
      case "$verdict_kind" in
        ship|heal) exit 0 ;;
        *)         exit 1 ;;
      esac
      ;;
  esac
}

if [ "$CMD" = "replay" ]; then
  replay "$@"
fi

# --- overview -------------------------------------------------------------
# Ticket 0019. `fleet overview` prints a single cross-project table answering
# "what is the fleet doing right now?" One row per discovered project, columns:
#
#   PROJECT  SHIP  REVIEW  SENDBK  $TODAY  IN-FLIGHT  STATE
#
# It is the cross-project subtraction the operator wants on day 2 with 3-7
# projects installed: instead of running `fleet doctor`, `fleet digest`, and
# `gh pr list` per repo, one command renders the fleet's pulse.
#
# Read-only: never mutates a manifest, never opens a PR, never touches gh
# beyond `gh pr list` per project. Discovery uses the same two-root pattern
# as doctor/digest/tail (FLEET_DISCOVERY_ROOT first, then
# ~/.local/share/agent-fleet/projects), de-duped by SLUG. No new lib/ helpers.
#
# STATE priority order (per the ticket):
#   EXPIRED > PAUSED > OVER-BUDGET > STUCK > HEAL > OK
# The first three reuse `digest_state`'s predicates verbatim. STUCK and HEAL
# need `gh` and are computed in a second pass inside this function (gracefully
# skipped when gh is offline — AC#7).
#
# Naming (LESSONS 2026-05-26): the dispatcher is named `overview()` — no
# coreutils binary by that name, so no `_cmd` suffix needed. The function
# does NOT shell out to anything called `overview`.
#
# Test hook: $FLEET_OVERVIEW_FAKE_NOW (epoch seconds) overrides "now" so
# SHIP-age math in tests/overview.sh is deterministic.

OVERVIEW_ROOT="${FLEET_DISCOVERY_ROOT:-$HOME/Desktop/projects}"
OVERVIEW_INSTALLED="$HOME/.local/share/agent-fleet/projects"

# Discover (slug, manifest_path, repo_url) rows union of the two roots,
# de-duped by SLUG, in slug-alpha order. Working-tree manifests win over
# installed copies (same convention as `discover()` at the top of this file).
overview_discover() {
  local _seen="" m slug repo_url
  { find "$OVERVIEW_ROOT"      -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
    find "$OVERVIEW_INSTALLED" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
  } | while read -r m; do
    [ -z "$m" ] && continue
    # shellcheck disable=SC1090
    slug=$( (source "$m"; echo "${SLUG:-}") 2>/dev/null )
    [ -z "$slug" ] && continue
    case " $_seen " in *" $slug "*) continue ;; esac
    _seen="$_seen $slug"
    # shellcheck disable=SC1090
    repo_url=$( (source "$m"; echo "${REPO_URL:-}") 2>/dev/null )
    printf '%s\t%s\t%s\n' "$slug" "$m" "$repo_url"
  done | sort -t $'\t' -k1,1
}

# Pluck the open agent PR for one project. Echoes "NUMBER|STATE|UPDATED_EPOCH"
# or empty when no PR is open (or gh fails). STATE is one of
# GREEN/RED/PENDING/BEHIND/DIRTY derived from mergeStateStatus + the rollup.
overview_inflight() {
  local repo="$1"
  command -v gh >/dev/null 2>&1 || { echo ""; return 0; }
  [ -n "$repo" ] || { echo ""; return 0; }
  # `gh pr list --search "head:feat/ head:eng/"` excludes chore/gtm-* (per
  # the engineering notes). The result is one PR per row in JSON; we take
  # the lowest-numbered (Phase 1 convention in lib/ship.sh).
  local raw
  raw="$(gh pr list \
            --repo "$repo" \
            --state open \
            --base main \
            --search "head:feat/ head:eng/" \
            --json number,mergeStateStatus,statusCheckRollup,headRefName,updatedAt \
            --limit 5 \
            2>/dev/null)" || true
  [ -z "$raw" ] || [ "$raw" = "[]" ] && { echo ""; return 0; }
  # Pick the lowest PR number. Use node if it's available; fall back to a
  # tiny sed scan when not.
  local picked=""
  if command -v node >/dev/null 2>&1; then
    picked="$(node -e '
      try {
        const arr = JSON.parse(require("fs").readFileSync(0, "utf8"));
        if (!Array.isArray(arr) || arr.length === 0) process.exit(0);
        arr.sort((a, b) => a.number - b.number);
        const p = arr[0];
        // Reduce statusCheckRollup → derived state. GitHub conclusions:
        // SUCCESS/FAILURE/CANCELLED/SKIPPED/NEUTRAL (and null while pending).
        const rollup = Array.isArray(p.statusCheckRollup) ? p.statusCheckRollup : [];
        let derived = "GREEN";
        let anyPending = false, anyFail = false;
        for (const c of rollup) {
          const v = (c.conclusion || c.status || "").toUpperCase();
          if (v === "FAILURE" || v === "FAILED" || v === "CANCELLED" || v === "TIMED_OUT") anyFail = true;
          if (v === "" || v === "IN_PROGRESS" || v === "QUEUED" || v === "PENDING") anyPending = true;
        }
        if (anyFail) derived = "RED";
        else if (anyPending) derived = "PENDING";
        // mergeStateStatus overrides for BEHIND/DIRTY (which are about the
        // branch, not the checks).
        const mss = (p.mergeStateStatus || "").toUpperCase();
        if (mss === "BEHIND") derived = "BEHIND";
        if (mss === "DIRTY") derived = "DIRTY";
        // Epoch seconds for updatedAt (used by STUCK detection).
        let epoch = 0;
        if (p.updatedAt) epoch = Math.floor(Date.parse(p.updatedAt) / 1000) || 0;
        process.stdout.write(`${p.number}|${derived}|${epoch}`);
      } catch (e) { /* drop */ }
    ' <<<"$raw")"
  else
    # Pure-shell fallback. Pick the first PR's number, treat status as GREEN
    # unless mergeStateStatus says otherwise. Good enough for the offline
    # fallback; the test rig has node.
    local n mss
    n="$(printf '%s' "$raw" | sed -nE 's/.*"number"[[:space:]]*:[[:space:]]*([0-9]+).*/\1/p' | head -1)"
    mss="$(printf '%s' "$raw" | sed -nE 's/.*"mergeStateStatus"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p' | head -1)"
    local derived="GREEN"
    case "$mss" in
      BEHIND) derived="BEHIND" ;;
      DIRTY)  derived="DIRTY" ;;
      BLOCKED) derived="RED" ;;
    esac
    [ -n "$n" ] && picked="${n}|${derived}|0"
  fi
  echo "$picked"
}

# Count `--request-changes` reviews in the trailing 24h via gh fallback.
# The ticket explicitly authorises using `gh pr list --search
# "review:changes-requested"` when no `review_blocked` event type exists.
overview_sendback_count() {
  local repo="$1"
  command -v gh >/dev/null 2>&1 || { echo 0; return 0; }
  [ -n "$repo" ] || { echo 0; return 0; }
  local raw
  raw="$(gh pr list \
            --repo "$repo" \
            --search "review:changes-requested updated:>$(date -u -v-1d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d '24 hours ago' +%Y-%m-%dT%H:%M:%SZ) head:feat/ head:eng/" \
            --json number \
            --limit 20 \
            2>/dev/null)" || true
  [ -z "$raw" ] || [ "$raw" = "[]" ] && { echo 0; return 0; }
  # Count objects. node when available; cheap brace count otherwise.
  if command -v node >/dev/null 2>&1; then
    node -e '
      try { const a = JSON.parse(require("fs").readFileSync(0, "utf8")); process.stdout.write(String(a.length || 0)); }
      catch (e) { process.stdout.write("0"); }
    ' <<<"$raw"
  else
    printf '%s' "$raw" | tr -cd '{' | wc -c | tr -d ' '
  fi
}

# Best-effort: last review verdict for a project, expressed as "ok Nh" /
# "block Nh" / "-". Sourced from gh pr list with the appropriate review
# filter, picking the most-recent updatedAt. When gh is offline we echo "-".
overview_last_review() {
  local repo="$1" now="$2"
  command -v gh >/dev/null 2>&1 || { echo "—"; return 0; }
  [ -n "$repo" ] || { echo "—"; return 0; }
  local raw
  raw="$(gh pr list \
            --repo "$repo" \
            --state open \
            --search "head:feat/ head:eng/" \
            --json number,reviewDecision,updatedAt \
            --limit 5 \
            2>/dev/null)" || true
  [ -z "$raw" ] || [ "$raw" = "[]" ] && { echo "—"; return 0; }
  if ! command -v node >/dev/null 2>&1; then
    # Pure-shell: read reviewDecision of the first PR.
    local rd
    rd="$(printf '%s' "$raw" | sed -nE 's/.*"reviewDecision"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p' | head -1)"
    case "$rd" in
      CHANGES_REQUESTED) echo "block" ;;
      APPROVED|COMMENTED) echo "ok" ;;
      *) echo "—" ;;
    esac
    return 0
  fi
  node -e '
    try {
      const arr = JSON.parse(require("fs").readFileSync(0, "utf8"));
      if (!Array.isArray(arr) || arr.length === 0) { process.stdout.write("—"); process.exit(0); }
      // Pick most recent updatedAt.
      arr.sort((a, b) => Date.parse(b.updatedAt || 0) - Date.parse(a.updatedAt || 0));
      const p = arr[0];
      const rd = (p.reviewDecision || "").toUpperCase();
      const ts = Date.parse(p.updatedAt || 0) / 1000 || 0;
      const now = parseInt(process.argv[1] || "0", 10) || 0;
      const diff = Math.max(0, now - ts);
      let age;
      if (diff < 3600) age = Math.floor(diff / 60) + "m";
      else if (diff < 86400) age = Math.floor(diff / 3600) + "h";
      else age = Math.floor(diff / 86400) + "d";
      let tag;
      if (rd === "CHANGES_REQUESTED") tag = "block";
      else if (rd === "APPROVED" || rd === "COMMENTED") tag = "ok";
      else { process.stdout.write("—"); process.exit(0); }
      process.stdout.write(tag + " " + age);
    } catch (e) { process.stdout.write("—"); }
  ' "$now" <<<"$raw"
}

# Compute the STATE for one project. Reuses digest_state for
# EXPIRED/PAUSED/OVER-BUDGET (and THROTTLED, which we collapse into OK for
# this surface — the ticket lists STATE as exactly six values, no THROTTLED).
# Then we add STUCK (open PR >24h old with no commit in 6h, when gh works)
# and HEAL (in-flight PR has a `heal:` commit).
overview_state() {
  local self_cancel="$1" spend_today="$2" cap="$3" namespace="$4" cache_dir="$5"
  local repo="$6" inflight_number="$7" inflight_epoch="$8" now="$9"
  # Reuse digest_state for the first three.
  local base
  base="$(digest_state "$self_cancel" "$spend_today" "$cap" "$namespace" "$cache_dir")"
  case "$base" in
    EXPIRED|PAUSED|OVER-BUDGET) echo "$base"; return 0 ;;
    THROTTLED) ;;  # not part of overview's STATE vocabulary → fall through
  esac
  # STUCK: open agent PR older than 24h with no commit in the last 6h.
  # "no commit in the last 6h" is approximated by updatedAt — `gh pr list`'s
  # updatedAt advances on every push, so an old PR with a stale updatedAt
  # qualifies. We require both: (PR_age > 24h) AND (updated_age > 6h).
  if [ -n "$inflight_number" ] && [ -n "$inflight_epoch" ] && [ "$inflight_epoch" -gt 0 ]; then
    # PR age is computed from createdAt, which we don't have in the cached
    # JSON — proxy with `updatedAt < (now - 24h)`. If updatedAt is more than
    # 24h ago, the PR is necessarily older than 24h AND has been quiet for
    # 24h+ (which is a strict superset of "no commit in 6h"). Cheap, correct
    # for the day-2 surface.
    local updated_age=$(( now - inflight_epoch ))
    if [ "$updated_age" -gt 86400 ]; then
      echo "STUCK"; return 0
    fi
  fi
  # HEAL: in-flight PR has a `heal:` commit. We use `gh pr view --json
  # commits` when gh is available; otherwise skip.
  if command -v gh >/dev/null 2>&1 && [ -n "$inflight_number" ] && [ -n "$repo" ]; then
    local commits
    commits="$(gh pr view "$inflight_number" \
                 --repo "$repo" \
                 --json commits \
                 2>/dev/null)" || true
    if [ -n "$commits" ] && echo "$commits" | grep -q '"messageHeadline"[[:space:]]*:[[:space:]]*"heal:'; then
      echo "HEAL"; return 0
    fi
  fi
  echo "OK"
}

# Human-form table row.
overview_render_human() {
  local slug="$1" ship_age="$2" review="$3" sendbk="$4" spend="$5"
  local inflight_label="$6" state="$7"
  printf '%-14s %-10s %-10s %-7s %-9s %-16s %s\n' \
    "$slug" "$ship_age" "$review" "$sendbk" "\$$spend" "$inflight_label" "$state"
}

overview() {
  shift  # drop the leading "overview"
  local want_json=0 slug_filter=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) want_json=1; shift ;;
      --slug) slug_filter="${2:-}"; shift 2 ;;
      --slug=*) slug_filter="${1#--slug=}"; shift ;;
      -h|--help)
        cat <<USAGE
fleet overview — single-glance cross-project health table.

Usage:
  fleet overview                 survey every discovered project
  fleet overview --slug NAME     restrict to one project
  fleet overview --json          machine-readable array

Columns:
  PROJECT   slug from manifest
  SHIP      age of newest ~/.cache/<slug>-agent/logs/ship-*.log
  REVIEW    last review verdict (ok N / block N) or "—"
  SENDBK    count of --request-changes reviews on agent PRs (trailing 24h)
  \$TODAY    today's UTC sum from runs.jsonl
  IN-FLIGHT lowest open feat/ or eng/ PR + GREEN/RED/PENDING/BEHIND/DIRTY
            ("—" when gh is offline/unauthenticated)
  STATE     one of OK / HEAL / PAUSED / OVER-BUDGET / EXPIRED / STUCK

JSON schema (one object per project):
  { slug, ship: {last_run_epoch, age_label},
    review: {last_verdict, age_label}, sendbk, spend_today_usd,
    inflight: {number, state, updated_epoch},
    state: {code, reason} }

Exit code: 1 when any project is EXPIRED, OVER-BUDGET, or STUCK; else 0.
HEAL and PAUSED are not red.
USAGE
        exit 0 ;;
      *) echo "fleet overview: unknown flag '$1'" >&2; exit 2 ;;
    esac
  done

  local now
  now="${FLEET_OVERVIEW_FAKE_NOW:-$(date -u +%s)}"

  # Print human header. The widths match overview_render_human's printf so
  # the columns line up under their labels.
  if [ "$want_json" != "1" ]; then
    printf '%-14s %-10s %-10s %-7s %-9s %-16s %s\n' \
      "PROJECT" "SHIP" "REVIEW" "SENDBK" "\$TODAY" "IN-FLIGHT" "STATE"
  fi

  local any_red=0
  local json_rows=""
  while IFS=$'\t' read -r slug manifest repo_url; do
    [ -z "$slug" ] && continue
    [ -n "$slug_filter" ] && [ "$slug" != "$slug_filter" ] && continue

    # Manifest probe — fetch what we need.
    local probe namespace self_cancel cap
    probe=$(
      # shellcheck disable=SC1090
      ( source "$manifest" 2>/dev/null
        echo "NAMESPACE=${NAMESPACE:-com.fleet.${SLUG:-x}}"
        echo "SELF_CANCEL=${SELF_CANCEL:-}"
        echo "MAX_DAILY_USD=${MAX_DAILY_USD:-}"
      ) 2>/dev/null
    ) || true
    namespace="$(echo "$probe" | sed -n 's/^NAMESPACE=//p')"
    self_cancel="$(echo "$probe" | sed -n 's/^SELF_CANCEL=//p')"
    cap="$(echo "$probe" | sed -n 's/^MAX_DAILY_USD=//p')"

    local cache_dir="$HOME/.cache/${slug}-agent"
    local runs="$cache_dir/runs.jsonl"
    local logs_dir="$cache_dir/logs"

    # SHIP: age of newest log file.
    local ship_epoch ship_age
    ship_epoch="$(newest_log_epoch "$logs_dir")"
    if [ -n "$ship_epoch" ]; then
      local diff=$(( now - ship_epoch ))
      if   [ "$diff" -lt 3600 ];  then ship_age="$(( diff/60 ))m ago"
      elif [ "$diff" -lt 86400 ]; then ship_age="$(( diff/3600 ))h ago"
      else ship_age="$(( diff/86400 ))d ago"; fi
    else
      ship_age="—"
    fi

    # Derive owner/repo from REPO_URL (https://github.com/owner/name[.git]).
    local repo
    repo="$(echo "$repo_url" | sed -E 's#https?://github.com/##; s#\.git$##')"

    # IN-FLIGHT: gh pr list. Returns "NUMBER|STATE|EPOCH" or empty.
    local inflight inflight_number="" inflight_state="" inflight_epoch=0
    inflight="$(overview_inflight "$repo")"
    if [ -n "$inflight" ]; then
      inflight_number="$(echo "$inflight" | cut -d'|' -f1)"
      inflight_state="$(echo "$inflight" | cut -d'|' -f2)"
      inflight_epoch="$(echo "$inflight" | cut -d'|' -f3)"
    fi

    # REVIEW + SENDBK: gh fallback (the `review_blocked` event type does not
    # exist yet — engineering note in the ticket; documented in the
    # implementation log). When gh is offline both gracefully degrade.
    local review_label sendbk
    review_label="$(overview_last_review "$repo" "$now")"
    sendbk="$(overview_sendback_count "$repo")"

    # $TODAY: today's UTC spend from runs.jsonl.
    local spend_today
    spend_today="$(digest_spend_today "$runs")"

    # STATE: digest_state for the first three; overview_state adds STUCK/HEAL.
    local state
    state="$(overview_state \
              "$self_cancel" "$spend_today" "$cap" "$namespace" "$cache_dir" \
              "$repo" "$inflight_number" "$inflight_epoch" "$now")"

    case "$state" in
      EXPIRED|OVER-BUDGET|STUCK) any_red=1 ;;
    esac

    # IN-FLIGHT human label. "#N STATE" or "—" when no PR / gh offline.
    local inflight_label
    if [ -n "$inflight_number" ]; then
      inflight_label="#${inflight_number} ${inflight_state}"
    else
      inflight_label="—"
    fi

    if [ "$want_json" = "1" ]; then
      local esc_slug esc_state esc_review esc_inflight_state
      esc_slug="$(doctor_json_escape "$slug")"
      esc_state="$(doctor_json_escape "$state")"
      esc_review="$(doctor_json_escape "$review_label")"
      esc_inflight_state="$(doctor_json_escape "$inflight_state")"
      local ship_epoch_json="${ship_epoch:-0}"
      local inflight_number_json="null"
      [ -n "$inflight_number" ] && inflight_number_json="$inflight_number"
      local inflight_epoch_json="${inflight_epoch:-0}"
      [ -n "$json_rows" ] && json_rows+=","
      json_rows+="{\"slug\":\"$esc_slug\""
      json_rows+=",\"ship\":{\"last_run_epoch\":$ship_epoch_json,\"age_label\":\"$(doctor_json_escape "$ship_age")\"}"
      json_rows+=",\"review\":{\"last_verdict\":\"$esc_review\"}"
      json_rows+=",\"sendbk\":$sendbk"
      json_rows+=",\"spend_today_usd\":$spend_today"
      json_rows+=",\"inflight\":{\"number\":$inflight_number_json,\"state\":\"$esc_inflight_state\",\"updated_epoch\":$inflight_epoch_json}"
      json_rows+=",\"state\":{\"code\":\"$esc_state\",\"reason\":\"\"}"
      json_rows+="}"
    else
      overview_render_human \
        "$slug" "$ship_age" "$review_label" "$sendbk" "$spend_today" \
        "$inflight_label" "$state"
    fi
  done < <(overview_discover)

  if [ "$want_json" = "1" ]; then
    printf '[%s]\n' "$json_rows"
  fi

  [ "$any_red" = "1" ] && exit 1
  exit 0
}

if [ "$CMD" = "overview" ]; then
  overview "$@"
fi

# --- lessons-sync ---------------------------------------------------------
# Ticket 0009. `fleet lessons-sync` walks every discovered project, reads
# its docs/LESSONS.md, and writes one merged file at
# $HOME/.local/share/agent-fleet/CROSS_LESSONS.md so the ship/groom prompts
# (and any human running `less`) can see what every project in the fleet
# has learned.
#
# Discovery reuses the same two-root pattern as `doctor`/`tail`/`rollback`:
#   1. $FLEET_DISCOVERY_ROOT (default ~/Desktop/projects)
#   2. ~/.local/share/agent-fleet/projects
# De-duped by SLUG, working-tree manifests winning over installed copies
# (so a project that's currently on a feature branch is read from the
# source tree, not the stale install).
#
# Output format:
#   # CROSS_LESSONS
#   <intro paragraph>
#
#   ## <slug-A>
#
#   <body of <slug-A>'s docs/LESSONS.md verbatim, MINUS its leading `# ...`
#    title and the introductory paragraph immediately after it — those are
#    boilerplate that would duplicate across every section. Subsection
#    headings (`## ...`) are demoted to `### ...` so the project heading
#    stays at the top of its block.>
#
#   ## <slug-B>
#   ...
#
# De-dup (AC#B): a paragraph (`\n\n`-separated block) whose body is
# byte-identical to one already emitted under another slug is dropped on
# the second appearance AND replaced with a single
# `> Already seen under ## <other-slug>` reference line under the current
# slug's heading. The lesson LINE inside that paragraph also picks up an
# `(also seen in <other-slug>)` annotation when first emitted, so an
# operator skimming the file sees the cross-project signal without having
# to grep.
#
# Idempotency (AC#C): we compute the proposed output in memory and only
# overwrite the destination when its sha differs. mtime stays put when
# bytes are unchanged — matters because consumers (fleet-control, the
# launchd label that triggers `tail -F`) may treat mtime as freshness.
#
# AC#G: a project without docs/LESSONS.md is silently skipped — no
# heading, no error, no entry in the merged file. The ticket calls this
# out explicitly.

lessons_sync_discover() {
  local discovery_root="${FLEET_DISCOVERY_ROOT:-$HOME/Desktop/projects}"
  local installed_root="$HOME/.local/share/agent-fleet/projects"
  local _seen="" m slug dir
  { find "$discovery_root" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
    find "$installed_root" -maxdepth 2 -name agents.config.sh 2>/dev/null | sort
  } | while read -r m; do
    [ -z "$m" ] && continue
    # shellcheck disable=SC1090
    slug=$( (source "$m"; echo "${SLUG:-}") 2>/dev/null )
    [ -z "$slug" ] && continue
    case " $_seen " in *" $slug "*) continue ;; esac
    _seen="$_seen $slug"
    dir="$(dirname "$m")"
    printf '%s\t%s\n' "$slug" "$dir"
  done
}

# Strip the leading `# Title\n\n<intro paragraph>\n\n` boilerplate from a
# LESSONS.md body. The intro is everything before the FIRST `## ` heading
# (or the whole file if there are no `## ` headings — in that case we
# keep the body unchanged so a sparse LESSONS.md still surfaces).
lessons_sync_strip_intro() {
  awk '
    BEGIN { skipping = 1 }
    {
      if (skipping && $0 ~ /^## /) skipping = 0
      if (!skipping) print
    }
  '
}

# Demote `## X` → `### X` so each projects subsection sits under its own
# project heading without colliding with another `##` block.
lessons_sync_demote() {
  sed -E 's/^## /### /'
}

lessons_sync() {
  shift  # drop the leading "lessons-sync"
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help)
        cat <<USAGE
fleet lessons-sync — merge every project's docs/LESSONS.md into one file.

Usage:
  fleet lessons-sync

Writes \$HOME/.local/share/agent-fleet/CROSS_LESSONS.md. Idempotent: the
file is only rewritten when content would change. Projects without a
docs/LESSONS.md are skipped silently.

Discovers projects via FLEET_DISCOVERY_ROOT (default ~/Desktop/projects)
AND ~/.local/share/agent-fleet/projects, de-duped by SLUG.
USAGE
        exit 0 ;;
      *) echo "fleet lessons-sync: unknown flag '$1'" >&2; exit 2 ;;
    esac
  done

  local dest_dir="$HOME/.local/share/agent-fleet"
  local dest="$dest_dir/CROSS_LESSONS.md"
  mkdir -p "$dest_dir"

  # Phase 1: collect (slug, lessons_path) rows for every project that has a
  # docs/LESSONS.md. Skip projects without one (AC#G).
  local rows=""
  while IFS=$'\t' read -r slug dir; do
    [ -z "$slug" ] && continue
    local lessons_file="$dir/docs/LESSONS.md"
    [ -f "$lessons_file" ] || continue
    rows="${rows}${slug}"$'\t'"${lessons_file}"$'\n'
  done < <(lessons_sync_discover)

  # Phase 2: render the merged document into a tmpfile, then atomically
  # compare against the existing file's sha. The rendering uses a small
  # python pass because the cross-slug dedup needs paragraph-level state
  # that awk handles badly across multiple files. python3 ships with
  # macOS via the Command Line Tools; if it's missing we fall back to a
  # shell-only implementation that omits the dedup annotation (still
  # passes AC#A, but logs a warning).
  local tmp; tmp="$(mktemp -t fleet-lessons.XXXXXX)"
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$tmp" <<'PY' "$rows"
import hashlib, os, re, sys
out_path = sys.argv[1]
raw_rows = sys.argv[2] if len(sys.argv) > 2 else ""
rows = []
for line in raw_rows.splitlines():
    if not line.strip():
        continue
    parts = line.split("\t")
    if len(parts) < 2:
        continue
    rows.append((parts[0], parts[1]))

def strip_intro(text):
    """Drop everything before the first '## ' heading. If there is none,
    keep the body unchanged (sparse LESSONS.md still surfaces). The
    project-level `# Title` line + any intro paragraph are dropped.
    """
    lines = text.splitlines()
    out = []
    started = False
    for ln in lines:
        if not started and ln.startswith("## "):
            started = True
        if started:
            out.append(ln)
    return "\n".join(out) if started else text

def demote(text):
    return re.sub(r"(?m)^## ", "### ", text)

def split_paragraphs(text):
    # Paragraphs are blank-line separated blocks. We keep each block's
    # leading whitespace stripped for dedup hashing but emit the raw
    # block verbatim. Headings (### ...) start a new paragraph; we treat
    # the heading line as a paragraph of its own so two identical body
    # paragraphs under different headings still dedup correctly.
    paras = []
    cur = []
    for ln in text.splitlines():
        if ln.strip() == "":
            if cur:
                paras.append("\n".join(cur))
                cur = []
        else:
            cur.append(ln)
    if cur:
        paras.append("\n".join(cur))
    return paras

# Body-hash → slug-of-first-appearance. We dedup on the paragraph body
# minus a trailing `(also seen in ...)` annotation so re-runs are stable.
seen = {}
# Per-slug list of (kind, payload). kind is "para" (verbatim emit), or
# "ref" (emit a `> Already seen under ## <slug>` line).
per_slug = []

for slug, path in rows:
    try:
        body = open(path, encoding="utf-8").read()
    except OSError:
        continue
    body = strip_intro(body)
    body = demote(body)
    paras = split_paragraphs(body)
    emitted = []
    for p in paras:
        # Hash ignores any existing `(also seen in ...)` tag so reruns
        # don't keep adding nesting layers.
        key = re.sub(r"\s*\(also seen in [^)]+\)", "", p).strip()
        if not key:
            continue
        if key in seen and seen[key] != slug:
            emitted.append(("ref", seen[key]))
        else:
            if key not in seen:
                seen[key] = slug
                # Annotate the lesson line with "(also seen in ...)" if
                # we discover later that another project shares it. We
                # do that in a second pass below; for now stash the
                # paragraph verbatim.
                emitted.append(("para", p))
            else:
                # Same slug repeats the same paragraph (rare; keep once)
                pass
    per_slug.append((slug, emitted))

# Second pass: for every paragraph body that's referenced by a OTHER
# slug, collect the referrer slugs keyed by the paragraph body's hash.
# `seen[key]` is the FIRST emitter slug for that body; any other slug
# that hit the body emitted a ("ref", first_emitter) row, so the set of
# referrers is "every slug that emitted a ref pointing at the body's
# first emitter AND whose own body matches key".
para_referrers = {}  # body_key -> set(referrer_slugs)
# We need to know which body key each ref corresponds to. Rebuild the
# per_slug walk to capture that: any "ref" was preceded by a body that
# matched an already-seen key — store the key alongside the ref.
per_slug_v2 = []
seen_v2 = {}
for slug, path in rows:
    try:
        body = open(path, encoding="utf-8").read()
    except OSError:
        continue
    body = strip_intro(body)
    body = demote(body)
    paras = split_paragraphs(body)
    emitted = []
    for p in paras:
        key = re.sub(r"\s*\(also seen in [^)]+\)", "", p).strip()
        if not key:
            continue
        if key in seen_v2 and seen_v2[key] != slug:
            emitted.append(("ref", seen_v2[key], key))
            para_referrers.setdefault(key, set()).add(slug)
        elif key not in seen_v2:
            seen_v2[key] = slug
            emitted.append(("para", p, key))
    per_slug_v2.append((slug, emitted))

per_slug = per_slug_v2
seen = seen_v2

# Re-render per slug:
chunks = ["# CROSS_LESSONS",
          "",
          "Auto-generated by `fleet lessons-sync`. Do not edit by hand —",
          "your edits will be overwritten on the next sync. The source of",
          "truth is each project's `docs/LESSONS.md`.",
          ""]
for slug, emitted in per_slug:
    if not emitted:
        continue
    chunks.append(f"## {slug}")
    chunks.append("")
    for row in emitted:
        kind = row[0]
        if kind == "para":
            payload = row[1]
            key = row[2]
            # If THIS paragraph body is referenced by other slugs, annotate
            # its first non-heading content line with `(also seen in ...)`.
            others = sorted(para_referrers.get(key, set()) - {slug})
            if others:
                lines = payload.splitlines()
                for i, ln in enumerate(lines):
                    if ln.startswith("###") or ln.strip() == "":
                        continue
                    if "(also seen in" in ln:
                        break
                    lines[i] = ln.rstrip() + f" (also seen in {', '.join(others)})"
                    break
                payload = "\n".join(lines)
            chunks.append(payload)
            chunks.append("")
        elif kind == "ref":
            target_slug = row[1]
            chunks.append(f"> Already seen under ## {target_slug}")
            chunks.append("")

text = "\n".join(chunks).rstrip() + "\n"
open(out_path, "w", encoding="utf-8").write(text)
PY
  else
    # Shell-only fallback. AC#A still passes; AC#B's annotation does not.
    {
      printf '# CROSS_LESSONS\n\n'
      printf 'Auto-generated by `fleet lessons-sync`. Do not edit by hand —\n'
      printf 'your edits will be overwritten on the next sync. The source of\n'
      printf "truth is each project's \`docs/LESSONS.md\`.\n\n"
      while IFS=$'\t' read -r slug path; do
        [ -z "$slug" ] && continue
        printf '## %s\n\n' "$slug"
        lessons_sync_strip_intro < "$path" | lessons_sync_demote
        printf '\n'
      done <<<"$rows"
    } > "$tmp"
    echo "fleet lessons-sync: python3 not found — dedup annotation skipped" >&2
  fi

  # Idempotency: write only when content differs (AC#C).
  if [ -f "$dest" ]; then
    local old_sha new_sha
    old_sha=$(shasum "$dest" 2>/dev/null | awk '{print $1}')
    new_sha=$(shasum "$tmp"  2>/dev/null | awk '{print $1}')
    if [ "$old_sha" = "$new_sha" ]; then
      rm -f "$tmp"
      exit 0
    fi
  fi
  mv -f "$tmp" "$dest"
  exit 0
}

if [ "$CMD" = "lessons-sync" ]; then
  lessons_sync "$@"
fi

if [ "$CMD" = "list" ]; then
  echo "${c_bld}fleet projects under $ROOT${c_rst}"
  while read -r m; do
    [ -z "$m" ] && continue
    # shellcheck disable=SC1090
    ( source "$m"; printf "  %-14s %s\n" "${SLUG:-?}" "$(dirname "$m")" )
  done < <(discover)
  exit 0
fi

printf "${c_bld}%-12s %-9s %-11s %-7s %-9s %s${c_rst}\n" \
  PROJECT INSTALLED "LAST RUN" PRS LESSONS "SELF-CANCEL"
echo "${c_dim}$(printf '%.0s─' {1..68})${c_rst}"

while read -r m; do
  [ -z "$m" ] && continue
  PROJECT_DIR="$(dirname "$m")"

  # Read manifest in a subshell so vars don't leak between projects.
  eval "$(
    # shellcheck disable=SC1090
    source "$m"
    echo "SLUG='${SLUG:-?}'"
    echo "NS='${NAMESPACE:-com.fleet.${SLUG:-x}}'"
    echo "REPO='$(echo "${REPO_URL:-}" | sed -E 's#https?://github.com/##; s#\.git$##')'"
    echo "SC='${SELF_CANCEL:-}'"
    echo "ENG='${ENG_ENABLED:-0}'"
  )"
  [ -n "$WANT" ] && [ "$WANT" != "$SLUG" ] && continue

  # installed? — count loaded launchd jobs for this namespace
  loaded=0
  for s in ship groom review eng; do
    launchctl print "$DOMAIN/$NS.agent-$s" >/dev/null 2>&1 && loaded=$(( loaded+1 ))
  done
  expected=3; [ "$ENG" = "1" ] && expected=4
  if   [ $loaded -eq 0 ];         then inst="${c_red}no${c_rst}      "
  elif [ $loaded -lt $expected ]; then inst="${c_ylw}$loaded/$expected${c_rst}     "
  else inst="${c_grn}yes${c_rst}     "; fi

  last="$(human_age "$(newest_log_epoch "$HOME/.cache/${SLUG}-agent/logs")")"

  # open agent PRs (best-effort; needs gh auth + network)
  prs="—"
  if command -v gh >/dev/null 2>&1 && [ -n "$REPO" ]; then
    n=$(gh pr list --repo "$REPO" --state open --base main \
          --json headRefName --jq \
          '[.[] | select(.headRefName | test("^(feat/|chore/gtm-|eng/)"))] | length' \
          2>/dev/null)
    [ -n "$n" ] && prs="$n"
  fi

  # lessons count — try the repo working tree, then the agent's fresh checkout
  # (so it resolves even when discovery used the installed manifest).
  les="—"
  for lf in "$PROJECT_DIR/docs/LESSONS.md" "$PROJECT_DIR/LESSONS.md" \
            "$HOME/.cache/${SLUG}-agent/checkout/docs/LESSONS.md" \
            "$HOME/.cache/${SLUG}-agent/checkout/LESSONS.md"; do
    [ -f "$lf" ] && { les=$(grep -cE '^(- |## )' "$lf" 2>/dev/null); break; }
  done

  # self-cancel
  if [ -n "$SC" ]; then
    d=$(days_until "$SC")
    if   [ "$d" -lt 0 ];  then sc="${c_red}EXPIRED ($SC)${c_rst}"
    elif [ "$d" -le 3 ];  then sc="${c_ylw}${d}d ($SC)${c_rst}"
    else sc="${c_dim}${d}d${c_rst}"; fi
  else sc="${c_dim}—${c_rst}"; fi

  printf "%-12s %b %-11s %-7s %-9s %b\n" "$SLUG" "$inst" "$last" "$prs" "$les" "$sc"
done < <(discover)

echo
echo "${c_dim}installed=launchd jobs loaded · last run=newest log · prs=open agent PRs · self-cancel=days left${c_rst}"
